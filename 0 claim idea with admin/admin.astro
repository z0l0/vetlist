---
import Layout from '../layouts/Layout.astro';
import { loadAllCsvData } from '../lib/csvToJson.js';

const allCsvData = loadAllCsvData();
---

<Layout title="Admin - Update CSV Records">
  <div class="min-h-screen bg-gray-50 py-8">
    <div class="max-w-6xl mx-auto px-4">
      <div class="bg-white rounded-xl shadow-lg p-8">
        <h1 class="text-3xl font-bold text-gray-900 mb-8">
          <span class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-8 h-8 text-primary-600">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            Admin Panel - Update CSV Records
          </span>
        </h1>

        <!-- Email Input Section -->
        <div class="mb-8">
          <label for="email-content" class="block text-lg font-semibold text-gray-700 mb-3">
            Paste Claim Email Content:
          </label>
          <textarea 
            id="email-content" 
            rows="12" 
            class="w-full p-4 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 font-mono text-sm"
            placeholder="Paste the claim email content here..."
          ></textarea>
          <button 
            id="parse-email" 
            class="mt-4 bg-primary-600 hover:bg-primary-700 text-white px-6 py-3 rounded-lg font-medium transition-colors"
          >
            Parse Email & Find Practice
          </button>
        </div>

        <!-- Results Section -->
        <div id="results-section" class="hidden">
          <div class="border-t pt-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-6">Review Changes</h2>
            
            <!-- Search Results -->
            <div id="search-results" class="mb-6"></div>
            
            <!-- Comparison Table -->
            <div id="comparison-section" class="hidden">
              <div class="bg-gray-50 rounded-lg p-6 mb-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Current vs New Data</h3>
                <div class="overflow-x-auto">
                  <table class="w-full text-sm">
                    <thead>
                      <tr class="border-b">
                        <th class="text-left py-2 px-3 font-medium text-gray-700">Field</th>
                        <th class="text-left py-2 px-3 font-medium text-gray-700">Current</th>
                        <th class="text-left py-2 px-3 font-medium text-gray-700">New</th>
                        <th class="text-left py-2 px-3 font-medium text-gray-700">Status</th>
                      </tr>
                    </thead>
                    <tbody id="comparison-table">
                    </tbody>
                  </table>
                </div>
              </div>
              
              <div class="flex gap-4">
                <button 
                  id="approve-changes" 
                  class="bg-green-600 hover:bg-green-700 text-white px-8 py-3 rounded-lg font-medium transition-colors"
                >
                  Approve & Update CSV
                </button>
                <button 
                  id="cancel-changes" 
                  class="bg-gray-500 hover:bg-gray-600 text-white px-8 py-3 rounded-lg font-medium transition-colors"
                >
                  Cancel
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- Status Messages -->
        <div id="status-message" class="hidden mt-6 p-4 rounded-lg"></div>
      </div>
    </div>
  </div>
</Layout>
<script define:vars={{ allCsvData }} is:inline>
  window.allCsvData = allCsvData;
  let currentPracticeData = null;
  let parsedEmailData = null;

  function parseEmail(emailContent) {
    const data = {};
    
    const nameMatch = emailContent.match(/Practice Name:\s*(.+)/i);
    if (nameMatch) data.name = nameMatch[1].trim();
    
    const phoneMatch = emailContent.match(/Phone:\s*(.+)/i);
    if (phoneMatch) data.phone_number = phoneMatch[1].trim();
    
    const emailMatch = emailContent.match(/Email:\s*(.+)/i);
    if (emailMatch) data.email_address = emailMatch[1].trim();
    
    const websiteMatch = emailContent.match(/Website:\s*(.+)/i);
    if (websiteMatch) data.website = websiteMatch[1].trim();
    
    const addressMatch = emailContent.match(/ADDRESS:\s*(.+?)(?=\n[A-Z]|\nSERVICES|$)/is);
    if (addressMatch) {
      const addressLines = addressMatch[1].trim().split('\n').filter(line => line.trim());
      if (addressLines.length > 0) {
        data.address = addressLines[0].trim();
        for (let line of addressLines) {
          if (line.includes(',')) {
            const parts = line.split(',').map(p => p.trim());
            if (parts.length >= 2) {
              data.city = parts[0];
              data.province = parts[1];
              if (parts.length >= 3) data.country = parts[2];
            }
          }
        }
      }
    }
    
    const servicesMatch = emailContent.match(/SERVICES OFFERED:\s*(.+?)(?=\nHOURS|$)/is);
    if (servicesMatch) {
      data.specialization = servicesMatch[1].trim().split(',').map(s => s.trim());
    }
    
    const hoursMatch = emailContent.match(/HOURS OF OPERATION:\s*(.+?)(?=\nVERIFICATION|$)/is);
    if (hoursMatch) {
      const hoursText = hoursMatch[1].trim();
      const hours = {};
      const dayMap = {
        'monday': '1', 'tuesday': '2', 'wednesday': '3', 'thursday': '4',
        'friday': '5', 'saturday': '6', 'sunday': '7'
      };
      
      hoursText.split('\n').forEach(line => {
        const match = line.match(/(\w+):\s*(.+)/i);
        if (match) {
          const day = match[1].toLowerCase();
          const time = match[2].trim();
          const dayNum = dayMap[day];
          if (dayNum) {
            if (time.toLowerCase().includes('closed')) {
              hours[dayNum] = [];
            } else {
              const timeFormatted = time.replace(/\s*-\s*/, '-');
              hours[dayNum] = [timeFormatted];
            }
          }
        }
      });
      data.hours_of_operation = JSON.stringify(hours);
    }
    
    return data;
  }

  function searchPractice(practiceData) {
    try {
      const allData = window.allCsvData;
      
      // Search across all CSV files
      for (const [fileName, records] of Object.entries(allData)) {
        for (let i = 0; i < records.length; i++) {
          const record = records[i];
          
          // Search by name
          if (record.name && practiceData.name && 
              record.name.toLowerCase().includes(practiceData.name.toLowerCase())) {
            return { 
              record, 
              lineIndex: i, 
              headers: Object.keys(record),
              sourceFile: fileName,
              csvFileName: fileName + '.csv'
            };
          }
          
          // Search by phone
          if (record.phone_number && practiceData.phone_number && 
              record.phone_number === practiceData.phone_number) {
            return { 
              record, 
              lineIndex: i, 
              headers: Object.keys(record),
              sourceFile: fileName,
              csvFileName: fileName + '.csv'
            };
          }
        }
      }
      
      return null;
    } catch (error) {
      console.error('Error searching practice:', error);
      return null;
    }
  }



  function displayComparison(currentRecord, newData) {
    const comparisonTable = document.getElementById('comparison-table');
    comparisonTable.innerHTML = '';
    
    const fieldsToCompare = [
      'name', 'phone_number', 'email_address', 'website', 'address', 
      'city', 'province', 'country', 'specialization', 'hours_of_operation'
    ];
    
    fieldsToCompare.forEach(field => {
      const currentValue = currentRecord[field] || '';
      const newValue = newData[field] || '';
      
      let displayCurrent = currentValue;
      let displayNew = newValue;
      
      if (Array.isArray(newValue)) {
        displayNew = newValue.join(', ');
      }
      if (field === 'specialization' && currentValue.startsWith('[')) {
        try {
          const parsed = JSON.parse(currentValue);
          displayCurrent = Array.isArray(parsed) ? parsed.join(', ') : currentValue;
        } catch (e) {
          // Keep original if parsing fails
        }
      }
      
      const isChanged = displayCurrent !== displayNew;
      const row = document.createElement('tr');
      row.className = isChanged ? 'bg-yellow-50' : '';
      
      row.innerHTML = `
        <td class="py-2 px-3 font-medium">${field.replace(/_/g, ' ')}</td>
        <td class="py-2 px-3 text-gray-600 max-w-xs truncate">${displayCurrent}</td>
        <td class="py-2 px-3 text-gray-900 max-w-xs truncate">${displayNew}</td>
        <td class="py-2 px-3">
          ${isChanged ? 
            '<span class="bg-yellow-100 text-yellow-800 px-2 py-1 rounded text-xs">Changed</span>' : 
            '<span class="bg-gray-100 text-gray-600 px-2 py-1 rounded text-xs">Same</span>'
          }
        </td>
      `;
      
      comparisonTable.appendChild(row);
    });
  }

  function showStatus(message, type) {
    const statusEl = document.getElementById('status-message');
    statusEl.className = `mt-6 p-4 rounded-lg ${
      type === 'success' ? 'bg-green-50 text-green-800 border border-green-200' :
      type === 'error' ? 'bg-red-50 text-red-800 border border-red-200' :
      type === 'warning' ? 'bg-yellow-50 text-yellow-800 border border-yellow-200' :
      'bg-blue-50 text-blue-800 border border-blue-200'
    }`;
    statusEl.textContent = message;
    statusEl.classList.remove('hidden');
    
    if (type === 'success' || type === 'info') {
      setTimeout(() => statusEl.classList.add('hidden'), 5000);
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('parse-email').addEventListener('click', async () => {
      const emailContent = document.getElementById('email-content').value.trim();
      if (!emailContent) {
        showStatus('Please paste email content first.', 'error');
        return;
      }
      
      showStatus('Parsing email and searching for practice...', 'info');
      
      parsedEmailData = parseEmail(emailContent);
      console.log('Parsed email data:', parsedEmailData);
      
      if (!parsedEmailData.name) {
        showStatus('Could not find practice name in email.', 'error');
        return;
      }
      
      const searchResult = searchPractice(parsedEmailData);
      
      if (searchResult) {
        currentPracticeData = searchResult;
        document.getElementById('search-results').innerHTML = `
          <div class="bg-green-50 border border-green-200 rounded-lg p-4 mb-4">
            <h4 class="font-semibold text-green-800">✓ Practice Found</h4>
            <p class="text-green-700">Found: ${searchResult.record.name}</p>
            <p class="text-green-600 text-sm mt-1">Source: ${searchResult.csvFileName} (line ${searchResult.lineIndex + 1})</p>
          </div>
        `;
        
        displayComparison(searchResult.record, parsedEmailData);
        document.getElementById('comparison-section').classList.remove('hidden');
        showStatus('Practice found! Review the changes below.', 'success');
      } else {
        document.getElementById('search-results').innerHTML = `
          <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-4">
            <h4 class="font-semibold text-red-800">✗ Practice Not Found</h4>
            <p class="text-red-700">No matching practice found for: ${parsedEmailData.name}</p>
          </div>
        `;
        showStatus('Practice not found in CSV.', 'error');
      }
      
      document.getElementById('results-section').classList.remove('hidden');
    });

    // Add event listeners for approve and cancel buttons
    document.addEventListener('click', function(e) {
      if (e.target.id === 'approve-changes') {
        if (!currentPracticeData || !parsedEmailData) return;
        
        showStatus('CSV update functionality needs server endpoint. Changes logged to console.', 'warning');
        console.log('Would update record:', currentPracticeData.record);
        console.log('With new data:', parsedEmailData);
        console.log('In file:', currentPracticeData.csvFileName);
        console.log('At line:', currentPracticeData.lineIndex + 1);
        
        // Show what the updated record would look like
        const updatedRecord = { ...currentPracticeData.record };
        Object.keys(parsedEmailData).forEach(key => {
          if (parsedEmailData[key]) {
            updatedRecord[key] = parsedEmailData[key];
          }
        });
        console.log('Updated record would be:', updatedRecord);
      }
      
      if (e.target.id === 'cancel-changes') {
        document.getElementById('results-section').classList.add('hidden');
        document.getElementById('email-content').value = '';
        currentPracticeData = null;
        parsedEmailData = null;
        showStatus('Changes cancelled.', 'info');
      }
    });
  });
</script>