---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import {
  DEFAULT_OG_IMAGE_HEIGHT,
  DEFAULT_OG_IMAGE_TYPE,
  DEFAULT_OG_IMAGE_WIDTH,
  getDefaultOgImageUrl,
  toAbsoluteUrl,
} from "../lib/seo.js";

interface Props {
  title: string;
  description?: string;
  openGraph?: any;
  twitterCard?: any;
  noindex?: boolean;
}

const {
  title,
  description = "Find the best veterinarians in your area with VetList.org",
  openGraph,
  twitterCard,
  noindex = false,
} = Astro.props;

let pathname = Astro.url.pathname;
if (!pathname.endsWith('/') && pathname !== '/') {
  pathname += '/';
}
const canonicalURL = new URL(pathname, "https://vetlist.org").toString();
const resolvedTitle = title.includes('VetList') ? title : `${title} | VetList.org`;
const defaultSocialImage = getDefaultOgImageUrl();
const socialImage = toAbsoluteUrl(openGraph?.image || twitterCard?.image || defaultSocialImage) || defaultSocialImage;
const socialImageAlt = openGraph?.imageAlt || twitterCard?.imageAlt || `${title} | VetList.org`;
const resolvedOpenGraph = {
  type: "website",
  url: canonicalURL,
  title: title,
  description,
  siteName: "VetList.org",
  locale: "en_US",
  image: socialImage,
  imageAlt: socialImageAlt,
  imageWidth: openGraph?.imageWidth || DEFAULT_OG_IMAGE_WIDTH,
  imageHeight: openGraph?.imageHeight || DEFAULT_OG_IMAGE_HEIGHT,
  imageType: openGraph?.imageType || DEFAULT_OG_IMAGE_TYPE,
  ...openGraph,
};
const resolvedTwitter = {
  card: socialImage ? "summary_large_image" : "summary",
  title: title,
  description,
  image: toAbsoluteUrl(twitterCard?.image || socialImage) || socialImage,
  imageAlt: twitterCard?.imageAlt || socialImageAlt,
  ...twitterCard,
};
if (!resolvedOpenGraph.image) resolvedOpenGraph.image = socialImage;
if (!resolvedOpenGraph.imageAlt) resolvedOpenGraph.imageAlt = socialImageAlt;
if (!resolvedOpenGraph.imageWidth) resolvedOpenGraph.imageWidth = DEFAULT_OG_IMAGE_WIDTH;
if (!resolvedOpenGraph.imageHeight) resolvedOpenGraph.imageHeight = DEFAULT_OG_IMAGE_HEIGHT;
if (!resolvedOpenGraph.imageType) resolvedOpenGraph.imageType = DEFAULT_OG_IMAGE_TYPE;
if (!resolvedTwitter.image) resolvedTwitter.image = socialImage;
if (!resolvedTwitter.imageAlt) resolvedTwitter.imageAlt = socialImageAlt;
if (!resolvedTwitter.card) resolvedTwitter.card = socialImage ? "summary_large_image" : "summary";
const robotsContent = noindex
  ? "noindex, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
  : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{resolvedTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="robots" content={robotsContent} />
    <meta name="theme-color" content="#020817" />
    <meta name="format-detection" content="telephone=no" />

	    <!-- Preconnect only to critical font domains -->
	    <link rel="preconnect" href="https://fonts.googleapis.com" />
	    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <!-- Preload critical font -->
    <link
	      rel="preload"
	      href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;900&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
	        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700;900&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Geo Meta Tags -->
    <meta name="geo.region" content="US" />
    <meta name="geo.region" content="CA" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={resolvedOpenGraph.type} />
    <meta property="og:url" content={resolvedOpenGraph.url} />
    <meta property="og:title" content={resolvedOpenGraph.title} />
    <meta property="og:description" content={resolvedOpenGraph.description} />
    <meta property="og:site_name" content={resolvedOpenGraph.siteName} />
    {resolvedOpenGraph.locale && (
      <meta property="og:locale" content={resolvedOpenGraph.locale} />
    )}
    {resolvedOpenGraph.image && (
      <meta property="og:image" content={resolvedOpenGraph.image} />
    )}
    {resolvedOpenGraph.image && (
      <meta property="og:image:secure_url" content={resolvedOpenGraph.image} />
    )}
    {resolvedOpenGraph.imageAlt && (
      <meta property="og:image:alt" content={resolvedOpenGraph.imageAlt} />
    )}
    {resolvedOpenGraph.imageWidth && (
      <meta property="og:image:width" content={String(resolvedOpenGraph.imageWidth)} />
    )}
    {resolvedOpenGraph.imageHeight && (
      <meta property="og:image:height" content={String(resolvedOpenGraph.imageHeight)} />
    )}
    {resolvedOpenGraph.imageType && (
      <meta property="og:image:type" content={resolvedOpenGraph.imageType} />
    )}

    <!-- Twitter -->
    <meta name="twitter:card" content={resolvedTwitter.card} />
    <meta name="twitter:title" content={resolvedTwitter.title} />
    <meta name="twitter:description" content={resolvedTwitter.description} />
    {resolvedTwitter.image && (
      <meta name="twitter:image" content={resolvedTwitter.image} />
    )}
    {resolvedTwitter.imageAlt && (
      <meta name="twitter:image:alt" content={resolvedTwitter.imageAlt} />
    )}


    <!-- Umami Analytics - Load after page interaction -->
    <script is:inline>
      // Load analytics after user interaction or page load
      function loadUmami() {
        if (window.umami) return; // Already loaded
        const script = document.createElement('script');
        script.defer = true;
        script.src = 'https://cloud.umami.is/script.js';
        script.setAttribute('data-website-id', 'e903c81c-e76f-4af1-9b51-8f919c421666');
        document.head.appendChild(script);
      }
      
      // Load on first user interaction
      ['mousedown', 'touchstart', 'keydown', 'scroll'].forEach(event => {
        document.addEventListener(event, loadUmami, { once: true, passive: true });
      });
      
      // Fallback: load after 3 seconds if no interaction
      setTimeout(loadUmami, 3000);
    </script>

    <!-- Inline critical CSS -->
    <style is:inline>
      /* Critical CSS - inlined for faster rendering */
      html {
        font-size: 17px;
        scroll-behavior: smooth;
      }
      
      body {
        font-size: 17px;
        -webkit-text-size-adjust: 100%;
        -moz-text-size-adjust: 100%;
        text-size-adjust: 100%;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      
      /* Hero gradient text effect */
      .hero-gradient-text {
        background: linear-gradient(135deg, #0066cc, #4a90e2);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      
      /* Hero gradient text effect */
      .hero-gradient-text {
        background: linear-gradient(135deg, #0066cc, #4a90e2);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      
      #search-flash-badge {
        will-change: opacity, transform;
        contain: layout style;
      }
      
      /* Optimize rendering performance */
      .searchable-item {
        contain: layout style;
      }
    </style>
    
    <!-- Load non-critical CSS asynchronously -->
    <link
      rel="preload"
      href="/styles/main.css"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript><link rel="stylesheet" href="/styles/main.css" /></noscript>
    
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-[radial-gradient(circle_at_top,_rgba(34,211,238,0.08),_transparent_28%),linear-gradient(180deg,#f8fbff_0%,#eef4fb_44%,#f8fafc_100%)] font-sans text-slate-900 flex flex-col">
    <Header />
    <main class="flex-1 mx-auto w-full max-w-[1600px] px-4 pb-16">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
