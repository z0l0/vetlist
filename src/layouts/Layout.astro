---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
  openGraph?: any;
  twitterCard?: any;
  noindex?: boolean;
}

const {
  title,
  description = "Find the best veterinarians in your area with VetList.org",
  openGraph,
  twitterCard,
  noindex = false,
} = Astro.props;
// Ensure canonical URL matches trailingSlash config
let pathname = Astro.url.pathname;
if (!pathname.endsWith('/') && pathname !== '/') {
  pathname += '/';
}
const canonicalURL = new URL(pathname, "https://vetlist.org").toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | VetList.org</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Conditional noindex for low-quality content -->
    {noindex && (
      <meta name="robots" content="noindex, follow" />
    )}
    <!-- Preconnect to external domains -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preconnect" href="https://cloud.umami.is" />
    <link rel="preconnect" href="https://api-gateway.umami.dev" />
    <link rel="preconnect" href="https://g13rpgtx1b-dsn.algolia.net" />
    
    <!-- Preload critical font -->
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
        rel="stylesheet"
      />
    </noscript>

    <!-- Open Graph / Facebook -->
    {
      openGraph && (
        <>
          <meta property="og:type" content={openGraph.type || "website"} />
          <meta property="og:url" content={openGraph.url || canonicalURL} />
          <meta property="og:title" content={openGraph.title || title} />
          <meta
            property="og:description"
            content={openGraph.description || description}
          />
          <meta
            property="og:site_name"
            content={openGraph.siteName || "VetList.org"}
          />
          {openGraph.image && (
            <meta property="og:image" content={openGraph.image} />
          )}
          {openGraph.locale && (
            <meta property="og:locale" content={openGraph.locale} />
          )}
        </>
      )
    }

    <!-- Twitter -->
    {
      twitterCard && (
        <>
          <meta
            name="twitter:card"
            content={twitterCard.card || "summary_large_image"}
          />
          <meta name="twitter:title" content={twitterCard.title || title} />
          <meta
            name="twitter:description"
            content={twitterCard.description || description}
          />
          {twitterCard.image && (
            <meta name="twitter:image" content={twitterCard.image} />
          )}
        </>
      )
    }


    <!-- Umami Analytics - Load after page interaction -->
    <script is:inline>
      // Load analytics after user interaction or page load
      function loadUmami() {
        if (window.umami) return; // Already loaded
        const script = document.createElement('script');
        script.defer = true;
        script.src = 'https://cloud.umami.is/script.js';
        script.setAttribute('data-website-id', 'e903c81c-e76f-4af1-9b51-8f919c421666');
        document.head.appendChild(script);
      }
      
      // Load on first user interaction
      ['mousedown', 'touchstart', 'keydown', 'scroll'].forEach(event => {
        document.addEventListener(event, loadUmami, { once: true, passive: true });
      });
      
      // Fallback: load after 3 seconds if no interaction
      setTimeout(loadUmami, 3000);
    </script>

    <!-- Inline critical CSS -->
    <style is:inline>
      /* Critical CSS - inlined for faster rendering */
      html {
        font-size: 17px;
        scroll-behavior: smooth;
      }
      
      body {
        font-size: 17px;
        -webkit-text-size-adjust: 100%;
        -moz-text-size-adjust: 100%;
        text-size-adjust: 100%;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
      }
      
      /* Hero gradient text effect */
      .hero-gradient-text {
        background: linear-gradient(135deg, #0066cc, #4a90e2);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      
      /* Hero gradient text effect */
      .hero-gradient-text {
        background: linear-gradient(135deg, #0066cc, #4a90e2);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      
      #search-flash-badge {
        will-change: opacity, transform;
        contain: layout style;
      }
      
      /* Optimize rendering performance */
      .searchable-item {
        contain: layout style;
      }
    </style>
    
    <!-- Load non-critical CSS asynchronously -->
    <link
      rel="preload"
      href="/styles/main.css"
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript><link rel="stylesheet" href="/styles/main.css" /></noscript>
    
    <slot name="head" />
  </head>
  <body class="bg-light font-sans flex flex-col min-h-screen">
    <Header />
    <main class="flex-1 container mx-auto px-4 pb-16 max-w-none -mt-2">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html {
    scroll-behavior: smooth;
  }
</style>
