                                <select
                                    id="claim-city-select"
                                    class="claim-finder-select w-full rounded-full border border-slate-300 bg-white px-5 py-4 pr-12 text-base text-slate-900 shadow-[0_8px_24px_rgba(15,23,42,0.08)] transition focus:border-cyan-400 focus:outline-none focus:ring-4 focus:ring-cyan-100 disabled:cursor-not-allowed disabled:bg-slate-100"
