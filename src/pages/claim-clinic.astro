                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="h-5 w-5">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
                                    </svg>
                                </div>
                            </div>
                        </div>
                        <div>
                            <label for="claim-region-select" class="block text-sm font-semibold uppercase tracking-[0.14em] text-slate-500 mb-3">
                                Province / State
                            </label>
                            <div class="relative">
                                <select
                                    id="claim-region-select"
                                    class="claim-finder-select w-full rounded-full border border-slate-300 bg-white px-5 py-4 pr-12 text-base text-slate-900 shadow-[0_8px_24px_rgba(15,23,42,0.08)] transition focus:border-cyan-400 focus:outline-none focus:ring-4 focus:ring-cyan-100 disabled:cursor-not-allowed disabled:bg-slate-100"
