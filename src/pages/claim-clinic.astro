                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Oncology</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Orthopedics"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Orthopedics</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Internal Medicine"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Internal Medicine</span
                            >
                        </label>

                        <!-- Specific Treatments -->
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="X-Ray/Imaging"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >X-Ray/Imaging</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Laboratory Services"
