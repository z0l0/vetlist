    function getBadgeThemeConfig(theme) {
        const themes = {
            light: {
                bg: "#ffffff",
                border: "#cbd5e1",
                accent: "#0f766e",
                accentSoft: "#ccfbf1",
                title: "#0f172a",
                body: "#334155",
            },
            dark: {
                bg: "#0f172a",
                border: "#1e293b",
                accent: "#22c55e",
                accentSoft: "#052e16",
                title: "#f8fafc",
                body: "#cbd5e1",
            },
            mint: {
                bg: "#f0fdf4",
                border: "#bbf7d0",
                accent: "#15803d",
                accentSoft: "#dcfce7",
                title: "#14532d",
                body: "#166534",
            },
        };

        return themes[theme] || themes.light;
    }

    function truncateDisplayText(value, maxLength) {
        const text = String(value || "").trim();
        if (!text) return "";
        if (text.length <= maxLength) return text;
        return `${text.slice(0, Math.max(0, maxLength - 1)).trim()}…`;
    }

    function getDefaultBadgeLabel(record = activeClinicRecord) {
        const cityName = String(record?.city || "").trim();
        const cityRank = Number.parseInt(record?.cityRank, 10);

        if (cityName && cityRank === 1) {
            return `#1 ${cityName} Veterinarian`;
        }

        if (cityName && Number.isFinite(cityRank) && cityRank > 1) {
            return `Top ${cityName} Veterinarian`;
        }

        if (cityName) {
            return `${cityName} Veterinarian`;
        }

        return "Top Veterinarian";
    }

    function getCompactBadgeLabel(record = activeClinicRecord, fallbackLabel = "") {
        const cityName = String(record?.city || "").trim();
        const cityRank = Number.parseInt(record?.cityRank, 10);
        const cleanedFallback = String(fallbackLabel || "")
            .replace(/\bVeterinarian\b/gi, "Vet")
            .replace(/\bVeterinary Clinics\b/gi, "Vets")
            .replace(/\bVeterinary\b/gi, "Vet")
            .trim();

        if (cityName && cityRank === 1) return `#1 ${cityName} Vet`;
        if (cityName && Number.isFinite(cityRank) && cityRank > 1) {
            return `Top ${cityName} Vet`;
        }
        if (cityName) return `${cityName} Vet`;
        return cleanedFallback || "Top Vet";
    }

    function getAnchorOptions(city) {
        const cityName = String(city || "").trim();
        if (!cityName) return ["Find a local veterinarian on VetList"];

        return [
            `${cityName} veterinarian`,
            `veterinarian in ${cityName}`,
            `${cityName} vet`,
            `${cityName} veterinary clinics`,
            `${cityName} vet directory`,
        ];
    }

    function refreshAnchorSuggestions() {
        if (!badgeAnchorSuggestionsEl) return;
        const options = getAnchorOptions(activeClinicRecord?.city);
        badgeAnchorSuggestionsEl.innerHTML = options
            .map(
