                                        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
                                    </svg>
                                </div>
                            </div>
                        </div>
                        <div>
                            <label for="claim-city-select" class="block text-sm font-semibold uppercase tracking-[0.14em] text-slate-500 mb-3">
