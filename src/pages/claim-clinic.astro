---
import Layout from "../layouts/Layout.astro";
import { fetchAllProfessionals } from '../lib/supabase';

function parseArrayValue(value) {
    if (Array.isArray(value)) return value.filter(Boolean);
    if (typeof value !== "string" || !value.trim()) return [];

    try {
        const parsed = JSON.parse(value);
        return Array.isArray(parsed) ? parsed.filter(Boolean) : [];
    } catch {
        return [];
    }
}

function parseObjectValue(value) {
    if (value && typeof value === "object" && !Array.isArray(value)) return value;
    if (typeof value !== "string" || !value.trim()) return null;

    try {
        const parsed = JSON.parse(value);
        return parsed && typeof parsed === "object" && !Array.isArray(parsed)
            ? parsed
            : null;
    } catch {
        return null;
    }
}

const CLAIMED_MULTIPLIER = 1.12;
const VERIFIED_MULTIPLIER = 1.08;
const BACKLINK_MULTIPLIER = 1.18;
const VERIFIED_TIER_FLOOR = 48;
const TRUSTED_NETWORK_FLOOR = 66;
const FEATURED_NETWORK_FLOOR = 74;

function isTruthyValue(value) {
    return value === true || value === "true";
}

function clampScore(value) {
    if (!Number.isFinite(value)) return 0;
    return Math.min(100, Math.round(value));
}

function applyTrustTierFloor(score, options = {}) {
    const claimed = Boolean(options.includeClaimed);
    const verified = Boolean(options.includeVerified);
    const backlink = Boolean(options.includeBacklink);
    let boostedScore = Number.parseFloat(score) || 0;

    if (claimed && verified && backlink) {
        boostedScore = Math.max(boostedScore, FEATURED_NETWORK_FLOOR);
    } else if (verified && backlink) {
        boostedScore = Math.max(boostedScore, TRUSTED_NETWORK_FLOOR);
    } else if (claimed && verified) {
        boostedScore = Math.max(boostedScore, VERIFIED_TIER_FLOOR);
    }

    return boostedScore;
}

function projectTrustScore(score, options = {}) {
    let boostedScore = Number.parseFloat(score) || 0;

    if (options.includeClaimed) {
        boostedScore *= CLAIMED_MULTIPLIER;
    }

    if (options.includeVerified) {
        boostedScore *= VERIFIED_MULTIPLIER;
    }

    if (options.includeBacklink) {
        boostedScore *= BACKLINK_MULTIPLIER;
    }

    return clampScore(applyTrustTierFloor(boostedScore, options));
}

function calculateProfileDetailGain(record) {
    let gain = 0;

    if (!record?.website) gain += 2;
    if (!Array.isArray(record?.services) || record.services.length === 0) gain += 2;
    if (!Array.isArray(record?.animals) || record.animals.length === 0) gain += 1;
    if (!hasOperationalHours(record?.hours)) gain += 2;

    return gain;
}

function buildClaimRecord(profile) {
    if (!profile || !profile.name) return null;

    const record = {
        practiceName: profile.name,
        phone: profile.phone_number || profile.phone || "",
        address: profile.address || "",
        city: profile.city || "",
        province: profile.province || "",
        country: profile.country || "",
        website: profile.website || "",
        vetscore:
            profile.vetscore != null && profile.vetscore !== ""
                ? Number.parseFloat(profile.vetscore)
                : null,
        claimed:
            profile.claimed === true ||
            profile.claimed === false
                ? profile.claimed
                : profile.claimed === "true",
        isVerified:
            profile.is_verified === true ||
            profile.is_verified === false
                ? profile.is_verified
                : profile.is_verified === "true",
        hasBacklink:
            profile.backlink_vetlist === true ||
            profile.backlink_vetlist === false
                ? profile.backlink_vetlist
                : profile.backlink_vetlist === "true",
        services: parseArrayValue(profile.specialization),
        animals:
            parseArrayValue(profile.pet_types_served).length > 0
                ? parseArrayValue(profile.pet_types_served)
                : parseArrayValue(profile.animals_treated),
        hours: parseObjectValue(profile.hours_of_operation),
        cityPageHref:
            profile.country_slug && profile.province_slug && profile.city_slug
                ? `/${profile.country_slug}/${profile.province_slug}/${profile.city_slug}/`
                : "",
    };

    return record;
}

function hasOperationalHours(hoursValue) {
    if (!hoursValue || typeof hoursValue !== "object") return false;

    return Object.values(hoursValue).some((dayHours) => {
        if (Array.isArray(dayHours)) {
            return dayHours.some(
                (entry) =>
                    typeof entry === "string" &&
                    entry.trim() &&
                    !/^closed$/i.test(entry.trim()),
            );
        }

        return (
            typeof dayHours === "string" &&
            dayHours.trim() &&
            !/^closed$/i.test(dayHours.trim())
        );
    });
}

function getRankForScore(score, cityScores) {
    if (!Array.isArray(cityScores) || cityScores.length === 0) return null;
    const numericScore = Number.parseFloat(score) || 0;
    return cityScores.filter((value) => (Number.parseFloat(value) || 0) > numericScore).length + 1;
}

function buildCityStats(profile, profiles) {
    if (!profile?.country_slug || !profile?.province_slug || !profile?.city_slug) {
        return null;
    }

    const cityProfiles = profiles
        .filter(
            (item) =>
                item.country_slug === profile.country_slug &&
                item.province_slug === profile.province_slug &&
                item.city_slug === profile.city_slug,
        )
        .map((item) => ({
            id: item.id != null ? String(item.id).trim() : "",
            name: item.name || "",
            score: Number.parseFloat(item.vetscore) || 0,
        }))
        .filter((item) => item.id);

    if (!cityProfiles.length) return null;

    cityProfiles.sort((a, b) => b.score - a.score || a.name.localeCompare(b.name));

    const currentId = profile.id != null ? String(profile.id).trim() : "";
    const currentIndex = cityProfiles.findIndex((item) => item.id === currentId);
    const leader = cityProfiles[0] || null;

    return {
        cityRank: currentIndex >= 0 ? currentIndex + 1 : null,
        cityTotal: cityProfiles.length,
        cityScores: cityProfiles.map((item) => item.score),
        cityLeaderName: leader?.name || "",
        cityLeaderScore: leader ? Math.round(leader.score) : null,
        cityPageHref: `/${profile.country_slug}/${profile.province_slug}/${profile.city_slug}/`,
    };
}

function parseRequestJSON(value, fallback) {
    if (!value) return fallback;

    try {
        return JSON.parse(value);
    } catch {
        try {
            return JSON.parse(decodeURIComponent(value));
        } catch {
            return fallback;
        }
    }
}

// Get stats for FOMO
const allProfiles = await fetchAllProfessionals();
const totalClinics = allProfiles.length;
const claimedCount = allProfiles.filter(p => p.claimed === true || p.claimed === 'true').length;
const unclaimedCount = totalClinics - claimedCount;
const showClaimedMomentum = claimedCount >= 25;
const vetscores = allProfiles.map(p => parseFloat(p.vetscore) || 0).filter(s => s > 0);
const avgVetScore = vetscores.length > 0 ? Math.round(vetscores.reduce((a, b) => a + b, 0) / vetscores.length) : 53;
const topVetScore = vetscores.length > 0 ? Math.max(...vetscores) : 91;

// Find clinics close to becoming #1 in their city
const cityLeaders = {};
allProfiles.forEach(p => {
  if (!p.city || !p.vetscore) return;
  const key = `${p.city}, ${p.province}`;
  if (!cityLeaders[key] || parseFloat(p.vetscore) > parseFloat(cityLeaders[key].vetscore)) {
    cityLeaders[key] = p;
  }
});
const citiesWithOpportunity = Object.keys(cityLeaders).length;

const title = "Claim Your Veterinary Practice | VetList.org";
const description =
    "Claim and verify your veterinary practice profile to increase visibility and attract more pet owners.";
const locationHierarchy = new Map();

const requestedClinicId = Astro.url.searchParams.get("clinic")?.trim() || "";
const matchedClinicProfile = requestedClinicId
    ? allProfiles.find((profile) => String(profile.id || "").trim() === requestedClinicId)
    : null;
const matchedClinicRecord = buildClaimRecord(matchedClinicProfile);
const matchedClinicCityStats = matchedClinicProfile
    ? buildCityStats(matchedClinicProfile, allProfiles)
    : null;

const requestedServices = parseRequestJSON(
    Astro.url.searchParams.get("services"),
    matchedClinicRecord?.services || [],
);
const requestedAnimals = parseRequestJSON(
    Astro.url.searchParams.get("animals"),
    matchedClinicRecord?.animals || [],
);
const requestedHours = parseRequestJSON(
    Astro.url.searchParams.get("hours"),
    matchedClinicRecord?.hours || null,
);

const initialClaimRecord = {
    practiceName:
        Astro.url.searchParams.get("name") ||
        matchedClinicRecord?.practiceName ||
        "",
    phone:
        Astro.url.searchParams.get("phone") ||
        matchedClinicRecord?.phone ||
        "",
    address:
        Astro.url.searchParams.get("address") ||
        matchedClinicRecord?.address ||
        "",
    city:
        Astro.url.searchParams.get("city") ||
        matchedClinicRecord?.city ||
        "",
    province:
        Astro.url.searchParams.get("province") ||
        matchedClinicRecord?.province ||
        "",
    country:
        Astro.url.searchParams.get("country") ||
        matchedClinicRecord?.country ||
        "",
    website:
        Astro.url.searchParams.get("website") ||
        matchedClinicRecord?.website ||
        "",
    vetscore: matchedClinicRecord?.vetscore ?? null,
    claimed: matchedClinicRecord?.claimed,
    isVerified: matchedClinicRecord?.isVerified,
    hasBacklink: matchedClinicRecord?.hasBacklink,
    services: Array.isArray(requestedServices) ? requestedServices : [],
    animals: Array.isArray(requestedAnimals) ? requestedAnimals : [],
    hours:
        requestedHours && typeof requestedHours === "object" && !Array.isArray(requestedHours)
            ? requestedHours
            : null,
    cityPageHref:
        Astro.url.searchParams.get("cityPage") ||
        matchedClinicCityStats?.cityPageHref ||
        matchedClinicRecord?.cityPageHref ||
        "",
    cityRank: matchedClinicCityStats?.cityRank ?? null,
    cityTotal: matchedClinicCityStats?.cityTotal ?? null,
    cityScores: matchedClinicCityStats?.cityScores || null,
    cityLeaderName: matchedClinicCityStats?.cityLeaderName || "",
    cityLeaderScore: matchedClinicCityStats?.cityLeaderScore ?? null,
};

const hasInitialClaimContext = [
    requestedClinicId,
    initialClaimRecord.practiceName,
    initialClaimRecord.phone,
    initialClaimRecord.address,
    initialClaimRecord.city,
    initialClaimRecord.province,
    initialClaimRecord.country,
    initialClaimRecord.website,
].some((value) => typeof value === "string" && value.trim() !== "");

const initialBaseScore =
    Number.isFinite(initialClaimRecord.vetscore)
        ? Math.round(initialClaimRecord.vetscore)
        : avgVetScore;

const initialVerificationScore = projectTrustScore(initialBaseScore, {
    includeClaimed: !isTruthyValue(initialClaimRecord.claimed),
    includeVerified: !isTruthyValue(initialClaimRecord.isVerified),
});
const initialBacklinkScenarioScore = projectTrustScore(initialBaseScore, {
    includeClaimed: !isTruthyValue(initialClaimRecord.claimed),
    includeVerified: !isTruthyValue(initialClaimRecord.isVerified),
    includeBacklink: !isTruthyValue(initialClaimRecord.hasBacklink),
});
const initialVerificationGain = hasInitialClaimContext
    ? Math.max(0, initialVerificationScore - initialBaseScore)
    : 0;
const initialBacklinkGain = hasInitialClaimContext
    ? Math.max(0, initialBacklinkScenarioScore - initialVerificationScore)
    : 0;
const initialProfileGain = hasInitialClaimContext
    ? calculateProfileDetailGain(initialClaimRecord)
    : 0;
const initialPotentialGain =
    initialVerificationGain + initialBacklinkGain + initialProfileGain;

const initialProjectedScore = Math.min(100, initialBacklinkScenarioScore + initialProfileGain);
const initialCurrentRank =
    initialClaimRecord.cityRank || getRankForScore(initialBaseScore, initialClaimRecord.cityScores);
const initialVerifiedRank = getRankForScore(initialVerificationScore, initialClaimRecord.cityScores);
const initialBacklinkRank = getRankForScore(initialBacklinkScenarioScore, initialClaimRecord.cityScores);
const initialProjectedRank = getRankForScore(initialProjectedScore, initialClaimRecord.cityScores);
const initialScoreNote = hasInitialClaimContext && initialClaimRecord.practiceName
    ? `${initialClaimRecord.practiceName} can jump from ${initialBaseScore} to ${initialProjectedScore}.` +
      (initialCurrentRank && initialProjectedRank && initialClaimRecord.city
          ? ` That can move it from #${initialCurrentRank} to around #${initialProjectedRank} in ${initialClaimRecord.city}.`
          : "")
    : "Projection assumes the full upgrade path: claim, verify, add the city-page backlink, and tighten the listing details.";
const initialRankNote =
    initialCurrentRank && initialClaimRecord.cityTotal && initialClaimRecord.city
        ? `${initialClaimRecord.practiceName || "This clinic"} is currently ` +
          `#${initialCurrentRank} of ${initialClaimRecord.cityTotal} in ${initialClaimRecord.city}. ` +
          `Verification can push it to about #${initialVerifiedRank || initialCurrentRank}, ` +
          `and the backlink tier can push it to about #${initialBacklinkRank || initialVerifiedRank || initialCurrentRank}.`
        : "We’ll compare your upgraded projection against every clinic in the same city when clinic data is available.";

allProfiles.forEach((profile) => {
    if (!profile.country_slug || !profile.province_slug || !profile.city_slug) return;

    const countrySlug = profile.country_slug;
    const provinceSlug = profile.province_slug;
    const citySlug = profile.city_slug;
    const countryName = profile.country || countrySlug;
    const provinceName = profile.province || provinceSlug;
    const cityName = profile.city || citySlug;

    if (!locationHierarchy.has(countrySlug)) {
        locationHierarchy.set(countrySlug, {
            name: countryName,
            slug: countrySlug,
            regions: new Map(),
        });
    }

    const countryEntry = locationHierarchy.get(countrySlug);
    if (!countryEntry.regions.has(provinceSlug)) {
        countryEntry.regions.set(provinceSlug, {
            name: provinceName,
            slug: provinceSlug,
            cities: new Map(),
        });
    }

    const regionEntry = countryEntry.regions.get(provinceSlug);
    if (!regionEntry.cities.has(citySlug)) {
        regionEntry.cities.set(citySlug, {
            name: cityName,
            slug: citySlug,
            href: `/${countrySlug}/${provinceSlug}/${citySlug}/`,
        });
    }
});

const claimLocationIndex = Array.from(locationHierarchy.values())
    .map((country) => ({
        name: country.name,
        slug: country.slug,
        regions: Array.from(country.regions.values())
            .map((region) => ({
                name: region.name,
                slug: region.slug,
                cities: Array.from(region.cities.values()).sort((a, b) =>
                    a.name.localeCompare(b.name),
                ),
            }))
            .sort((a, b) => a.name.localeCompare(b.name)),
    }))
    .sort((a, b) => a.name.localeCompare(b.name));
---

<Layout title={title} description={description} noindex={true}>
    <div class="max-w-5xl mx-auto pt-8 px-4">
        <div class="text-center mb-8">
            <h1 class="text-4xl md:text-5xl font-black text-gray-900 mb-4 pt-4">
                Claim Your Veterinary Practice
            </h1>
            <p class="text-xl text-gray-600 font-medium">
                Update your information and boost your VetScore™
            </p>
        </div>

        <div
            id="claim-prefill-notice"
            class:list={[
                "rounded-2xl border border-emerald-200 bg-emerald-50 p-5 mb-6",
                !hasInitialClaimContext && "hidden",
            ]}
        >
            <p class="text-sm font-semibold text-emerald-800">
                Claiming clinic:
                <span id="claim-prefill-clinic-name" class="font-black">
                    {initialClaimRecord.practiceName || "Selected clinic"}
                </span>
            </p>
            <p class="text-sm text-emerald-700 mt-1">
                This form is already pre-filled. If this is the wrong clinic, use <a href="/claim-clinic/" class="underline font-semibold">manual finder</a>.
            </p>
        </div>

        <!-- FOMO Banner -->
        <div class="bg-gradient-to-r from-amber-500 to-orange-500 text-white rounded-2xl p-6 mb-8 shadow-xl">
            <div class="flex flex-col md:flex-row items-center justify-between gap-4">
                <div class="flex items-center gap-4">
                    <div class="text-4xl">🏆</div>
                    <div>
                        <h2 class="text-xl font-bold">Your Competitors Are Already Here</h2>
                        <p class="text-amber-100">
                            {showClaimedMomentum
                                ? `${claimedCount.toLocaleString()} clinics have claimed their listing. ${unclaimedCount.toLocaleString()} spots still available.`
                                : 'Clinic owners are already updating their listings. Claim yours before a competitor owns the first impression.'}
                        </p>
                    </div>
                </div>
                <div class="flex gap-4 text-center">
                    <div class="bg-white/20 backdrop-blur rounded-lg px-4 py-2">
                        <div class="text-2xl font-bold">{citiesWithOpportunity}+</div>
                        <div class="text-xs text-amber-100">Cities</div>
                    </div>
                    <div class="bg-white/20 backdrop-blur rounded-lg px-4 py-2">
                        <div class="text-2xl font-bold">{topVetScore}</div>
                        <div class="text-xs text-amber-100">Top Score</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- VetScore Boost Section -->
        <div class="bg-gradient-to-br from-slate-950 via-sky-950 to-teal-950 text-white rounded-2xl p-8 mb-8 shadow-xl">
            <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] items-start">
                <div>
                    <div class="inline-flex items-center gap-2 bg-white/10 px-3 py-1 rounded-full text-sm mb-4">
                        <span class="w-2 h-2 bg-emerald-400 rounded-full"></span>
                        VetScore™ Boost
                    </div>
                    <h2 class="text-3xl font-bold mb-4">See the Score Jump You Unlock</h2>
                    <p class="text-sky-100/85 mb-6 text-lg leading-8">
                        We start with your clinic’s current VetScore, then show the strongest path: claim the listing, verify ownership, add the city-page backlink, and move into the higher-trust tier that can shake up local rankings fast.
                    </p>
                    <div class="grid gap-4 sm:grid-cols-2">
                        <div class="rounded-2xl border border-white/10 bg-white/8 p-4">
                            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-200/70">Step 1</p>
                            <h3 class="mt-2 text-xl font-black text-white">Claim and verify ownership</h3>
                            <p class="mt-2 text-sm leading-7 text-sky-100/80">
                                This pushes the listing into a stronger trust tier right away and unlocks the verified badge.
                            </p>
                        </div>
                        <div class="rounded-2xl border border-emerald-300/20 bg-emerald-400/10 p-4">
                            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-emerald-200/80">Step 2</p>
                            <h3 class="mt-2 text-xl font-black text-white">Add the city-page backlink</h3>
                            <p class="mt-2 text-sm leading-7 text-emerald-100/85">
                                This is the real accelerator. The backlink pushes the clinic into the trusted network tier and is designed to create a much bigger ranking jump.
                            </p>
                        </div>
                    </div>
                    <div class="mt-6 space-y-3">
                        <div class="flex items-center gap-3">
                            <span class="text-emerald-400 text-xl">✓</span>
                            <span>See where the clinic ranks in its city right now</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-emerald-400 text-xl">✓</span>
                            <span>Estimate how verification and backlinking can move that rank</span>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-emerald-400 text-xl">✓</span>
                            <span>Copy a ready-to-use badge that links to the city page on VetList</span>
                        </div>
                    </div>
                </div>
                <div class="space-y-4">
                    <div class="bg-white/10 backdrop-blur rounded-2xl p-6">
                        <h3 class="font-bold text-lg mb-4 text-center">Your VetScore Projection</h3>
                        <div class="space-y-4">
                            <div class="flex items-center justify-between">
                                <span class="text-sky-100/80">Current Score</span>
                                <span id="claim-current-score" class="text-2xl font-bold">{initialBaseScore}</span>
                            </div>
                            <div class="flex items-center justify-between text-sky-100">
                                <span>Claim + owner verification</span>
                                <span id="claim-verification-gain" class="font-bold text-cyan-300">+{initialVerificationGain}</span>
                            </div>
                            <div class="flex items-center justify-between text-sky-100">
                                <span>Trusted backlink tier</span>
                                <span id="claim-backlink-gain" class="font-bold text-emerald-300">+{initialBacklinkGain}</span>
                            </div>
                            <div class="flex items-center justify-between text-sky-100">
                                <span>Profile detail additions</span>
                                <span id="claim-profile-gain" class="font-bold text-amber-300">+{initialProfileGain}</span>
                            </div>
                            <div class="flex items-center justify-between text-emerald-300">
                                <span>Upside on the table</span>
                                <span id="claim-potential-gain" class="font-bold">+{initialPotentialGain}</span>
                            </div>
                            <div class="border-t border-white/20 pt-4 flex items-center justify-between">
                                <span class="font-bold">Projected Score</span>
                                <span id="claim-projected-score" class="text-3xl font-bold text-emerald-300">{initialProjectedScore}</span>
                            </div>
                            <p id="claim-score-note" class="text-xs text-sky-100/70 text-center">
                                {initialScoreNote}
                            </p>
                        </div>
                    </div>

                    <div class="rounded-2xl border border-white/12 bg-white/6 p-6">
                        <div class="flex items-center justify-between gap-4">
                            <div>
                                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-sky-200/70">City impact</p>
                                <h3 class="mt-2 text-xl font-black text-white">What this could change locally</h3>
                            </div>
                            <span class="rounded-full border border-white/10 bg-white/8 px-3 py-1 text-xs font-semibold uppercase tracking-[0.14em] text-sky-100/80">Estimated</span>
                        </div>
                        <div class="mt-4 grid grid-cols-3 gap-3 text-center">
                            <div class="rounded-2xl border border-white/10 bg-slate-950/30 p-4">
                                <div id="claim-rank-now" class="text-2xl font-black text-white">{initialCurrentRank ? `#${initialCurrentRank}` : "--"}</div>
                                <div class="mt-1 text-xs uppercase tracking-[0.16em] text-sky-100/60">Now</div>
                            </div>
                            <div class="rounded-2xl border border-cyan-300/20 bg-cyan-300/8 p-4">
                                <div id="claim-rank-verified" class="text-2xl font-black text-cyan-200">{initialVerifiedRank ? `#${initialVerifiedRank}` : "--"}</div>
                                <div class="mt-1 text-xs uppercase tracking-[0.16em] text-sky-100/60">Verified</div>
                            </div>
                            <div class="rounded-2xl border border-emerald-300/20 bg-emerald-300/8 p-4">
                                <div id="claim-rank-backlink" class="text-2xl font-black text-emerald-200">{initialBacklinkRank ? `#${initialBacklinkRank}` : "--"}</div>
                                <div class="mt-1 text-xs uppercase tracking-[0.16em] text-sky-100/60">Trusted</div>
                            </div>
                        </div>
                        <p id="claim-rank-note" class="mt-4 text-sm leading-7 text-sky-100/75 text-center">
                            {initialRankNote}
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Search Section -->
        <div
            id="claim-workflow-section"
            class:list={[
                "rounded-[28px] border border-slate-300/70 bg-white p-8 mb-10 shadow-[0_20px_48px_rgba(15,23,42,0.10)]",
                hasInitialClaimContext && "hidden",
            ]}
        >
            <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
                <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Claim workflow</p>
                    <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950">
                        Pick your location first
                    </h2>
                    <p class="mt-4 text-lg leading-8 text-slate-600">
                        Keep it simple: choose country, province/state, and city. Then open the city page and pick your clinic from there.
                    </p>
                    <div class="mt-6 grid gap-4">
                        <div>
                            <label for="claim-country-select" class="block text-sm font-semibold uppercase tracking-[0.14em] text-slate-500 mb-3">
                                Country
                            </label>
                            <div class="relative">
                                <select
                                    id="claim-country-select"
                                    class="claim-finder-select w-full rounded-full border border-slate-300 bg-white px-5 py-4 pr-12 text-base text-slate-900 shadow-[0_8px_24px_rgba(15,23,42,0.08)] transition focus:border-cyan-400 focus:outline-none focus:ring-4 focus:ring-cyan-100"
                                >
