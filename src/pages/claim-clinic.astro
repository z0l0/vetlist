                                    rel="noopener"
                                    class="rounded-full border border-white/15 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
                                >
                                    Open City Page
                                </a>
                            </div>
                            <p id="claim-badge-copy-message" class="mt-3 hidden text-sm text-emerald-300">
                                Embed code copied.
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Services -->
