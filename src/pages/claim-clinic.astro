<script is:inline>
    // Handle day checkboxes
    document.querySelectorAll(".day-checkbox").forEach((checkbox) => {
        checkbox.addEventListener("change", function () {
            const day = this.dataset.day;
            const openInput = document.querySelector(
                `.day-open[data-day="${day}"]`,
            );
            const closeInput = document.querySelector(
                `.day-close[data-day="${day}"]`,
            );

            if (this.checked) {
                openInput.disabled = false;
                closeInput.disabled = false;
                openInput.value = "09:00";
                closeInput.value = "17:00";
            } else {
                openInput.disabled = true;
                closeInput.disabled = true;
                openInput.value = "";
                closeInput.value = "";
            }
        });
    });

    // Handle form submission
    document
        .getElementById("claim-form")
        .addEventListener("submit", function (e) {
            e.preventDefault();

            // Collect form data
            const formData = {
                practiceName: document.getElementById("practice-name").value,
                phone: document.getElementById("phone").value,
                address: document.getElementById("address").value,
                city: document.getElementById("city").value,
                province: document.getElementById("province").value,
                country: document.getElementById("country").value,
                email: document.getElementById("email").value,
                website: document.getElementById("website").value,
                verificationInterest: document.getElementById(
                    "verification-interest",
                ).checked,
            };

            // Collect services
            const services = [];
            document
                .querySelectorAll('input[type="checkbox"][value]:checked')
                .forEach((cb) => {
                    if (cb.value && cb.id !== "verification-interest" && !cb.classList.contains('faq-checkbox')) {
                        services.push(cb.value);
                    }
                });

            // Collect FAQ preferences (as encoded answers)
            const faqAnswers = [];
            document
                .querySelectorAll('.faq-radio:checked')
                .forEach((radio) => {
                    if (!radio.value.endsWith('X')) { // Skip the "Skip" options
                        faqAnswers.push(radio.value);
                    }
                });

            // Update form data with FAQ count for display
            formData.faqCount = faqAnswers.length;

            // Add custom services
            const customServices =
                document.getElementById("custom-services").value;
            if (customServices && customServices.trim()) {
                const customList = customServices
                    .split(",")
                    .map((s) => s.trim())
                    .filter((s) => s);
                services.push(...customList);
            }

            // Collect hours
            const hours = {};
            [
                "monday",
                "tuesday",
                "wednesday",
                "thursday",
                "friday",
                "saturday",
                "sunday",
            ].forEach((day) => {
                const checkbox = document.querySelector(
                    `.day-checkbox[data-day="${day}"]`,
                );
                if (checkbox.checked) {
                    const openTime = document.querySelector(
                        `.day-open[data-day="${day}"]`,
                    ).value;
                    const closeTime = document.querySelector(
                        `.day-close[data-day="${day}"]`,
                    ).value;
                    hours[day] = `${openTime} - ${closeTime}`;
                } else {
                    hours[day] = "Closed";
                }
            });

            // Generate email content
            const emailContent = `Dear VetList Team,

I would like to claim my veterinary practice profile on VetList.org.

PRACTICE INFORMATION:
Practice Name: ${formData.practiceName}
Phone: ${formData.phone}
Email: ${formData.email}
Website: ${formData.website || "Not provided"}

ADDRESS:
${formData.address}
${formData.city}, ${formData.province}
${formData.country}

SERVICES OFFERED:
${services.length > 0 ? services.join(", ") : "Not specified"}

FREQUENTLY ASKED QUESTIONS:
${faqAnswers.length > 0 ? generateFAQText(faqAnswers) : "Not specified"}

HOURS OF OPERATION:
Monday: ${hours.monday}
Tuesday: ${hours.tuesday}
Wednesday: ${hours.wednesday}
Thursday: ${hours.thursday}
Friday: ${hours.friday}
Saturday: ${hours.saturday}
Sunday: ${hours.sunday}

VERIFICATION INTEREST:
${formData.verificationInterest ? "Yes, I am interested in the verification program ($249/year introductory offer)" : "No, just claiming the basic profile"}

Please update my profile with this information. I confirm that I am authorized to make changes to this veterinary practice profile.

Thank you,
[Your Name]
[Your Title]
${formData.practiceName}`;

            // Show modal with email content
            document.getElementById("email-content").value = emailContent;
            document.getElementById("email-modal").classList.remove("hidden");
            document.getElementById("email-modal").classList.add("flex");
        });

    // Handle modal close
    document
        .getElementById("close-modal")
        .addEventListener("click", function () {
            document.getElementById("email-modal").classList.add("hidden");
            document.getElementById("email-modal").classList.remove("flex");
        });

    // Handle copy email
    document
        .getElementById("copy-email")
        .addEventListener("click", function () {
            const emailContent = document.getElementById("email-content");
            emailContent.select();
            document.execCommand("copy");

            // Show feedback
            const button = this;
            const originalText = button.textContent;
            button.textContent = "Copied!";
            button.classList.add("bg-green-600");
            button.classList.remove("bg-primary-600");

            setTimeout(() => {
                button.textContent = originalText;
                button.classList.remove("bg-green-600");
                button.classList.add("bg-primary-600");
            }, 2000);
        });

    // Close modal when clicking outside
    document
        .getElementById("email-modal")
        .addEventListener("click", function (e) {
            if (e.target === this) {
                this.classList.add("hidden");
                this.classList.remove("flex");
            }
        });

    // FAQ Encoding System for existing profile FAQs
    // These are the common FAQ questions from the CSV data
    const FAQ_QUESTIONS = {
        'A': 'Are walk-in appointments available?',
        'B': 'Are prescription pet foods or diets available?', 
        'C': 'Is pet dental care available?',
        'D': 'Is care provided for exotic animals like birds or reptiles?',
        'E': 'Is pet insurance accepted?',
        'F': 'Are spay and neuter services available?',
        'G': 'Is the clinic open on weekends?',
        'H': 'Are X-rays or ultrasounds offered?',
        'I': 'Are house calls offered for pets?',
        'J': 'Are surgical procedures performed?',
        'K': 'Is emergency care provided?',
        'L': 'Are evening appointments available?',
        'M': 'Are vaccinations provided?',
        'N': 'Can appointments be scheduled online?',
        'O': 'Are payment plans or financing options available?'
    };

    // FAQ answers mapping (Y/N + code for common answers)
    const FAQ_ANSWERS = {
        'Y1': 'Yes, this service is available.',
        'Y2': 'Yes, we offer this service.',
        'Y3': 'Yes, we are open on weekends for your convenience.',
        'Y4': 'Yes, evening hours (after 7 PM) are offered.',
        'Y5': 'Yes, comprehensive surgical services are available on-site.',
        'Y6': 'Yes, routine spay and neuter procedures are performed.',
        'N1': 'No, appointments are required as walk-ins aren\'t typically accepted.',
        'N2': 'Prescription diets aren\'t available.',
        'N3': 'Pet dental care isn\'t currently available.',
        'N4': 'Care is primarily focused on cats and dogs.',
        'N5': 'Direct billing for pet insurance isn\'t available.',
        'N6': 'Diagnostic imaging isn\'t offered on-site.',
        'N7': 'House calls aren\'t currently offered.',
        'N8': 'Emergency care isn\'t offered; referrals may be provided.',
        'N9': 'Online booking isn\'t offered at this time.',
        'N10': 'Payment plans aren\'t currently available.'
    };

    // Initialize FAQ checkboxes
    function initializeFAQSection() {
        const faqGrid = document.getElementById('faq-grid');
        if (!faqGrid) return;

        Object.entries(FAQ_QUESTIONS).forEach(([code, question]) => {
            const container = document.createElement('div');
            container.className = 'border border-gray-200 rounded-lg p-4 hover:bg-gray-50 transition-colors';
            container.innerHTML = `
                <div class="mb-3">
                    <div class="text-sm font-medium text-gray-900 mb-2">${question}</div>
                    <div class="flex gap-4">
                        <label class="flex items-center cursor-pointer">
                            <input type="radio" name="faq-${code}" value="${code}Y" class="faq-radio rounded border-gray-300 text-green-600 focus:ring-green-500">
                            <span class="ml-2 text-sm text-green-700">Yes</span>
                        </label>
                        <label class="flex items-center cursor-pointer">
                            <input type="radio" name="faq-${code}" value="${code}N" class="faq-radio rounded border-gray-300 text-red-600 focus:ring-red-500">
                            <span class="ml-2 text-sm text-red-700">No</span>
                        </label>
                        <label class="flex items-center cursor-pointer">
                            <input type="radio" name="faq-${code}" value="${code}X" class="faq-radio rounded border-gray-300 text-gray-600 focus:ring-gray-500" checked>
                            <span class="ml-2 text-sm text-gray-600">Skip</span>
                        </label>
                    </div>
                </div>
            `;
            faqGrid.appendChild(container);
        });

        // Add event listeners to update counter
        document.querySelectorAll('.faq-radio').forEach(radio => {
            radio.addEventListener('change', updateFAQCounter);
        });

        updateFAQCounter();
    }

    // Update FAQ counter
    function updateFAQCounter() {
        const counter = document.getElementById('faq-counter');
        const answeredCount = document.querySelectorAll('.faq-radio:checked').length - document.querySelectorAll('.faq-radio:checked[value$="X"]').length;
        if (counter) {
            counter.textContent = `${answeredCount} answered`;
            counter.className = answeredCount > 0 
                ? 'text-xs font-medium text-blue-600 bg-blue-100 px-2 py-1 rounded'
                : 'text-xs font-medium text-gray-600 bg-white px-2 py-1 rounded';
        }
    }

    // Generate full FAQ text for email
    function generateFAQText(faqAnswers) {
        let faqText = `${faqAnswers.length} questions answered:\n\n`;
        
        faqAnswers.forEach((answer, index) => {
            const questionCode = answer.charAt(0);
            const answerType = answer.charAt(1);
            const question = FAQ_QUESTIONS[questionCode];
            
            let answerText;
            if (answerType === 'Y') {
                // Find appropriate "Yes" answer
                answerText = FAQ_ANSWERS['Y1']; // Default yes answer
                if (questionCode === 'G') answerText = FAQ_ANSWERS['Y3']; // Weekend hours
                if (questionCode === 'L') answerText = FAQ_ANSWERS['Y4']; // Evening hours
                if (questionCode === 'J') answerText = FAQ_ANSWERS['Y5']; // Surgery
                if (questionCode === 'F') answerText = FAQ_ANSWERS['Y6']; // Spay/neuter
            } else {
                // Find appropriate "No" answer based on question
                const noAnswerMap = {
                    'A': 'N1', 'B': 'N2', 'C': 'N3', 'D': 'N4', 'E': 'N5',
                    'H': 'N6', 'I': 'N7', 'K': 'N8', 'N': 'N9', 'O': 'N10'
                };
                answerText = FAQ_ANSWERS[noAnswerMap[questionCode]] || FAQ_ANSWERS['N1'];
            }
            
            faqText += `${index + 1}. ${question}\n   ${answerText}\n\n`;
        });
        
        return faqText;
    }

    // Handle URL parameter prefilling
    function prefillFormFromURL() {
        const urlParams = new URLSearchParams(window.location.search);

        // Basic information
        const name = urlParams.get("name");
        if (name) {
            const nameEl = document.getElementById("practice-name");
            if (nameEl) nameEl.value = name;
        }

        const phone = urlParams.get("phone");
        if (phone) {
            const phoneEl = document.getElementById("phone");
            if (phoneEl) phoneEl.value = phone;
        }

        const address = urlParams.get("address");
        if (address) {
            const addressEl = document.getElementById("address");
            if (addressEl) addressEl.value = address;
        }

        const city = urlParams.get("city");
        if (city) {
            const cityEl = document.getElementById("city");
            if (cityEl) cityEl.value = city;
        }

        const province = urlParams.get("province");
        if (province) {
            const provinceEl = document.getElementById("province");
            if (provinceEl) provinceEl.value = province;
        }

        const country = urlParams.get("country");
        if (country) {
            const countryEl = document.getElementById("country");
            if (countryEl) countryEl.value = country;
        }

        const website = urlParams.get("website");
        if (website) {
            const websiteEl = document.getElementById("website");
            if (websiteEl) websiteEl.value = website;
        }

        // FAQ codes (encoded as pairs like "AY,BN,FY" for A=Yes, B=No, F=Yes)
        const faqParam = urlParams.get("faq");
        if (faqParam) {
            const faqPairs = faqParam.split(',');
            faqPairs.forEach(pair => {
                if (pair.length === 2) {
                    const questionCode = pair.charAt(0);
                    const answerCode = pair.charAt(1);
                    const radio = document.querySelector(`input[name="faq-${questionCode}"][value="${questionCode}${answerCode}"]`);
                    if (radio) radio.checked = true;
                }
            });
            updateFAQCounter();
        }

        // Services
        const servicesParam = urlParams.get("services");
        if (servicesParam) {
            try {
                const services = JSON.parse(servicesParam);
                services.forEach((service) => {
                    const checkbox = document.querySelector(
                        `input[type="checkbox"][value="${service}"]`,
                    );
                    if (checkbox) checkbox.checked = true;
                });
            } catch (e) {
                console.error("Error parsing services:", e);
            }
        }

        // Hours
        const hoursParam = urlParams.get("hours");
        if (hoursParam) {
            try {
                const hours = JSON.parse(decodeURIComponent(hoursParam));
                const dayMapping = {
                    "1": "monday",
                    "2": "tuesday",
                    "3": "wednesday",
                    "4": "thursday",
                    "5": "friday",
                    "6": "saturday",
                    "7": "sunday",
                };

                Object.entries(hours).forEach(([dayNum, dayHours]) => {
                    const dayName = dayMapping[dayNum];
                    if (
                        dayName &&
                        Array.isArray(dayHours) &&
                        dayHours.length > 0
                    ) {
                        const timeRange = dayHours[0];
                        if (timeRange && timeRange.includes("-")) {
                            const [openTime, closeTime] = timeRange.split("-");
                            const checkbox = document.querySelector(
                                `.day-checkbox[data-day="${dayName}"]`,
                            );
                            const openInput = document.querySelector(
                                `.day-open[data-day="${dayName}"]`,
                            );
                            const closeInput = document.querySelector(
                                `.day-close[data-day="${dayName}"]`,
                            );

                            if (checkbox && openInput && closeInput) {
                                checkbox.checked = true;
                                openInput.disabled = false;
                                closeInput.disabled = false;

                                // Convert time format if needed (e.g., "9:00 AM" to "09:00")
                                const convertTo24Hour = (time) => {
                                    const timeStr = time.trim();
                                    if (
                                        timeStr.includes("AM") ||
                                        timeStr.includes("PM")
                                    ) {
                                        const [timePart, period] =
                                            timeStr.split(/\s+(AM|PM)/i);
                                        let [hours, minutes] =
                                            timePart.split(":");
                                        hours = parseInt(hours, 10);
                                        minutes = minutes || "00";

                                        if (
                                            period.toUpperCase() === "PM" &&
                                            hours !== 12
                                        ) {
                                            hours += 12;
                                        } else if (
                                            period.toUpperCase() === "AM" &&
                                            hours === 12
                                        ) {
                                            hours = 0;
                                        }

                                        return `${hours.toString().padStart(2, "0")}:${minutes}`;
                                    }
                                    return timeStr;
                                };

                                openInput.value = convertTo24Hour(openTime);
                                closeInput.value = convertTo24Hour(closeTime);
                            }
                        }
                    }
                });
            } catch (e) {
                console.error("Error parsing hours:", e);
            }
        }
    }

    // Run initialization when page loads
    document.addEventListener("DOMContentLoaded", function() {
        initializeFAQSection();
        prefillFormFromURL();
    });

    // Handle premium section reveal
    document
        .getElementById("reveal-premium")
        .addEventListener("click", function () {
            const premiumSection = document.getElementById("premium-section");
            const button = this;

            // Show the section
            premiumSection.classList.remove("hidden");

            // Trigger animation after a brief delay
            setTimeout(() => {
                premiumSection.classList.remove("opacity-0", "translate-y-4");
                premiumSection.classList.add("opacity-100", "translate-y-0");
            }, 50);

            // Smooth scroll to the premium section
            setTimeout(() => {
                premiumSection.scrollIntoView({
                    behavior: "smooth",
                    block: "start",
                });
            }, 100);

            // Update button text and disable it
            button.innerHTML = `
      <span class="flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Premium Options Revealed
      </span>
    `;
            button.disabled = true;
            button.classList.add("opacity-75", "cursor-not-allowed");
        });
</script>
