    });

    badgeAnchorInputEl?.addEventListener("input", function () {
        badgeState.anchorText = (this.value || "").trim().slice(0, 44);
        updateBadgeConfigurator();
    });

    badgeCopyButtonEl?.addEventListener("click", async function () {
        if (!badgeEmbedCodeEl?.value) return;

        try {
            await navigator.clipboard.writeText(badgeEmbedCodeEl.value);
        } catch {
            badgeEmbedCodeEl.select();
            document.execCommand("copy");
        }

        if (badgeCopyMessageEl) {
            badgeCopyMessageEl.classList.remove("hidden");
            window.setTimeout(() => {
                badgeCopyMessageEl.classList.add("hidden");
            }, 1800);
        }
    });

    function parseJSONParam(rawValue, fallback = null) {
        if (!rawValue) return fallback;
        const attempts = [rawValue];
        try {
            attempts.push(decodeURIComponent(rawValue));
        } catch {}

        for (const candidate of attempts) {
            try {
                return JSON.parse(candidate);
            } catch {}
        }

        return fallback;
    }

    function setInputValue(id, value) {
        if (value == null || value === "") return;
        const el = document.getElementById(id);
        if (el) el.value = value;
    }

    function clearCheckboxGroup(selector) {
        document.querySelectorAll(selector).forEach((checkbox) => {
            checkbox.checked = false;
        });
    }

    function prefillServices(services) {
        if (!Array.isArray(services) || services.length === 0) return;
        clearCheckboxGroup('#services-grid input[type="checkbox"]');

        const normalizedServices = services
            .map((service) => String(service || "").trim())
            .filter(Boolean);
        const unmatchedServices = [];

        normalizedServices.forEach((service) => {
            let checkbox = document.querySelector(
                `#services-grid input[type="checkbox"][value="${service}"]`,
            );

            if (!checkbox) {
                const allCheckboxes = document.querySelectorAll(
                    '#services-grid input[type="checkbox"]',
                );
                for (const cb of allCheckboxes) {
                    if (cb.value.toLowerCase() === service.toLowerCase()) {
                        checkbox = cb;
                        break;
                    }
                }
            }

            if (checkbox) {
                checkbox.checked = true;
            } else {
                unmatchedServices.push(service);
            }
        });

        const customServicesEl = document.getElementById("custom-services");
        if (customServicesEl) {
            customServicesEl.value = unmatchedServices.join(", ");
        }
    }

    function prefillAnimals(animals) {
        if (!Array.isArray(animals) || animals.length === 0) return;
        clearCheckboxGroup('#animals-grid input[type="checkbox"]');

        animals.forEach((animal) => {
            const normalizedAnimal = String(animal || "")
                .toLowerCase()
                .replace(/\s+/g, "_");
            if (!normalizedAnimal) return;

            const checkbox = document.querySelector(
                `#animals-grid input[type="checkbox"][value="${normalizedAnimal}"]`,
            );
            if (checkbox) checkbox.checked = true;
        });
    }

    function convertTo24Hour(time) {
        const timeStr = String(time || "").trim();
        if (!timeStr) return "";

        if (timeStr.includes("AM") || timeStr.includes("PM")) {
            const [timePart, period] = timeStr.split(/\s+(AM|PM)/i);
            let [hours, minutes] = timePart.split(":");
            hours = parseInt(hours, 10);
            minutes = minutes || "00";

            if (period.toUpperCase() === "PM" && hours !== 12) {
                hours += 12;
            } else if (period.toUpperCase() === "AM" && hours === 12) {
                hours = 0;
            }

            return `${hours.toString().padStart(2, "0")}:${minutes}`;
        }

        return timeStr;
    }

    function prefillHours(hoursValue) {
        if (!hoursValue || typeof hoursValue !== "object") return;

        const dayMapping = {
            "1": "monday",
            "2": "tuesday",
            "3": "wednesday",
            "4": "thursday",
            "5": "friday",
            "6": "saturday",
            "7": "sunday",
            monday: "monday",
            tuesday: "tuesday",
            wednesday: "wednesday",
            thursday: "thursday",
            friday: "friday",
            saturday: "saturday",
            sunday: "sunday",
        };

        document.querySelectorAll(".day-checkbox").forEach((checkbox) => {
            checkbox.checked = false;
            const day = checkbox.dataset.day;
            const openInput = document.querySelector(`.day-open[data-day="${day}"]`);
            const closeInput = document.querySelector(`.day-close[data-day="${day}"]`);
            if (openInput && closeInput) {
                openInput.value = "";
                closeInput.value = "";
                openInput.disabled = true;
                closeInput.disabled = true;
            }
        });

        Object.entries(hoursValue).forEach(([rawDay, dayHours]) => {
            const dayName = dayMapping[String(rawDay).toLowerCase()];
            if (!dayName) return;

            let timeRange = "";
            if (Array.isArray(dayHours) && dayHours.length > 0) {
                timeRange = String(dayHours[0] || "").trim();
            } else if (typeof dayHours === "string") {
                timeRange = dayHours.trim();
            }

            if (
                !timeRange ||
                /^closed$/i.test(timeRange) ||
                !timeRange.includes("-")
            ) {
                return;
            }

            const [openTime, closeTime] = timeRange.split("-");
            const checkbox = document.querySelector(
                `.day-checkbox[data-day="${dayName}"]`,
            );
            const openInput = document.querySelector(
                `.day-open[data-day="${dayName}"]`,
            );
            const closeInput = document.querySelector(
                `.day-close[data-day="${dayName}"]`,
            );

            if (checkbox && openInput && closeInput) {
                checkbox.checked = true;
                openInput.disabled = false;
                closeInput.disabled = false;
                openInput.value = convertTo24Hour(openTime);
                closeInput.value = convertTo24Hour(closeTime);
            }
        });
    }

    function prefillFromClinicRecord(clinicRecord) {
        if (!clinicRecord || typeof clinicRecord !== "object") return;
        applyClinicContext(clinicRecord);
        setInputValue("practice-name", clinicRecord.practiceName || clinicRecord.name);
        setInputValue("phone", clinicRecord.phone);
        setInputValue("address", clinicRecord.address);
        setInputValue("city", clinicRecord.city);
        setInputValue("province", clinicRecord.province);
        setInputValue("country", clinicRecord.country);
        setInputValue("website", clinicRecord.website);
        prefillServices(clinicRecord.services);
        prefillAnimals(clinicRecord.animals);
        prefillHours(clinicRecord.hours);
        updateScoreProjection();
    }

    const clinicPrefillCache = new Map();

    async function loadClinicRecord(clinicId) {
        if (!clinicId) return null;
        if (clinicPrefillCache.has(clinicId)) return clinicPrefillCache.get(clinicId);

        try {
            const response = await fetch(
                `/api/claim-clinic-prefill.json?clinic=${encodeURIComponent(clinicId)}`,
                {
                    headers: { Accept: "application/json" },
                },
            );

            if (!response.ok) {
                clinicPrefillCache.set(clinicId, null);
                return null;
            }

            const parsed = await response.json();
            let record = parsed?.record && typeof parsed.record === "object"
                ? parsed.record
                : null;

            if (!record && parsed && typeof parsed === "object" && parsed[clinicId]) {
                record = deriveCityStatsFromIndex(
                    parsed[clinicId],
                    Object.values(parsed).filter((value) => value && typeof value === "object"),
                );
            }

            clinicPrefillCache.set(clinicId, record);
            return record;
        } catch {
            clinicPrefillCache.set(clinicId, null);
            return null;
        }
    }

    // Handle URL parameter prefilling
    async function prefillFormFromURL() {
        const urlParams = new URLSearchParams(window.location.search);
        const clinicParam = (urlParams.get("clinic") || "").trim();
        activeClinicId = clinicParam;
        let resolvedClinicRecord = activeClinicRecord;

        if (clinicParam && !resolvedClinicRecord) {
            if (claimWorkflowSection) {
                claimWorkflowSection.classList.add("hidden");
            }
            if (claimPrefillNotice) {
                claimPrefillNotice.classList.remove("hidden");
            }
            if (claimPrefillClinicName) {
                claimPrefillClinicName.textContent = "Loading clinic details...";
            }

            resolvedClinicRecord = await loadClinicRecord(clinicParam);

            if (resolvedClinicRecord) {
                prefillFromClinicRecord(resolvedClinicRecord);
            }
        }

        const nameParam = urlParams.get("name");
        const phoneParam = urlParams.get("phone");
        const addressParam = urlParams.get("address");
        const cityParam = urlParams.get("city");
        const provinceParam = urlParams.get("province");
        const countryParam = urlParams.get("country");
        const websiteParam = urlParams.get("website");

        setInputValue("practice-name", nameParam);
        setInputValue("phone", phoneParam);
        setInputValue("address", addressParam);
        setInputValue("city", cityParam);
        setInputValue("province", provinceParam);
        setInputValue("country", countryParam);
        setInputValue("website", websiteParam);

        const services = parseJSONParam(urlParams.get("services"), null);
        if (Array.isArray(services)) {
            prefillServices(services);
        }

        const animals = parseJSONParam(urlParams.get("animals"), null);
        if (Array.isArray(animals)) {
            prefillAnimals(animals);
        }

        const hours = parseJSONParam(urlParams.get("hours"), null);
        if (hours && typeof hours === "object") {
            prefillHours(hours);
        }

        if (!resolvedClinicRecord) {
            const hasDirectClinicPrefill = [
                nameParam,
                phoneParam,
                addressParam,
                cityParam,
                provinceParam,
                countryParam,
                websiteParam,
            ].some((value) => typeof value === "string" && value.trim() !== "");

            if (hasDirectClinicPrefill) {
                applyClinicContext({
                    practiceName: nameParam || "Selected clinic",
                    city: cityParam || "",
                    province: provinceParam || "",
                    country: countryParam || "",
                    cityPageHref: (urlParams.get("cityPage") || "").trim(),
                });
            }
        }

        updateScoreProjection();
    }

    let claimPageInitialized = false;

    async function initializeClaimPage() {
        if (claimPageInitialized) return;
        claimPageInitialized = true;
        activeClinicId = new URLSearchParams(window.location.search).get("clinic")?.trim() || "";

        initializeClaimLocationPicker();
        if (activeClinicRecord) {
            prefillFromClinicRecord(activeClinicRecord);
        }
        await prefillFormFromURL();

        verificationInterestEl?.addEventListener("change", function () {
            if (!this.checked && backlinkInterestEl?.checked) {
                backlinkInterestEl.checked = false;
            }
            updateScoreProjection();
        });

        backlinkInterestEl?.addEventListener("change", function () {
            if (this.checked && verificationInterestEl && !verificationInterestEl.checked) {
                verificationInterestEl.checked = true;
            }
            updateScoreProjection();
        });

        [
            "#website",
            "#custom-services",
            "#verification-interest",
            "#backlink-interest",
            '#services-grid input[type="checkbox"]',
            '#animals-grid input[type="checkbox"]',
            ".day-checkbox",
            ".day-open",
            ".day-close",
        ].forEach((selector) => {
            document.querySelectorAll(selector).forEach((element) => {
                element.addEventListener("change", updateScoreProjection);
                element.addEventListener("input", updateScoreProjection);
            });
        });

        updateScoreProjection();
    }

    // Run initialization when page loads (and safely handle cases where DOM is already loaded)
    if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initializeClaimPage, {
            once: true,
        });
    } else {
        initializeClaimPage();
    }
</script>
