    function updateBadgeConfigurator() {
        if (!badgeSectionEl || !badgePreviewLinkEl || !badgePreviewImageEl || !badgeEmbedCodeEl) {
            return;
        }

        const cityPageHref = resolveCityPageHref();
        const publicCityUrl = cityPageHref ? `https://vetlist.org${cityPageHref}` : "";
        const localCityUrl = cityPageHref ? `${window.location.origin}${cityPageHref}` : "#";

        if (!activeClinicId || !publicCityUrl) {
            badgeSectionEl.classList.add("hidden");
            return;
        }

        badgeSectionEl.classList.remove("hidden");
        const sizeConfig = getBadgeSizeConfig(badgeState.size);
        const badgeLabel =
            (badgeState.label || "").trim() ||
            getDefaultBadgeLabel(activeClinicRecord);

        const badgeParams = new URLSearchParams({
            clinic: activeClinicId,
            theme: badgeState.theme,
            size: badgeState.size,
            shape: badgeState.shape,
            label: badgeLabel,
        });

        const publicBadgeUrl = `https://vetlist.org/api/vetlist-badge.svg?${badgeParams.toString()}`;
        const altText = `${activeClinicRecord?.practiceName || "Clinic"} on VetList`;
        const anchorText =
            (badgeState.anchorText || "").trim() ||
            getAnchorOptions(activeClinicRecord?.city)[0];
        const previewBadgeUrl = buildBadgePreviewDataUrl({
            clinicName: activeClinicRecord?.practiceName || "Clinic",
            label: badgeLabel,
            size: badgeState.size,
            theme: badgeState.theme,
            shape: badgeState.shape,
            score: toScore(activeClinicRecord?.vetscore) || defaultScore,
            city: activeClinicRecord?.city || "",
            cityRank: activeClinicRecord?.cityRank || null,
        });

        badgePreviewLinkEl.setAttribute("href", localCityUrl);
        badgePreviewLinkEl.style.width = `${sizeConfig.width}px`;
        badgePreviewLinkEl.style.maxWidth = "100%";
        badgePreviewImageEl.setAttribute("src", previewBadgeUrl);
        badgePreviewImageEl.setAttribute("alt", altText);
        badgePreviewImageEl.setAttribute("width", String(sizeConfig.width));
        badgePreviewImageEl.setAttribute("height", String(sizeConfig.height));
        badgePreviewImageEl.style.width = `${sizeConfig.width}px`;
        badgePreviewImageEl.style.maxWidth = "100%";

        if (badgeTextPreviewEl) {
            badgeTextPreviewEl.setAttribute("href", localCityUrl);
            badgeTextPreviewEl.textContent = anchorText;
            badgeTextPreviewEl.classList.add("hidden");
        }

        const badgeImageMarkup =
            `<a href="${publicCityUrl}" title="${anchorText}" target="_blank" rel="noopener">` +
            `<img src="${publicBadgeUrl}" alt="${anchorText}" width="${sizeConfig.width}" height="${sizeConfig.height}" loading="lazy" style="display:block;max-width:100%;height:auto;border:0;"></a>`;
        badgeEmbedCodeEl.value = badgeImageMarkup;

        if (badgeOpenCityPageEl) {
            badgeOpenCityPageEl.setAttribute("href", localCityUrl);
        }
    }

    function escapeSvgText(value) {
        return String(value || "")
            .replace(/&/g, "&amp;")
            .replace(/</g, "&lt;")
            .replace(/>/g, "&gt;")
            .replace(/"/g, "&quot;")
            .replace(/'/g, "&apos;");
    }

    function buildBadgePreviewDataUrl({ clinicName, label, size, theme, shape, score, city, cityRank }) {
        const sizeConfig = getBadgeSizeConfig(size);
        const themeConfig = getBadgeThemeConfig(theme);
        const rounded = shape !== "square";
        const radius = rounded ? 20 : 8;
        const iconRadius = rounded ? 16 : 10;
        const displayLabel = sizeConfig.layout === "small"
            ? getCompactBadgeLabel({ city, cityRank }, label)
            : (label || "Top Veterinarian");
        const safeLabel = escapeSvgText(truncateDisplayText(displayLabel, sizeConfig.labelMax));
        const safeClinicName = escapeSvgText(truncateDisplayText(clinicName || "Clinic", sizeConfig.clinicMax));
        const subtitleText = sizeConfig.layout === "small"
            ? `VetScore ${score}`
            : cityRank && city
                ? `VetScore ${score} | #${cityRank} in ${city}`
                : city
                    ? `VetScore ${score} | ${city}`
                    : `VetScore ${score}`;
        const safeSubtitle = escapeSvgText(truncateDisplayText(subtitleText, sizeConfig.subtitleMax));
        const checkStartX = sizeConfig.iconX + Math.round(sizeConfig.iconSize * 0.26);
        const checkStartY = sizeConfig.iconY + Math.round(sizeConfig.iconSize * 0.55);
        const checkMidX = sizeConfig.iconX + Math.round(sizeConfig.iconSize * 0.47);
        const checkMidY = sizeConfig.iconY + Math.round(sizeConfig.iconSize * 0.75);
        const checkEndX = sizeConfig.iconX + Math.round(sizeConfig.iconSize * 0.78);
        const checkEndY = sizeConfig.iconY + Math.round(sizeConfig.iconSize * 0.34);
        const checkStroke = 4.5;
        const bodyMarkup = sizeConfig.layout === "small"
            ? `<rect x="${sizeConfig.panelX}" y="${sizeConfig.panelY}" width="${sizeConfig.panelWidth}" height="${sizeConfig.panelHeight}" rx="${rounded ? 22 : 10}" fill="${themeConfig.bg}" stroke="${themeConfig.border}" stroke-width="2"/>` +
              `<circle cx="${sizeConfig.iconX + (sizeConfig.iconSize / 2)}" cy="${sizeConfig.iconY + (sizeConfig.iconSize / 2)}" r="${sizeConfig.iconSize / 2}" fill="${themeConfig.accentSoft}"/>` +
              `<path d="M${checkStartX} ${checkStartY} L${checkMidX} ${checkMidY} L${checkEndX} ${checkEndY}" stroke="${themeConfig.accent}" stroke-width="${checkStroke}" stroke-linecap="round" stroke-linejoin="round"/>` +
              `<text x="${sizeConfig.textX}" y="${sizeConfig.titleY}" fill="${themeConfig.title}" font-family="Arial, sans-serif" font-size="${sizeConfig.titleSize}" font-weight="800">${safeLabel}</text>` +
              `<text x="${sizeConfig.textX}" y="${sizeConfig.nameY}" fill="${themeConfig.body}" font-family="Arial, sans-serif" font-size="${sizeConfig.nameSize}" font-weight="600">${safeClinicName}</text>` +
              `<text x="${sizeConfig.scoreX}" y="${sizeConfig.scoreLabelY}" text-anchor="end" fill="${themeConfig.accent}" font-family="Arial, sans-serif" font-size="${sizeConfig.subtitleSize}" font-weight="700">VetScore</text>` +
              `<text x="${sizeConfig.scoreX}" y="${sizeConfig.scoreValueY}" text-anchor="end" fill="${themeConfig.accent}" font-family="Arial, sans-serif" font-size="18" font-weight="800">${score}</text>`
            : `<rect x="1" y="1" width="${sizeConfig.width - 2}" height="${sizeConfig.height - 2}" rx="${radius}" fill="${themeConfig.bg}" stroke="${themeConfig.border}" stroke-width="2"/>` +
              `<rect x="${sizeConfig.iconX}" y="${sizeConfig.iconY}" width="${sizeConfig.iconSize}" height="${sizeConfig.iconSize}" rx="${iconRadius}" fill="${themeConfig.accentSoft}"/>` +
              `<path d="M${checkStartX} ${checkStartY} L${checkMidX} ${checkMidY} L${checkEndX} ${checkEndY}" stroke="${themeConfig.accent}" stroke-width="${checkStroke}" stroke-linecap="round" stroke-linejoin="round"/>` +
              `<text x="${sizeConfig.textX}" y="${sizeConfig.titleY}" fill="${themeConfig.title}" font-family="Arial, sans-serif" font-size="${sizeConfig.titleSize}" font-weight="700">${safeLabel}</text>` +
              `<text x="${sizeConfig.textX}" y="${sizeConfig.nameY}" fill="${themeConfig.body}" font-family="Arial, sans-serif" font-size="${sizeConfig.nameSize}" font-weight="600">${safeClinicName}</text>` +
              `<text x="${sizeConfig.textX}" y="${sizeConfig.subtitleY}" fill="${themeConfig.body}" font-family="Arial, sans-serif" font-size="${sizeConfig.subtitleSize}">${safeSubtitle}</text>`;

        const svg = `<?xml version="1.0" encoding="UTF-8"?>\n` +
            `<svg xmlns="http://www.w3.org/2000/svg" width="${sizeConfig.width}" height="${sizeConfig.height}" viewBox="0 0 ${sizeConfig.width} ${sizeConfig.height}" fill="none" role="img" aria-label="${safeLabel}">` +
            bodyMarkup +
            `</svg>`;

        return `data:image/svg+xml;charset=utf-8,${encodeURIComponent(svg)}`;
    }

    function updateScoreProjection() {
        const baseScore = toScore(activeClinicRecord?.vetscore) ?? defaultScore;
        const verificationSelected = verificationInterestEl?.checked !== false;
        const backlinkSelected = backlinkInterestEl?.checked === true;
        const claimedAlready = normalizeBoolean(activeClinicRecord?.claimed);
        const verifiedAlready = normalizeBoolean(activeClinicRecord?.isVerified);
        const backlinkAlready = normalizeBoolean(activeClinicRecord?.hasBacklink);

        const verifiedScenarioScore = projectTrustTierScore(baseScore, {
            includeClaimed: verificationSelected && !claimedAlready,
            includeVerified: verificationSelected && !verifiedAlready,
        });
        const verificationGain = verificationSelected
            ? Math.max(0, verifiedScenarioScore - baseScore)
            : 0;

        const backlinkScenarioScore = projectTrustTierScore(baseScore, {
            includeClaimed: verificationSelected && !claimedAlready,
            includeVerified: verificationSelected && !verifiedAlready,
            includeBacklink: backlinkSelected && !backlinkAlready,
        });
        const backlinkGain = backlinkSelected
            ? Math.max(
                0,
                backlinkScenarioScore - (verificationSelected ? verifiedScenarioScore : baseScore),
            )
            : 0;

        const profileGain = getProfileDetailGain();
        const potentialGain = verificationGain + backlinkGain + profileGain;
        const selectedBoostScore = backlinkSelected
            ? backlinkScenarioScore
            : verificationSelected
                ? verifiedScenarioScore
                : baseScore;
        const projectedScore = Math.min(100, selectedBoostScore + profileGain);

        if (currentScoreEl) currentScoreEl.textContent = String(baseScore);
        if (verificationGainEl) verificationGainEl.textContent = `+${verificationGain}`;
        if (backlinkGainEl) backlinkGainEl.textContent = `+${backlinkGain}`;
        if (profileGainEl) profileGainEl.textContent = `+${profileGain}`;
        if (potentialGainEl) potentialGainEl.textContent = `+${potentialGain}`;
        if (projectedScoreEl) projectedScoreEl.textContent = String(projectedScore);

        const cityScores = Array.isArray(activeClinicRecord?.cityScores)
            ? activeClinicRecord.cityScores
            : null;
        const cityTotal = activeClinicRecord?.cityTotal || cityScores?.length || null;
        const currentRank =
            activeClinicRecord?.cityRank || getRankForScore(baseScore, cityScores);
        const verifiedRank = getRankForScore(verifiedScenarioScore, cityScores);
        const backlinkRank = getRankForScore(backlinkScenarioScore, cityScores);
        const projectedRank = getRankForScore(projectedScore, cityScores);

        if (rankNowEl) rankNowEl.textContent = formatRank(currentRank, cityTotal);
        if (rankVerifiedEl) rankVerifiedEl.textContent = formatRank(verifiedRank, cityTotal);
        if (rankBacklinkEl) rankBacklinkEl.textContent = formatRank(backlinkRank, cityTotal);

        if (rankNoteEl) {
            rankNoteEl.textContent = buildProjectionRankNote({
                practiceName: activeClinicRecord?.practiceName,
                currentRank,
                cityTotal,
                city: activeClinicRecord?.city,
                verifiedRank,
                backlinkRank,
            });
        }

        if (scoreNoteEl) {
            scoreNoteEl.textContent = buildProjectionScoreNote({
                practiceName: activeClinicRecord?.practiceName,
                baseScore,
                projectedScore,
                currentRank,
                projectedRank,
                city: activeClinicRecord?.city,
            });
        }

        updateBadgeConfigurator();
    }

    function applyClinicContext(clinicRecord) {
        activeClinicRecord = clinicRecord || null;

        if (activeClinicRecord && claimWorkflowSection) {
            claimWorkflowSection.classList.add("hidden");
        }

        if (activeClinicRecord && claimPrefillNotice && claimPrefillClinicName) {
            claimPrefillClinicName.textContent =
                activeClinicRecord.practiceName || "Selected clinic";
            claimPrefillNotice.classList.remove("hidden");
        }

        if (
            activeClinicRecord &&
            (!badgeState.label ||
                ["Listed on VetList", "Verified on VetList", "Trusted local listing"].includes(
                    badgeState.label,
                ))
        ) {
            badgeState.label = getDefaultBadgeLabel(activeClinicRecord);
            if (badgeLabelInputEl) {
                badgeLabelInputEl.value = badgeState.label;
            }
        }

        if (activeClinicRecord && !badgeState.anchorText) {
            badgeState.anchorText = getAnchorOptions(activeClinicRecord.city)[0];
            if (badgeAnchorInputEl) {
                badgeAnchorInputEl.value = badgeState.anchorText;
            }
        }

        refreshAnchorSuggestions();

        updateBadgeConfigurator();
        updateScoreProjection();
    }

