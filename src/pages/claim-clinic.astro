<script
    is:inline
    define:vars={{
        avgVetScore,
        serverClaimContext: hasInitialClaimContext ? initialClaimRecord : null,
    }}
>
    const claimCountrySelect = document.getElementById("claim-country-select");
    const claimRegionSelect = document.getElementById("claim-region-select");
    const claimCitySelect = document.getElementById("claim-city-select");
    const claimCityLink = document.getElementById("claim-city-link");
    const claimLocationNote = document.getElementById("claim-location-note");
    const claimWorkflowSection = document.getElementById("claim-workflow-section");
    const claimPrefillNotice = document.getElementById("claim-prefill-notice");
    const claimPrefillClinicName = document.getElementById("claim-prefill-clinic-name");
    const currentScoreEl = document.getElementById("claim-current-score");
    const verificationGainEl = document.getElementById("claim-verification-gain");
    const backlinkGainEl = document.getElementById("claim-backlink-gain");
    const profileGainEl = document.getElementById("claim-profile-gain");
    const potentialGainEl = document.getElementById("claim-potential-gain");
    const projectedScoreEl = document.getElementById("claim-projected-score");
    const scoreNoteEl = document.getElementById("claim-score-note");
    const rankNowEl = document.getElementById("claim-rank-now");
    const rankVerifiedEl = document.getElementById("claim-rank-verified");
    const rankBacklinkEl = document.getElementById("claim-rank-backlink");
    const rankNoteEl = document.getElementById("claim-rank-note");
    const verificationInterestEl = document.getElementById("verification-interest");
    const backlinkInterestEl = document.getElementById("backlink-interest");
    const badgeSectionEl = document.getElementById("claim-badge-section");
    const badgePreviewLinkEl = document.getElementById("claim-badge-preview-link");
    const badgePreviewImageEl = document.getElementById("claim-badge-preview-image");
    const badgeTextPreviewEl = document.getElementById("claim-badge-text-preview");
    const badgeEmbedCodeEl = document.getElementById("claim-badge-embed-code");
    const badgeCopyButtonEl = document.getElementById("copy-badge-code");
    const badgeCopyMessageEl = document.getElementById("claim-badge-copy-message");
    const badgeOpenCityPageEl = document.getElementById("claim-open-city-page");
    const badgeLabelInputEl = document.getElementById("badge-label-input");
    const badgeAnchorInputEl = document.getElementById("badge-anchor-input");
    const badgeAnchorSuggestionsEl = document.getElementById("badge-anchor-suggestions");
    const defaultScore = avgVetScore;
    const CLAIMED_MULTIPLIER = 1.12;
    const VERIFIED_MULTIPLIER = 1.08;
    const BACKLINK_MULTIPLIER = 1.18;
    const VERIFIED_TIER_FLOOR = 48;
    const TRUSTED_NETWORK_FLOOR = 66;
    const FEATURED_NETWORK_FLOOR = 74;
    const badgeState = {
        size: "md",
        theme: "light",
        shape: "rounded",
        label: "",
        anchorText: "",
    };
    let activeClinicRecord = serverClaimContext;
    let activeClinicId = "";

    function setClaimSelectOptions(selectEl, items, placeholder) {
        if (!selectEl) return;
        selectEl.innerHTML = `<option value="">${placeholder}</option>` +
            items
                .map((item) => `<option value="${item.slug}">${item.name}</option>`)
                .join("");
    }

    function resetClaimCityLink() {
        if (!claimCityLink || !claimLocationNote) return;
        claimCityLink.setAttribute("href", "#");
        claimCityLink.classList.add("pointer-events-none", "opacity-50");
        claimLocationNote.textContent = "Choose a city to open its listing page.";
    }

    function initializeClaimLocationPicker() {
        if (!claimCountrySelect || !claimRegionSelect || !claimCitySelect) return;
        const claimLocationDataEl = document.getElementById("claim-location-data");
        const claimLocationData = claimLocationDataEl
            ? JSON.parse(claimLocationDataEl.textContent || "[]")
            : [];
        if (!Array.isArray(claimLocationData) || !claimLocationData.length) return;

        setClaimSelectOptions(claimCountrySelect, claimLocationData, "Select a country");
        setClaimSelectOptions(claimRegionSelect, [], "Select country first");
        setClaimSelectOptions(claimCitySelect, [], "Select province/state first");
        claimRegionSelect.disabled = true;
        claimCitySelect.disabled = true;
        resetClaimCityLink();

        claimCountrySelect.addEventListener("change", function () {
            const selectedCountry = claimLocationData.find(
                (country) => country.slug === this.value,
            );

            setClaimSelectOptions(
                claimRegionSelect,
                selectedCountry?.regions || [],
                selectedCountry ? "Select a province/state" : "Select country first",
            );
            setClaimSelectOptions(claimCitySelect, [], "Select province/state first");
            claimRegionSelect.disabled = !selectedCountry;
            claimCitySelect.disabled = true;
            resetClaimCityLink();

            const countryInput = document.getElementById("country");
            if (countryInput) countryInput.value = selectedCountry?.name || "";
            const provinceInput = document.getElementById("province");
            if (provinceInput) provinceInput.value = "";
            const cityInput = document.getElementById("city");
            if (cityInput) cityInput.value = "";
        });

        claimRegionSelect.addEventListener("change", function () {
            const selectedCountry = claimLocationData.find(
                (country) => country.slug === claimCountrySelect.value,
            );
            const selectedRegion = selectedCountry?.regions?.find(
                (region) => region.slug === this.value,
            );

            setClaimSelectOptions(
                claimCitySelect,
                selectedRegion?.cities || [],
                selectedRegion ? "Select a city" : "Select province/state first",
            );
            claimCitySelect.disabled = !selectedRegion;
            resetClaimCityLink();

            const provinceInput = document.getElementById("province");
            if (provinceInput) provinceInput.value = selectedRegion?.name || "";
            const cityInput = document.getElementById("city");
            if (cityInput) cityInput.value = "";
        });

        claimCitySelect.addEventListener("change", function () {
            const selectedCountry = claimLocationData.find(
                (country) => country.slug === claimCountrySelect.value,
            );
            const selectedRegion = selectedCountry?.regions?.find(
                (region) => region.slug === claimRegionSelect.value,
            );
            const selectedCity = selectedRegion?.cities?.find(
                (city) => city.slug === this.value,
            );

            if (!claimCityLink || !claimLocationNote || !selectedCity) {
                resetClaimCityLink();
                return;
            }

            claimCityLink.setAttribute("href", selectedCity.href);
            claimCityLink.classList.remove("pointer-events-none", "opacity-50");
            claimLocationNote.textContent = `${selectedCity.name}, ${selectedRegion?.name || ""}`;

            const cityInput = document.getElementById("city");
            if (cityInput) cityInput.value = selectedCity.name || "";
        });
    }

    function toScore(value) {
        const numeric = Number.parseFloat(value);
        return Number.isFinite(numeric) ? Math.round(numeric) : null;
    }

    function countChecked(selector) {
        return document.querySelectorAll(`${selector}:checked`).length;
    }

    function hasOperationalHours(hoursValue = null) {
        if (hoursValue && typeof hoursValue === "object") {
            return Object.values(hoursValue).some((dayHours) => {
                if (Array.isArray(dayHours)) {
                    return dayHours.some(
                        (entry) =>
                            typeof entry === "string" &&
                            entry.trim() &&
                            !/^closed$/i.test(entry.trim()),
                    );
                }

                return (
                    typeof dayHours === "string" &&
                    dayHours.trim() &&
                    !/^closed$/i.test(dayHours.trim())
                );
            });
        }

        return Array.from(document.querySelectorAll(".day-checkbox")).some(
            (checkbox) => checkbox.checked,
        );
    }

    function normalizeBoolean(value) {
        return value === true || value === "true";
    }

    function clampScore(value) {
        const numeric = Math.round(Number.parseFloat(value) || 0);
        return Math.min(100, Math.max(0, numeric));
    }

    function applyTrustTierFloor(score, options = {}) {
        const claimed = Boolean(options.includeClaimed);
        const verified = Boolean(options.includeVerified);
        const backlink = Boolean(options.includeBacklink);
        let boostedScore = Number.parseFloat(score) || 0;

        if (claimed && verified && backlink) {
            boostedScore = Math.max(boostedScore, FEATURED_NETWORK_FLOOR);
        } else if (verified && backlink) {
            boostedScore = Math.max(boostedScore, TRUSTED_NETWORK_FLOOR);
        } else if (claimed && verified) {
            boostedScore = Math.max(boostedScore, VERIFIED_TIER_FLOOR);
        }

        return boostedScore;
    }

    function projectTrustTierScore(score, options = {}) {
        let boostedScore = Number.parseFloat(score) || 0;

        if (options.includeClaimed) {
            boostedScore *= CLAIMED_MULTIPLIER;
        }
        if (options.includeVerified) {
            boostedScore *= VERIFIED_MULTIPLIER;
        }
        if (options.includeBacklink) {
            boostedScore *= BACKLINK_MULTIPLIER;
        }

        return clampScore(applyTrustTierFloor(boostedScore, options));
    }

    function slugifyText(value) {
        return String(value || "")
            .toLowerCase()
            .trim()
            .replace(/\s+/g, "-")
            .replace(/[^\w-]+/g, "")
            .replace(/--+/g, "-")
            .replace(/-?\d+$/, "");
    }

    function deriveCityStatsFromIndex(clinicRecord, allRecords) {
        if (!clinicRecord || !Array.isArray(allRecords) || allRecords.length === 0) {
            return clinicRecord;
        }

        const city = String(clinicRecord.city || "").trim().toLowerCase();
        const province = String(clinicRecord.province || "").trim().toLowerCase();
        const country = String(clinicRecord.country || "").trim().toLowerCase();
        if (!city || !province || !country) return clinicRecord;

        const cityRecords = allRecords
            .filter((record) => {
                return (
                    String(record?.city || "").trim().toLowerCase() === city &&
                    String(record?.province || "").trim().toLowerCase() === province &&
                    String(record?.country || "").trim().toLowerCase() === country
                );
            })
            .map((record) => ({
                ...record,
                score: Number.parseFloat(record?.vetscore) || 0,
            }))
            .sort((a, b) => b.score - a.score || String(a.practiceName || "").localeCompare(String(b.practiceName || "")));

        if (!cityRecords.length) return clinicRecord;

        const currentName = String(clinicRecord.practiceName || "").trim();
        const currentAddress = String(clinicRecord.address || "").trim();
        const currentIndex = cityRecords.findIndex((record) => {
            return (
                String(record.practiceName || "").trim() === currentName &&
                String(record.address || "").trim() === currentAddress
            );
        });

        return {
            ...clinicRecord,
            cityRank: currentIndex >= 0 ? currentIndex + 1 : null,
            cityTotal: cityRecords.length,
            cityScores: cityRecords.map((record) => record.score),
            cityLeaderName: cityRecords[0]?.practiceName || "",
            cityLeaderScore: cityRecords[0]?.score != null ? Math.round(cityRecords[0].score) : null,
            cityPageHref:
                clinicRecord.cityPageHref ||
                `/${slugifyText(clinicRecord.country)}/${slugifyText(clinicRecord.province)}/${slugifyText(clinicRecord.city)}/`,
        };
    }

    function getProfileDetailGain() {
        let gain = 0;
        const websiteValue = (document.getElementById("website")?.value || "").trim();
        const hadWebsiteBefore = Boolean((activeClinicRecord?.website || "").trim());
        if (websiteValue && !hadWebsiteBefore) gain += 2;

        const customServicesValue = (
            document.getElementById("custom-services")?.value || ""
        ).trim();
        const currentServicesCount =
            countChecked('#services-grid input[type="checkbox"]') +
            (customServicesValue ? 1 : 0);
        const hadServicesBefore = Array.isArray(activeClinicRecord?.services)
            ? activeClinicRecord.services.length > 0
            : false;
        if (currentServicesCount > 0 && !hadServicesBefore) gain += 2;

        const hadAnimalsBefore = Array.isArray(activeClinicRecord?.animals)
            ? activeClinicRecord.animals.length > 0
            : false;
        if (countChecked('#animals-grid input[type="checkbox"]') > 0 && !hadAnimalsBefore) {
            gain += 1;
        }

        const hadHoursBefore = hasOperationalHours(activeClinicRecord?.hours);
        if (hasOperationalHours() && !hadHoursBefore) gain += 2;

        return gain;
    }

    function getRankForScore(score, cityScores) {
        if (!Array.isArray(cityScores) || cityScores.length === 0) return null;
        const numericScore = Number.parseFloat(score) || 0;
        return cityScores.filter((value) => (Number.parseFloat(value) || 0) > numericScore).length + 1;
    }

    function formatRank(rank, total) {
        if (!rank || !total) return "--";
        return `#${rank}`;
    }

    function buildProjectionScoreNote({
        practiceName,
        baseScore,
        projectedScore,
        currentRank,
        projectedRank,
        city,
    }) {
        if (!practiceName) {
            return "Projection assumes the full upgrade path: claim, verify, add the city-page backlink, and tighten the listing details.";
        }

        let note = `${practiceName} can jump from ${baseScore} to ${projectedScore}.`;

        if (currentRank && projectedRank && city) {
            note += ` That can move it from #${currentRank} to around #${projectedRank} in ${city}.`;
            if (projectedRank <= 5) {
                note += " That is the kind of jump that gets a clinic into the local top tier fast.";
            }
        }

        return note;
    }

    function buildProjectionRankNote({
        practiceName,
        currentRank,
        cityTotal,
        city,
        verifiedRank,
        backlinkRank,
    }) {
        if (!currentRank || !cityTotal || !city) {
            return "We’ll compare your upgraded projection against every clinic in the same city when clinic data is available.";
        }

        let note =
            `${practiceName || "This clinic"} is currently #${currentRank} of ${cityTotal} in ${city}. ` +
            `Verification can push it to about #${verifiedRank || currentRank}, ` +
            `and the backlink tier can push it to about #${backlinkRank || verifiedRank || currentRank}.`;

        if (backlinkRank && backlinkRank <= 5) {
            note += " That puts the clinic in striking distance of the top 5.";
        }

        return note;
    }

    function resolveCityPageHref() {
        if (activeClinicRecord?.cityPageHref) return activeClinicRecord.cityPageHref;

        const urlParams = new URLSearchParams(window.location.search);
        const cityPageParam = (urlParams.get("cityPage") || "").trim();
        if (cityPageParam) return cityPageParam;

        const country = document.getElementById("country")?.value || activeClinicRecord?.country;
        const province = document.getElementById("province")?.value || activeClinicRecord?.province;
        const city = document.getElementById("city")?.value || activeClinicRecord?.city;
        if (!country || !province || !city) return "";

        return `/${slugifyText(country)}/${slugifyText(province)}/${slugifyText(city)}/`;
    }

