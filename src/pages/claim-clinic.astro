---
import Layout from "../layouts/Layout.astro";
import UnifiedVetSearch from "../components/UnifiedVetSearch.astro";

const title = "Claim Your Veterinary Practice | VetList.org";
const description =
    "Claim and verify your veterinary practice profile to increase visibility and attract more pet owners.";
---

<Layout title={title} description={description}>
    <div class="max-w-4xl mx-auto pt-8">
        <!-- Search Section -->
        <div class="bg-blue-50 border border-blue-200 rounded-xl p-6 mb-8">
            <h2 class="text-xl font-semibold text-gray-900 mb-3">
                Find Your Clinic First
            </h2>
            <p class="text-gray-600 mb-4">
                Use the search below to find your clinic and click "Claim" if you see it. If you don't find your clinic, then click "Add Your Clinic" to create a new listing.
            </p>
            <UnifiedVetSearch />
            <div class="mt-4 text-center">
                <a 
                    href="/add-vet/" 
                    class="inline-flex items-center gap-2 bg-gradient-to-r from-orange-500 to-red-600 text-white px-6 py-3 rounded-lg hover:from-orange-600 hover:to-red-700 transition-all font-medium"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
                    </svg>
                    Don't see your clinic? Add it here
                </a>
            </div>
        </div>

        <!-- Header -->
        <div class="text-center mb-8">
            <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4 pt-4">
                Claim Your Veterinary Practice
            </h1>
            <p class="text-lg text-gray-600">
                Update your information and boost your online presence
            </p>
        </div>

        <!-- Claim Form -->
        <div class="bg-white rounded-xl shadow-card p-8 mb-8">
            <h2 class="text-2xl font-bold text-gray-900 mb-3">
                Update Your Practice Information
            </h2>
            <div class="bg-blue-50 border-l-4 border-blue-400 p-4 mb-6">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <svg
                            class="h-5 w-5 text-blue-400"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <div class="ml-3">
                        <p class="text-sm text-blue-700">
                            Please review and update any incorrect information
                            below. Our team will process your request and update
                            your profile as soon as possible, typically within
                            24-48 hours.
                        </p>
                    </div>
                </div>
            </div>

            <form id="claim-form" class="space-y-6">
                <!-- Basic Information -->
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >Practice Name *</label
                        >
                        <input
                            type="text"
                            id="practice-name"
                            required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >Phone Number *</label
                        >
                        <input
                            type="tel"
                            id="phone"
                            required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                </div>

                <!-- Address -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2"
                        >Full Address *</label
                    >
                    <input
                        type="text"
                        id="address"
                        required
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                    />
                </div>

                <div class="grid md:grid-cols-3 gap-6">
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >City *</label
                        >
                        <input
                            type="text"
                            id="city"
                            required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >Province/State *</label
                        >
                        <input
                            type="text"
                            id="province"
                            required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >Country *</label
                        >
                        <input
                            type="text"
                            id="country"
                            required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                </div>

                <!-- Contact Information -->
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >Email Address *</label
                        >
                        <input
                            type="email"
                            id="email"
                            required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >Website</label
                        >
                        <input
                            type="url"
                            id="website"
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                </div>

                <!-- Services -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-3"
                        >Services & Specializations Offered</label
                    >
                    <div
                        class="grid md:grid-cols-3 gap-3 mb-4"
                        id="services-grid"
                    >
                        <!-- Most Common Veterinary Services -->
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="General Veterinary Care"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >General Veterinary Care</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Emergency Care"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Emergency Care</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Surgery"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Surgery</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Preventive Care"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Preventive Care</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Vaccinations"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Vaccinations</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Spay/Neuter"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Spay/Neuter</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Dental Care"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Dental Care</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Dermatology"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Dermatology</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Cardiology"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Cardiology</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Oncology"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Oncology</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Orthopedics"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Orthopedics</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Internal Medicine"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Internal Medicine</span
                            >
                        </label>

                        <!-- Specific Treatments -->
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="X-Ray/Imaging"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >X-Ray/Imaging</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Laboratory Services"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Laboratory Services</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Microchipping"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Microchipping</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Grooming"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Grooming</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Boarding"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Boarding</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Exotic Pet Care"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Exotic Pet Care</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Large Animal Care"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Large Animal Care</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Equine Care"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Equine Care</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Behavioral Consultation"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Behavioral Consultation</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Nutrition Counseling"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Nutrition Counseling</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Pain Management"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Pain Management</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Rehabilitation"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Rehabilitation</span
                            >
                        </label>

                        <!-- Additional Services -->
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="House Calls"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >House Calls</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Euthanasia Services"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Euthanasia Services</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Pet Insurance"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Pet Insurance</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Wellness Plans"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Wellness Plans</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Telemedicine"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Telemedicine</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Ultrasound"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Ultrasound</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Laser Therapy"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Laser Therapy</span
                            >
                        </label>
                        <label class="flex items-center">
                            <input
                                type="checkbox"
                                value="Acupuncture"
                                class="rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                            />
                            <span class="ml-2 text-sm text-gray-700"
                                >Acupuncture</span
                            >
                        </label>
                    </div>

                    <!-- Custom Services Input -->
                    <div class="border-t pt-4">
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >Additional Services (if not listed above)</label
                        >
                        <input
                            type="text"
                            id="custom-services"
                            placeholder="Enter additional services separated by commas"
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                        <p class="text-xs text-gray-500 mt-1">
                            Example: Holistic treatments, Alternative medicine,
                            etc.
                        </p>
                    </div>
                </div>

                <!-- Hours -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-4"
                        >Hours of Operation</label
                    >
                    <div class="space-y-3" id="hours-container">
                        {
                            [
                                "Monday",
                                "Tuesday",
                                "Wednesday",
                                "Thursday",
                                "Friday",
                                "Saturday",
                                "Sunday",
                            ].map((day) => (
                                <div class="flex flex-col sm:flex-row sm:items-center gap-2 sm:gap-4">
                                    <div class="flex items-center gap-4 sm:gap-4">
                                        <div class="w-20 sm:w-24 text-sm font-medium text-gray-700">
                                            {day}
                                        </div>
                                        <label class="flex items-center">
                                            <input
                                                type="checkbox"
                                                class="day-checkbox rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                                                data-day={day.toLowerCase()}
                                            />
                                            <span class="ml-2 text-sm text-gray-600">
                                                Open
                                            </span>
                                        </label>
                                    </div>
                                    <div class="flex items-center gap-2 ml-24 sm:ml-0">
                                        <input
                                            type="time"
                                            class="day-open px-3 py-2 border border-gray-300 rounded-md text-sm flex-1 sm:flex-none"
                                            data-day={day.toLowerCase()}
                                            disabled
                                        />
                                        <span class="text-gray-500 text-sm">to</span>
                                        <input
                                            type="time"
                                            class="day-close px-3 py-2 border border-gray-300 rounded-md text-sm flex-1 sm:flex-none"
                                            data-day={day.toLowerCase()}
                                            disabled
                                        />
                                    </div>
                                </div>
                            ))
                        }
                    </div>
                </div>

                <!-- FAQ Section -->
                <div class="bg-blue-50 border border-blue-200 rounded-xl p-6">
                    <div class="flex items-center gap-2 mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-blue-600">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-9 5.25h.008v.008H12v-.008z" />
                        </svg>
                        <label class="text-lg font-semibold text-gray-900"
                            >Common Questions Your Practice Handles</label
                        >
                    </div>
                    <p class="text-sm text-gray-600 mb-4">
                        Select the questions your practice commonly answers. This helps pet owners understand your expertise areas and improves your profile visibility.
                    </p>
                    <div class="grid md:grid-cols-1 gap-3 mb-4" id="faq-grid">
                        <!-- FAQ checkboxes will be populated by JavaScript -->
                    </div>
                    <div class="flex justify-between items-center mt-2">
                        <p class="text-xs text-blue-600">
                            💡 We've pre-selected questions based on your services, but you can adjust these selections.
                        </p>
                        <span id="faq-counter" class="text-xs font-medium text-gray-600 bg-white px-2 py-1 rounded">
                            0 selected
                        </span>
                    </div>
                </div>

                <!-- Submit Buttons -->
                <div
                    class="flex flex-col sm:flex-row gap-4 justify-center items-center"
                >
                    <button
                        type="submit"
                        class="bg-primary-600 hover:bg-primary-700 text-white px-8 py-4 rounded-full font-medium text-lg transition-colors duration-200"
                    >
                        Generate Claim Email
                    </button>

                    <button
                        type="button"
                        id="reveal-premium"
                        class="bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-700 hover:to-indigo-700 text-white px-6 py-4 rounded-full font-medium text-lg transition-all duration-200 shadow-lg hover:shadow-xl transform hover:scale-105"
                    >
                        <span class="flex items-center gap-2">
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="2"
                                stroke="currentColor"
                                class="w-5 h-5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z"
                                ></path>
                            </svg>
                            Rank Higher in ChatGPT
                        </span>
                    </button>
                </div>
            </form>
        </div>

        <!-- Hidden Premium Sales Pitch -->
        <div
            id="premium-section"
            class="hidden mb-8 opacity-0 transform translate-y-4 transition-all duration-500 ease-out"
        >
            <!-- AI Explanation Header -->
            <div
                class="bg-gradient-to-r from-slate-900 to-slate-800 rounded-xl p-8 mb-6 text-white relative overflow-hidden"
            >
                <div
                    class="absolute inset-0 bg-gradient-to-r from-blue-600/10 to-purple-600/10"
                >
                </div>
                <div class="relative z-10">
                    <div class="text-center mb-6">
                        <div
                            class="inline-flex items-center justify-center w-16 h-16 bg-gradient-to-r from-blue-500 to-purple-500 rounded-full mb-4"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="2"
                                stroke="currentColor"
                                class="w-8 h-8"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
