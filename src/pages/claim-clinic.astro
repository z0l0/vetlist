                                        <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"></path>
                                    </svg>
                                </div>
                            </div>
                        </div>
                        <div class="flex flex-wrap items-center gap-3">
                            <a
                                id="claim-city-link"
                                href="#"
                                class="inline-flex rounded-full border border-cyan-300/25 bg-cyan-300/10 px-5 py-3 text-sm font-semibold text-cyan-800 transition hover:bg-cyan-300/15 pointer-events-none opacity-50"
                            >
                                Browse clinics in selected city
