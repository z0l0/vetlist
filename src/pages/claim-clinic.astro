                    </div>
                </div>

                <div class="rounded-[24px] border border-slate-200 bg-slate-50 p-6">
                    <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Direct contact</p>
                    <h3 class="mt-2 text-2xl font-black tracking-tight text-slate-950">Email us if the finder misses</h3>
                    <p class="mt-4 text-sm leading-7 text-slate-600">
                        If you can’t find the listing quickly, send the claim details directly and we’ll help sort it out.
                    </p>
                    <a href="mailto:directorytraffic@gmail.com" class="mt-5 inline-flex rounded-full border border-cyan-300/25 bg-cyan-300/10 px-5 py-3 text-sm font-semibold text-cyan-800 transition hover:bg-cyan-300/15">
                        directorytraffic@gmail.com
                    </a>
                    <div class="mt-5 space-y-3 text-sm text-slate-600">
                        <p>Include clinic name, city, website, and the best owner or manager email.</p>
                        <p>If your clinic is not listed yet, use <a href="/add-vet/" class="font-semibold text-cyan-700 hover:text-cyan-800">Add Your Clinic</a> instead.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Claim Form -->
        <div class="bg-white rounded-2xl shadow-2xl p-10 mb-10 border border-gray-100">
            <h2 class="text-3xl font-black text-gray-900 mb-6">
                Update Your Practice Information
            </h2>
            <div class="bg-blue-50 border-l-4 border-blue-400 p-4 mb-6">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <svg
                            class="h-5 w-5 text-blue-400"
                            viewBox="0 0 20 20"
                            fill="currentColor"
                        >
                            <path
                                fill-rule="evenodd"
                                d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z"
                                clip-rule="evenodd"></path>
                        </svg>
                    </div>
                    <div class="ml-3">
                        <p class="text-sm text-blue-700">
                            Please review and update any incorrect information
                            below. Our team will process your request and update
                            your profile as soon as possible, typically within
                            24-48 hours.
                        </p>
                    </div>
                </div>
            </div>

            <form id="claim-form" class="space-y-6">
                <!-- Basic Information -->
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >Practice Name *</label
                        >
                        <input
                            type="text"
                            id="practice-name"
                            required
                            value={initialClaimRecord.practiceName}
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >Phone Number *</label
                        >
                        <input
                            type="tel"
                            id="phone"
                            required
                            value={initialClaimRecord.phone}
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                </div>

                <!-- Address -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2"
                        >Full Address *</label
                    >
                    <input
                        type="text"
                        id="address"
                        required
                        value={initialClaimRecord.address}
                        class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                    />
                </div>

                <div class="grid md:grid-cols-3 gap-6">
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >City *</label
                        >
                        <input
                            type="text"
                            id="city"
                            required
                            value={initialClaimRecord.city}
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >Province/State *</label
                        >
                        <input
                            type="text"
                            id="province"
                            required
                            value={initialClaimRecord.province}
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >Country *</label
                        >
                        <input
                            type="text"
                            id="country"
                            required
                            value={initialClaimRecord.country}
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                </div>

                <!-- Contact Information -->
                <div class="grid md:grid-cols-2 gap-6">
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >Email Address *</label
                        >
                        <input
                            type="email"
                            id="email"
                            required
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                    <div>
                        <label
                            class="block text-sm font-medium text-gray-700 mb-2"
                            >Website</label
                        >
                        <input
                            type="url"
                            id="website"
                            value={initialClaimRecord.website}
                            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                        />
                    </div>
                </div>

                <div class="rounded-[28px] border border-emerald-200 bg-gradient-to-br from-emerald-50 via-white to-cyan-50 p-6">
                    <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-emerald-700">Visibility boosts</p>
                            <h3 class="mt-2 text-2xl font-black tracking-tight text-slate-950">Verify first, then add the city-page backlink</h3>
                            <p class="mt-4 text-sm leading-7 text-slate-600">
                                Owner verification creates the first jump. The real move comes from adding a VetList badge on your homepage or footer that links back to your city page on VetList.
                            </p>
                            <p class="mt-3 text-sm leading-7 text-slate-600">
                                That backlink should point to the city page, not the homepage, so the SEO signal supports the market page where local pet owners are browsing and pushes the listing into the stronger network tier.
                            </p>
                        </div>
                        <div class="space-y-4">
                            <label class="flex items-start gap-3 rounded-2xl border border-slate-200 bg-white px-4 py-4 shadow-sm">
                                <input
                                    type="checkbox"
                                    id="verification-interest"
                                    checked
                                    class="mt-1 rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                                />
                                <span>
                                    <span class="block text-sm font-semibold text-slate-950">Include owner verification</span>
                                    <span class="mt-1 block text-sm text-slate-600">
                                        Unlocks the verified badge and the first major trust-tier jump.
                                    </span>
                                </span>
                            </label>
                            <label class="flex items-start gap-3 rounded-2xl border border-emerald-200 bg-white px-4 py-4 shadow-sm">
                                <input
                                    type="checkbox"
                                    id="backlink-interest"
                                    checked
                                    class="mt-1 rounded border-gray-300 text-primary-600 focus:ring-primary-500"
                                />
                                <span>
                                    <span class="block text-sm font-semibold text-slate-950">Add a VetList city-page badge backlink</span>
                                    <span class="mt-1 block text-sm text-slate-600">
                                        This is the biggest boost. It pushes the clinic into the stronger backlink tier and we’ll generate the ready-to-paste badge code below.
                                    </span>
                                </span>
                            </label>
                        </div>
                    </div>
                </div>

                <div
                    id="claim-badge-section"
                    class:list={[
                        "rounded-[28px] border border-slate-200 bg-slate-50 p-6",
                        !hasInitialClaimContext && "hidden",
                    ]}
                >
                    <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr] items-start">
                        <div>
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">City backlink badge</p>
                            <h3 class="mt-2 text-2xl font-black tracking-tight text-slate-950">Embed your VetList badge</h3>
                            <p class="mt-4 text-sm leading-7 text-slate-600">
                                Use this on your homepage or footer. It links to your VetList city page and gives visitors a clean local ranking badge they can drop in quickly.
                            </p>

                            <div class="mt-6 space-y-5">
                                <div>
                                    <div class="text-sm font-semibold text-slate-700 mb-2">Size</div>
                                    <div class="flex flex-wrap gap-2">
                                        <button type="button" data-badge-size="md" class="claim-badge-tab active">Standard</button>
                                        <button type="button" data-badge-size="sm" class="claim-badge-tab">Small</button>
                                    </div>
                                    <p class="mt-2 text-xs text-slate-500">Small uses fewer words and pushes the VetScore harder, so it fits more naturally in tight footers and sidebars.</p>
                                </div>
                                <div>
                                    <div class="text-sm font-semibold text-slate-700 mb-2">Theme</div>
                                    <div class="flex flex-wrap gap-2">
                                        <button type="button" data-badge-theme="light" class="claim-badge-tab active">Light</button>
                                        <button type="button" data-badge-theme="dark" class="claim-badge-tab">Dark</button>
                                        <button type="button" data-badge-theme="mint" class="claim-badge-tab">Mint</button>
                                    </div>
                                </div>
                                <div>
                                    <div class="text-sm font-semibold text-slate-700 mb-2">Shape</div>
                                    <div class="flex flex-wrap gap-2">
                                        <button type="button" data-badge-shape="rounded" class="claim-badge-tab active">Rounded</button>
                                        <button type="button" data-badge-shape="square" class="claim-badge-tab">Square</button>
                                    </div>
                                </div>
                                <div>
                                    <label for="badge-label-input" class="block text-sm font-semibold text-slate-700 mb-2">Badge headline</label>
                                    <input
                                        type="text"
                                        id="badge-label-input"
                                        maxlength="34"
                                        placeholder="#1 Miami Veterinarian"
                                        class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                                    />
                                    <p class="mt-2 text-xs text-slate-500">Examples: #1 Miami Veterinarian, Top Miami Veterinarian, Miami Veterinarian.</p>
                                </div>
                                <div>
                                    <label for="badge-anchor-input" class="block text-sm font-semibold text-slate-700 mb-2">Anchor text</label>
                                    <input
                                        type="text"
                                        id="badge-anchor-input"
                                        maxlength="44"
                                        class="w-full px-4 py-3 border border-gray-300 rounded-xl focus:ring-2 focus:ring-primary-500 focus:border-primary-500"
                                    />
                                    <div id="badge-anchor-suggestions" class="mt-3 flex flex-wrap gap-2"></div>
                                    <p class="mt-2 text-xs text-slate-500">Keep anchors natural. A few good local variants help more than repetitive exact-match spam.</p>
                                </div>
                            </div>
                        </div>

                        <div class="rounded-[24px] bg-slate-950 p-5 text-white shadow-[0_20px_48px_rgba(15,23,42,0.2)]">
                            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-400">Preview</p>
                            <div class="mt-4 rounded-2xl bg-white p-4">
                                <div id="claim-badge-preview-stack" class="flex flex-col items-center gap-3">
                                    <a
                                        id="claim-badge-preview-link"
                                        href="#"
                                        target="_blank"
                                        rel="noopener"
                                        class="inline-block"
                                    >
                                        <img
                                            id="claim-badge-preview-image"
                                            src=""
                                            alt="VetList badge preview"
                                            class="block h-auto rounded-xl"
                                        />
                                    </a>
                                    <a
                                        id="claim-badge-text-preview"
                                        href="#"
                                        target="_blank"
                                        rel="noopener"
                                        class="hidden text-center text-sm font-semibold text-cyan-700 underline decoration-cyan-300 underline-offset-4"
                                    ></a>
                                </div>
                            </div>

                            <textarea
                                id="claim-badge-embed-code"
                                readonly
                                class="mt-4 h-40 w-full rounded-2xl border border-white/10 bg-slate-900 p-4 text-sm text-slate-100"
                            ></textarea>

                            <div class="mt-4 flex flex-wrap gap-3">
                                <button
                                    type="button"
                                    id="copy-badge-code"
                                    class="rounded-full bg-emerald-400 px-5 py-3 text-sm font-semibold text-slate-950 transition hover:bg-emerald-300"
                                >
                                    Copy Embed Code
