---
import Layout from '../../../../layouts/Layout.astro';
import Breadcrumbs from '../../../../components/Breadcrumbs.astro';
import { getProfessionals, getProfilesForCity, getLocationDetails, getNearbyCitiesForCity } from '../../../../lib/dataCache.js';
// Keep the direct import as fallback
import { fetchAllProfessionals } from '../../../../lib/supabase';

// Convert slug to title case
function toTitleCase(str) {
  return str
    .replace(/-/g, ' ')
    .split(' ')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

export async function getStaticPaths() {
  try {
    // First try to get from cache
    const profiles = await getProfessionals();
    console.log(`[city].astro getStaticPaths: Received ${profiles?.length || 0} profiles from cache.`);
    
    // If cache failed or is empty, fall back to direct fetch
    const allProfiles = profiles?.length ? profiles : await fetchAllProfessionals();
    console.log('Generated static paths for cities from', allProfiles.length, 'profiles');

    // Filter out profiles with missing or empty slugs
    const validProfiles = allProfiles.filter(profile => 
      profile.country_slug && 
      profile.province_slug && 
      profile.city_slug &&
      profile.country_slug.trim() !== '' && 
      profile.province_slug.trim() !== '' && 
      profile.city_slug.trim() !== ''
    );
    
    console.log(`[city].astro getStaticPaths: ${validProfiles.length} valid profiles after filtering`);

    const cities = new Map();
    validProfiles.forEach(profile => {
      const key = `${profile.country_slug}/${profile.province_slug}/${profile.city_slug}`;
      if (!cities.has(key)) {
        cities.set(key, {
          country: profile.country_slug,
          region: profile.province_slug,
          city: profile.city_slug
        });
      }
    });

    const paths = Array.from(cities.values()).map(({ country, region, city }) => ({
      params: { country, region, city }
    }));

    console.log(`[city].astro getStaticPaths: Generated ${paths.length} city paths`);
    return paths;
  } catch (fetchError) {
    console.error('Error fetching profiles for static paths:', fetchError);
    return [];
  }
}

const { country, region, city } = Astro.params;

// Attempt to use the cached data first
let profiles: any[] = [];
let locations: any[] = [];
let nearbyData: any[] = [];

// Get profiles for this city first from cache
profiles = await getProfilesForCity(country, region, city);

// If no profiles found in cache, fetch all profiles and filter
if (!profiles || profiles.length === 0) {
  console.log(`[city].astro: No profiles found in cache for ${country}/${region}/${city}, trying direct fetch...`);
  try {
    const allProfiles = await getProfessionals();
    profiles = allProfiles.filter(p => 
      p.country_slug === country && 
      p.province_slug === region && 
      p.city_slug === city
    );
  } catch (e) {
    console.error(`[city].astro: Error fetching profiles from cache:`, e.message);
    
    // Try direct fetch as last resort
    try {
      const allProfiles = await fetchAllProfessionals();
      profiles = allProfiles.filter(p => 
        p.country_slug === country && 
        p.province_slug === region && 
        p.city_slug === city
      );
    } catch (directFetchError) {
      console.error(`[city].astro: Direct fetch also failed:`, directFetchError.message);
      profiles = [];
    }
  }
}

console.log('Fetched', profiles.length, 'profiles for', `${country}/${region}/${city}`);

// Fetch location details from cache
let locationDetails = await getLocationDetails(country, region, city);
const longDescription = locationDetails?.long_description || null;

// Get nearby cities from cache
const nearbyCities = await getNearbyCitiesForCity(country, region, city);

// Apply smart limiting to cached cities too
let limitedCachedCities = nearbyCities;
if (nearbyCities && nearbyCities.length > 12) {
  const sortedCached = nearbyCities.sort((a, b) => b.count - a.count);
  const topCached = sortedCached.slice(0, 6);
  const remainingCached = sortedCached.slice(6);
  const shuffledRemainingCached = remainingCached.sort(() => Math.random() - 0.5).slice(0, 6);
  limitedCachedCities = [...topCached, ...shuffledRemainingCached];
}

// If nearbyCities is empty, compute it on the fly
let finalNearbyCities = limitedCachedCities;
if (!finalNearbyCities || finalNearbyCities.length === 0) {
  console.log(`[city].astro: No nearby cities found in cache for ${country}/${region}/${city}, computing on the fly...`);
  
  try {
    // Get all profiles for this region
    const allProfiles = await getProfessionals();
    nearbyData = allProfiles.filter(p => 
      p.country_slug === country && 
      p.province_slug === region && 
      p.city_slug !== city
    );

    const nearbyCityCounts = new Map();
    nearbyData.forEach(item => {
      const key = item.city_slug;
      nearbyCityCounts.set(key, (nearbyCityCounts.get(key) || 0) + 1);
    });

    const uniqueNearbyCities = [...new Set(nearbyData.map(item => item.city_slug))].map(citySlug => {
      const cityData = nearbyData.find(item => item.city_slug === citySlug);
      return { city_slug: citySlug, city: cityData.city, count: nearbyCityCounts.get(citySlug) || 0 };
    });

    // Sort by count and limit to top cities + some random ones
    const sortedCities = uniqueNearbyCities.sort((a, b) => b.count - a.count);
    const topCities = sortedCities.slice(0, 6); // Top 6 by vet count
    const remainingCities = sortedCities.slice(6);
    
    // Shuffle remaining cities and take up to 6 more
    const shuffledRemaining = remainingCities.sort(() => Math.random() - 0.5).slice(0, 6);
    
    finalNearbyCities = [...topCities, ...shuffledRemaining];
  } catch (e) {
    console.error(`[city].astro: Error computing nearby cities:`, e.message);
    finalNearbyCities = [];
  }
}

const cityName = profiles?.[0]?.city || toTitleCase(city);
const profileCount = profiles ? profiles.length : 0;
const path = Astro.url.pathname.replace(/\/$/, '');
---

<Layout title={`${cityName} Veterinarians`}>
  <!-- Local business schema for rich snippets -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": `Veterinarians in ${cityName}`,
    "description": `Complete directory of veterinary clinics and animal hospitals in ${cityName}, ${toTitleCase(region)}`,
    "numberOfItems": profiles.length,
    "itemListOrder": "https://schema.org/ItemListOrderDescending",
    "itemListElement": profiles.slice(0, 20).map((profile, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "VeterinaryCare",
        "@id": `https://vetlist.org/${country}/${region}/${city}/${profile.name_slug}`,
        "name": profile.name,
        "address": {
          "@type": "PostalAddress",
          "addressLocality": profile.city,
          "addressRegion": profile.province,
          "addressCountry": profile.country
        },
        "telephone": profile.phone_number || "",
        "url": `https://vetlist.org/${country}/${region}/${city}/${profile.name_slug}`,
        ...(profile.rating ? {
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": profile.rating,
            "bestRating": "5"
          }
        } : {})
      }
    })),
    "mainEntity": {
      "@type": "City",
      "name": cityName,
      "containedInPlace": {
        "@type": "State", 
        "name": toTitleCase(region)
      }
    }
  })} />
  
  <Breadcrumbs path={path} />
  
  <!-- Hero Section with Disappearing Logic -->
  <section class="relative overflow-hidden bg-gradient-to-br from-primary-700 via-primary-800 to-primary-900 pt-4 pb-4 md:pt-6 md:pb-6 mb-2" style="margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); width: 100vw;">
    <!-- Subtle background elements -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 -right-40 w-80 h-80 bg-blue-500/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl"></div>
    </div>

    <div class="container mx-auto px-4 md:px-8 lg:px-12 max-w-6xl relative">
      <!-- Header Container with Dynamic Height -->
      <div
        id="hero-header-container"
        class="text-center transition-all duration-500 ease-out overflow-hidden"
        style="margin-bottom: 0.5rem;"
      >
        <!-- Main Header -->
        <div id="hero-header" class="transition-all duration-500 ease-out">
          <h1 class="text-lg md:text-xl xl:text-2xl font-medium text-white/85 mb-1.5 leading-tight tracking-wide">
            {cityName} Veterinarians
          </h1>
          <div class="text-sm xl:text-base text-primary-100/70 leading-relaxed max-w-5xl mx-auto font-light">
            {longDescription ? (
              <div class="description-wrapper">
                <div class="description clamped" id="description" set:html={longDescription}></div>
                <button class="read-more text-primary-200 hover:text-white underline mt-2" id="readMore">Read More</button>
                <button class="hide text-primary-200 hover:text-white underline mt-2" id="hide" style="display: none;">Read Less</button>
              </div>
            ) : (
              <p>Find the best veterinary clinics in {cityName}, {toTitleCase(region)}</p>
            )}
          </div>
        </div>

        <!-- Ultra-minimal Header State - Behind Content -->
        <div
          id="hero-header-mini"
          class="transition-all duration-500 ease-out opacity-0 scale-90 pointer-events-none fixed inset-x-0 z-40"
          style="top: -10px;"
        >
          <div class="container mx-auto px-4 md:px-8 lg:px-12 max-w-6xl">
            <button
              id="header-expand-btn"
              class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-white/10 backdrop-blur-md rounded-full border border-white/20 text-white/70 hover:text-white/90 hover:bg-white/20 transition-all text-xs font-light shadow-lg"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1"
                stroke="currentColor"
                class="w-3 h-3"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
              </svg>
              <span>{cityName} Veterinarians</span>
            </button>
          </div>
        </div>
      </div>


    </div>
  </section>

    <div id="profiles-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {profiles && profiles.length > 0 ? (
        profiles.slice(0, 36).map(profile => (
