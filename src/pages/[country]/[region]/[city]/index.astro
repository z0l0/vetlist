                        </svg>
                        <span class="font-medium">{profile.rating.toFixed(1)}</span>
                      </div>
                    )}
                  </div>
                </div>
              </a>
            ) : (
              <div class="flex h-32">
                <div class="relative w-32 h-32 bg-primary-50 flex-shrink-0">
                  {profile.picture ? (
                    <img 
                      src={profile.picture} 
                      alt={`${profile.name} image`} 
                      class="w-full h-full object-cover"
                      onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                    />
                  ) : null}
                  <div class={`absolute inset-0 flex items-center justify-center text-primary-500 ${profile.picture ? 'hidden' : 'flex'}`}>
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-8 h-8">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v4"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14 14h-4"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14 18h-4"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M14 8h-4"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M18 12h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-9a2 2 0 0 1 2-2h2"/>
                      <path stroke-linecap="round" stroke-linejoin="round" d="M18 22V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v18"/>
                    </svg>
                  </div>
                </div>
                <div class="flex-1 flex flex-col justify-between p-4 min-w-0">
                  <div>
                    <h3 class="text-gray-700 font-medium text-sm leading-tight mb-2 truncate">
                      {profile.name.length > 45 ? profile.name.substring(0, 45) + '...' : profile.name}
                    </h3>
                    {profile.description && (
                      <p class="text-gray-500 text-xs leading-relaxed line-clamp-2 mb-3">
                        {profile.description.length > 80 ? profile.description.substring(0, 80) + '...' : profile.description}
                      </p>
