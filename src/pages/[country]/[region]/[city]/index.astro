                  </div>
                  <div class="flex items-center justify-between">
                    {/* Address - extract street address only */}
                    {profile.address && (
                      <div class="flex items-center text-xs text-gray-500 truncate flex-1 mr-2">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3 mr-1 flex-shrink-0">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
                        </svg>
                        <span class="truncate">
                          {(() => {
                            // Extract just the street address (first part before comma)
                            const addressParts = profile.address.split(',');
                            return addressParts[0].trim();
                          })()}
                        </span>
                      </div>
                    )}
                    
                    {/* Rating */}
                    {profile.rating && profile.rating > 0 && (
                      <div class="flex items-center text-xs text-gray-600 flex-shrink-0">
                        <svg class="w-3 h-3 text-yellow-400 mr-1" fill="currentColor" viewBox="0 0 24 24">
