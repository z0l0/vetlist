function buildSignalRows(profile, peerProfiles) {
  const total = peerProfiles.length || 0;
  return CARE_SIGNALS.map((signal) => {
    const count = peerProfiles.filter((item) => signal.active(item)).length;
    return {
      ...signal,
      active: signal.active(profile),
      count,
      total,
      percentage: total ? percent(count, total) : 0,
    };
  });
}

function fieldLabelForGap(key) {
  const labels = {
    phone_number: 'phone number',
    website: 'website',
    address: 'street address',
    hours_of_operation: 'hours',
    rating: 'rating',
    pricing: 'pricing',
    languages: 'language information',
    animals: 'pet types',
  };
  return labels[key] || key;
}

function buildDataGaps(profile, metrics, hours) {
  const checks = [
    ['phone_number', Boolean(profile.phone_number)],
    ['website', Boolean(profile.website)],
    ['address', Boolean(profile.address)],
    ['hours_of_operation', Boolean(hours)],
    ['rating', profile.rating != null],
    ['pricing', asBool(profile.has_pricing)],
    ['languages', metrics.languages.length > 0],
    ['animals', metrics.animals.length > 0],
  ];
  return checks.filter(([, present]) => !present).map(([key]) => fieldLabelForGap(key));
}

function buildDistinctiveFacts(profile, metrics, cityPeers, regionPeers, citySignalRows, regionSignalRows, hoursSummary, ratingRow) {
  const facts = [];
  const cityPeerCount = cityPeers.length;
  const regionPeerCount = regionPeers.length;
  const profileAnimals = metrics.animals.map((animal) => String(animal).toLowerCase());
  const profileServices = metrics.services.map((service) => String(service).toLowerCase());

  citySignalRows
    .filter((row) => row.active && (row.percentage <= 35 || row.count <= 3))
    .sort((a, b) => a.percentage - b.percentage)
    .slice(0, 2)
    .forEach((row) => {
      facts.push({
        label: row.label,
        detail: row.total
          ? `Only ${row.count} of ${row.total} nearby clinics publish this detail.`
          : `This detail is listed here, but there are not enough nearby clinics to compare it fairly yet.`,
      });
    });

  const rareAnimals = profileAnimals
    .filter((animal) => !['dogs', 'cats'].includes(animal))
    .map((animal) => {
      const cityCount = cityPeers.filter((item) => parseArray(item.profile.pet_types_served || item.profile.animals_treated).map((value) => String(value).toLowerCase()).includes(animal)).length;
      const regionCount = regionPeers.filter((item) => parseArray(item.profile.pet_types_served || item.profile.animals_treated).map((value) => String(value).toLowerCase()).includes(animal)).length;
      return { animal, cityCount, regionCount };
    })
    .filter((item) => (cityPeerCount && percent(item.cityCount, cityPeerCount) <= 35) || (regionPeerCount && percent(item.regionCount, regionPeerCount) <= 25))
    .slice(0, 2);

  rareAnimals.forEach((item) => {
    const comparisonText = item.cityCount > 0
      ? `Only ${item.cityCount} nearby ${item.cityCount === 1 ? 'clinic lists' : 'clinics list'} ${formatAnimal(item.animal)} care.`
      : `Few nearby clinics clearly list ${formatAnimal(item.animal)} care.`;
    facts.push({
      label: `${displayLabel(item.animal)} care`,
      detail: comparisonText,
    });
  });

  const rareServices = profileServices
    .map((service) => {
      const cityCount = cityPeers.filter((item) => item.services.map((value) => String(value).toLowerCase()).includes(service)).length;
      return { service, cityCount };
    })
    .filter((item) => cityPeerCount && percent(item.cityCount, cityPeerCount) <= 35)
    .slice(0, 2);

  rareServices.forEach((item) => {
    facts.push({
      label: displayLabel(item.service),
      detail: `Fewer nearby clinics publish ${displayLabel(item.service).toLowerCase()} than routine primary-care services.`,
    });
  });

  if (ratingRow?.cityAverage != null && metrics.rating != null && metrics.rating >= ratingRow.cityAverage + 0.25) {
    facts.push({
      label: 'Review signal',
      detail: `The listed rating is ${metrics.rating.toFixed(1)} out of 5, above the local average of ${ratingRow.cityAverage.toFixed(1)}.`,
    });
  } else if (metrics.rating != null && metrics.rating >= 4.5) {
    facts.push({
      label: 'Review signal',
      detail: `The listed rating is ${metrics.rating.toFixed(1)} out of 5.`,
    });
  }

  if (hoursSummary.hasSunday) {
    facts.push({
      label: 'Sunday hours',
      detail: 'Sunday hours are listed, which can help when weekday appointments are difficult.',
    });
  } else if (hoursSummary.hasWeekend) {
    facts.push({
      label: 'Weekend hours',
      detail: 'Weekend hours are listed, which may help for non-urgent visits outside the workweek.',
    });
  } else if (hoursSummary.hasLateHours) {
    facts.push({
      label: 'Evening access',
      detail: 'The schedule includes at least one evening closing time.',
    });
  }

  if (metrics.languages.filter((language) => language.toLowerCase() !== 'english').length > 0) {
    facts.push({
      label: 'Language access',
      detail: `${humanList(metrics.languages, { limit: 3 })} is listed for communication with the clinic.`,
    });
  }

  const regionRare = regionSignalRows
    .filter((row) => row.active && row.total > 10 && row.percentage <= 25)
    .sort((a, b) => a.percentage - b.percentage)[0];
  if (regionRare) {
    facts.push({
      label: `${regionRare.label} in the region`,
      detail: `Only ${formatPercent(regionRare.percentage)} of clinics in the broader region publish this detail.`,
    });
  }

  if (asBool(profile.has_pricing) || profile.price_range) {
    facts.push({
      label: 'Cost transparency',
      detail: 'Some pricing or price-range information is available before you call.',
    });
  }

  if (parseOptionalList(profile.veterinarian_names).length > 0) {
    facts.push({
      label: 'Named clinician',
      detail: `${humanList(parseOptionalList(profile.veterinarian_names), { limit: 2 })} ${parseOptionalList(profile.veterinarian_names).length === 1 ? 'is' : 'are'} named for this clinic.`,
    });
  }

  return facts.slice(0, 6);
}

function buildEditorialSummary(profile, metrics, distinctFacts, hoursSummary, variant) {
  const location = streetAddress(profile.address)
    ? `at ${streetAddress(profile.address)}`
    : `in ${profile.city}, ${profile.province}`;
  const animalText = metrics.animals.length
    ? `Care is listed for ${humanList(metrics.animals.map(formatAnimal), { limit: 4 })}`
    : 'Call to confirm which pets they treat';
  const standoutLabel = distinctFacts[0]?.label?.toLowerCase();
  const standout = standoutLabel
    ? `One useful detail to ask about is ${standoutLabel}.`
    : hoursSummary.summary;
  const ratingText = metrics.rating != null
    ? `The public rating shown here is ${metrics.rating.toFixed(1)} out of 5.`
    : 'A public rating is not attached yet.';

  const variants = [
    `${profile.name} is a veterinary practice ${location}. ${animalText}. ${standout} ${ratingText}`,
    `${profile.name} serves pet owners ${location}. ${animalText}; check the hours and access notes before booking. ${ratingText}`,
    `For pet owners comparing local options, ${profile.name} gives you the basics to call, map the visit, and check whether the care fits ${location}. ${animalText}. ${standout}`,
    `${profile.name} is a local veterinary provider ${location}. ${animalText}. ${ratingText}`,
    `${profile.name} may be worth a call if you need a vet ${location}. ${animalText}. ${standout}`,
    `${profile.name} may be a practical nearby option ${location}, especially if the listed hours, directions, and care details match what your pet needs. ${animalText}. ${ratingText}`,
  ];

  return variants[variant % variants.length];
}

function buildBestFitRows(profile, metrics, distinctFacts, hoursSummary) {
  const rows = [];
  const specialtyAnimals = metrics.animals.filter((animal) => !['dogs', 'cats'].includes(String(animal).toLowerCase()));
  const primarySignals = CARE_SIGNALS.filter((signal) => signal.active(profile)).map((signal) => signal.copyLabel);

  if (specialtyAnimals.length > 0) {
    rows.push({
      label: 'Pet owners with less-common animals',
      detail: `${humanList(specialtyAnimals.map(formatAnimal), { limit: 3 })} care is listed here.`,
    });
  }

  if (primarySignals.length > 0) {
    rows.push({
      label: 'Appointments needing specific access options',
      detail: `Published options include ${humanList(primarySignals, { limit: 4 })}.`,
    });
  }

  if (hoursSummary.daysOpen > 0) {
    rows.push({
      label: 'People checking availability before calling',
      detail: hoursSummary.summary,
    });
  }

  if (distinctFacts.length > 0) {
    rows.push({
      label: 'People comparing nearby clinics',
      detail: distinctFacts[0].detail,
    });
  }

  if (!rows.length) {
    rows.push({
      label: 'Basic contact lookup',
      detail: 'The strongest use case for this page is confirming location and contact details before reaching out.',
    });
  }

  return rows.slice(0, 4);
}

const { country, region, city, profile } = Astro.params;
const { profileId } = Astro.props || {};

let profileData = profileId ? await getProfessionalById(profileId) : null;

if (!profileData) {
  const allProfiles = await getProfessionals();
  profileData = allProfiles.find((item) =>
    item.country_slug === country &&
    item.province_slug === region &&
    item.city_slug === city &&
    item.name_slug === profile
  );
}

if (!profileData) {
  const allProfiles = await fetchAllProfessionals();
  profileData = allProfiles.find((item) =>
    item.country_slug === country &&
    item.province_slug === region &&
    item.city_slug === city &&
    item.name_slug === profile
  );
}

const missingProfile = !profileData;

if (!profileData) {
  profileData = {
    id: profileId || 'missing',
    name: 'Profile not found',
    country_slug: country,
    province_slug: region,
    city_slug: city,
    name_slug: profile,
    country: titleCase(country),
    province: titleCase(region),
    city: titleCase(city),
    address: '',
    phone_number: '',
    website: '',
    description: '',
    detailed_description: '',
    specialization: [],
    pet_types_served: [],
    faqs: [],
    claimed: false,
    is_verified: false,
  };
}

const cityProfiles = await getProfilesForCity(country, region, city);
const regionProfiles = await getProfilesForRegion(country, region);
const relatedVets = await getRelatedVetsForProfile(profileData.id);
const nearbyCities = await getNearbyCitiesForCity(country, region, city);

const profileKey = `${profileData.id}-${profileData.name_slug}`;
const cityPeersRaw = cityProfiles.filter((item) => `${item.id}-${item.name_slug}` !== profileKey);
const regionPeersRaw = regionProfiles.filter((item) => `${item.id}-${item.name_slug}` !== profileKey);

const metrics = buildProfileMetrics(profileData);
const cityPeerMetrics = cityPeersRaw.map((item) => ({ profile: item, ...buildProfileMetrics(item) }));
const regionPeerMetrics = regionPeersRaw.map((item) => ({ profile: item, ...buildProfileMetrics(item) }));

const comparisonRows = buildComparisonRows(metrics, cityPeerMetrics, regionPeerMetrics);

const languages = metrics.languages;
const services = metrics.services;
const animals = metrics.animals;
const faqs = parseFaqs(profileData.faqs);
const hours = parseHours(profileData.hours_of_operation);
const veterinarianNames = parseArray(profileData.veterinarian_names);
const socialLinks = parseSocialLinks(profileData.social_media);
const website = safeWebsite(profileData.website);
const imageUrl = profileData.picture && /^https?:\/\//.test(profileData.picture) ? profileData.picture : '';
const reviewDates = buildReviewDates(profileData);
const sourceDateLabel = formatDate(reviewDates.sourceDate);
const checkedDateLabel = formatDate(reviewDates.checkedDate);
const refreshDateLabel = formatDate(reviewDates.refreshDate);

const cityRatingValues = cityPeerMetrics.map((item) => item.rating).filter((value) => value != null);
const cityAvgRating = average(cityRatingValues);
const ratingRow = comparisonRows.find((row) => row.key === 'rating');
const vetscoreRow = comparisonRows.find((row) => row.key === 'vetscore');
const coveragePercent = percent(metrics.completenessScore, metrics.completenessMax);
const hoursSummary = analyzeHours(hours);
const citySignalRows = buildSignalRows(profileData, cityProfiles);
const regionSignalRows = buildSignalRows(profileData, regionProfiles);
const distinctiveFacts = buildDistinctiveFacts(profileData, metrics, cityPeerMetrics, regionPeerMetrics, citySignalRows, regionSignalRows, hoursSummary, ratingRow);
const pageVariant = hashString(profileData.composite_id || profileData.id || profileData.name_slug || profileData.name);
const factualSummary = buildEditorialSummary(profileData, metrics, distinctiveFacts, hoursSummary, pageVariant);
const bestFitRows = buildBestFitRows(profileData, metrics, distinctiveFacts, hoursSummary);
const dataGaps = buildDataGaps(profileData, metrics, hours);
const telHref = formatPhoneHref(profileData.phone_number);

const pricingRows = [
  ['Exam', profileData.pricing_exam],
  ['Vaccine', profileData.pricing_vaccine],
  ['Rabies vaccine', profileData.pricing_rabies],
  ['Spay dog', profileData.pricing_spay_dog],
  ['Spay cat', profileData.pricing_spay_cat],
  ['Neuter dog', profileData.pricing_neuter_dog],
  ['Neuter cat', profileData.pricing_neuter_cat],
  ['Dental', profileData.pricing_dental],
  ['Blood panel', profileData.pricing_blood_panel],
  ['Fecal test', profileData.pricing_fecal],
  ['X-ray', profileData.pricing_xray],
  ['Microchip', profileData.pricing_microchip],
  ['Nail trim', profileData.pricing_nail_trim],
  ['Anal gland', profileData.pricing_anal_gland],
  ['Ear cleaning', profileData.pricing_ear_clean],
].filter(([, value]) => value);

const capabilityChips = [
  profileData.emergency_services && 'Emergency care',
  profileData.emergency_24_hour && '24/7',
  profileData.accepts_new_patients && 'Accepting new patients',
  profileData.walk_ins_welcome && 'Walk-ins welcome',
  profileData.appointment_required && 'Appointment required',
  profileData.online_booking && 'Online booking',
  profileData.telehealth_available && 'Telehealth',
  profileData.house_calls_available && 'House calls',
  profileData.mobile_vet_service && 'Mobile service',
  profileData.curbside_service && 'Curbside service',
  profileData.accepts_pet_insurance && 'Accepts insurance',
  asBool(profileData.payment_plans) && 'Payment plans',
  profileData.wheelchair_accessible && 'Wheelchair accessible',
  profileData.boarding_available && 'Boarding',
  profileData.grooming_available && 'Grooming',
  profileData.daycare_available && 'Daycare',
  profileData.training_available && 'Training',
  profileData.pharmacy_onsite && 'On-site pharmacy',
  profileData.lab_onsite && 'On-site lab',
  profileData.hospice_care && 'Hospice care',
  profileData.behavioral_services && 'Behavioral services',
  profileData.has_client_portal && 'Client portal',
].filter(Boolean);

const timelineItems = [
  checkedDateLabel ? { label: 'Page refreshed', value: checkedDateLabel } : null,
  sourceDateLabel ? { label: 'Source snapshot', value: sourceDateLabel } : null,
  refreshDateLabel ? { label: 'Next refresh window', value: refreshDateLabel } : null,
].filter(Boolean);

const vetscoreLabel = metrics.vetscore != null ? `${Math.round(metrics.vetscore)}/100` : 'Not scored';
const localRankLabel = vetscoreRow?.cityRank && vetscoreRow.cityTotal
  ? `#${vetscoreRow.cityRank} of ${vetscoreRow.cityTotal} nearby clinics`
  : null;
const serializedHours = JSON.stringify(hours || {});
const serviceSummary = services.length ? humanList(services.slice(0, 5), { limit: 5 }) : '';
const animalSummary = animals.length ? humanList(animals.map(formatAnimal), { limit: 5 }) : '';
const locationLine = `${profileData.city}, ${profileData.province}`;
const pageTitle = `${profileData.name} - Vet in ${profileData.city}, ${profileData.province}`;
const metaDescription = truncateText(
  `${profileData.name} vet in ${profileData.city}, ${profileData.province}. ` +
  `${profileData.address ? `${stripCountry(profileData.address)}. ` : ''}` +
  `${animalSummary ? `Animals treated: ${animalSummary}. ` : ''}` +
  `${capabilityChips.length ? `Access notes: ${capabilityChips.slice(0, 3).join(', ')}. ` : ''}`,
  160,
);
const canonical = `https://vetlist.org/${country}/${region}/${city}/${profile}/`;
const generatedProfileImage = getGeneratedOgImageUrl('profiles', [country, region, city, profile]);
const socialImage = generatedProfileImage || imageUrl || getDefaultOgImageUrl();
const openingHoursSpecification = buildOpeningHoursSpecification(hours);
const latitude = toNumber(profileData.latitude);
const longitude = toNumber(profileData.longitude);
const profileGeo = latitude != null && longitude != null
  ? {
      '@type': 'GeoCoordinates',
      latitude,
      longitude,
    }
  : undefined;
const openGraphConfig = {
  type: 'website',
  url: canonical,
  title: pageTitle,
  description: metaDescription,
  image: socialImage,
  imageAlt: `${profileData.name} veterinary profile image`,
};
const twitterCardConfig = {
  card: 'summary_large_image',
  title: pageTitle,
  description: metaDescription,
  image: socialImage,
  imageAlt: `${profileData.name} veterinary profile image`,
};
const claimClinicId = !missingProfile && profileData?.id != null ? String(profileData.id) : '';
const claimParams = new URLSearchParams();
if (claimClinicId) claimParams.set('clinic', claimClinicId);
const claimHref =
  claimParams.toString().length > 0
    ? `/claim-clinic/?${claimParams.toString()}`
    : '/claim-clinic/';
const isClaimedProfile = Boolean(profileData.claimed || profileData.is_verified);
const careNowHref = `/${country}/${region}/${city}/?need=open-now#care-now`;
const hasCostPolicyDetails = Boolean(
  profileData.price_range ||
  profileData.accepts_pet_insurance ||
  asBool(profileData.payment_plans) ||
  profileData.free_first_visit ||
  pricingRows.length > 0,
);

const priorityRelatedVets = [...relatedVets].sort((a, b) => {
  const score = (vet) =>
    (asBool(vet.emergency_24_hour) ? 100 : 0) +
    (asBool(vet.emergency_services) ? 70 : 0) +
    (asBool(vet.telehealth_available) ? 45 : 0) +
    (asBool(vet.online_booking) ? 25 : 0) +
    (asBool(vet.accepts_new_patients) ? 10 : 0) +
    (toNumber(vet.rating) || 0);
  return score(b) - score(a);
});
const priorityAlternativeCount = priorityRelatedVets.filter((vet) =>
  asBool(vet.emergency_24_hour) ||
  asBool(vet.emergency_services) ||
  asBool(vet.telehealth_available) ||
  asBool(vet.online_booking)
).length;

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: profileData.country || titleCase(country), href: `/${country}/` },
  { label: profileData.province || titleCase(region), href: `/${country}/${region}/` },
  { label: profileData.city || titleCase(city), href: `/${country}/${region}/${city}/` },
  { label: profileData.name, href: `/${country}/${region}/${city}/${profile}/` },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'VeterinaryCare',
    '@id': `${canonical}#veterinary-care`,
    name: profileData.name,
    mainEntityOfPage: canonical,
    url: canonical,
    image: socialImage,
    telephone: profileData.phone_number || undefined,
    email: profileData.email_address || undefined,
    description: factualSummary,
    dateModified: profileData.scraped_at || undefined,
    geo: profileGeo,
    hasMap: profileData.address ? mapLink(profileData.address) : undefined,
    openingHoursSpecification: openingHoursSpecification.length ? openingHoursSpecification : undefined,
    availableLanguage: languages.length ? languages : undefined,
    address: profileData.address
      ? {
          '@type': 'PostalAddress',
          streetAddress: profileData.address,
          addressLocality: profileData.city,
          addressRegion: profileData.province,
          addressCountry: profileData.country,
        }
      : undefined,
    areaServed: profileData.city ? `${profileData.city}, ${profileData.province}` : undefined,
    aggregateRating: profileData.rating
      ? {
          '@type': 'AggregateRating',
          ratingValue: Number(profileData.rating),
          bestRating: 5,
          worstRating: 1,
          ratingCount: Number(profileData.rating_count || profileData.review_count || 1),
          reviewCount: Number(profileData.review_count || profileData.rating_count || 1),
        }
      : undefined,
    sameAs: [
      ...(website ? [website] : []),
      ...socialLinks,
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbItems.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      item: new URL(item.href, 'https://vetlist.org').toString(),
    })),
  },
  ...(faqs.length
    ? [{
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqs.slice(0, 8).map((item) => ({
          '@type': 'Question',
          name: item.question,
          acceptedAnswer: {
            '@type': 'Answer',
            text: item.answer,
          },
        })),
      }]
    : []),
];
---

<Layout title={pageTitle} description={metaDescription} openGraph={openGraphConfig} twitterCard={twitterCardConfig} noindex={missingProfile}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <section class="mx-auto max-w-7xl pt-6">
    <Breadcrumbs items={breadcrumbItems} />

    <section class="mt-4 overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-card">
      <div class="grid gap-0 lg:grid-cols-[minmax(0,1.12fr)_minmax(360px,0.88fr)]">
        <div class="p-6 md:p-8 lg:p-10">
          <div class="flex flex-wrap items-center gap-2">
            {profileData.claimed && <span class="rounded-full border border-emerald-200 bg-emerald-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-emerald-700">Claimed</span>}
            {profileData.is_verified && <span class="rounded-full border border-blue-200 bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-blue-700">Verified</span>}
            {(profileData.emergency_services || profileData.emergency_24_hour) && <span class="rounded-full border border-rose-200 bg-rose-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-rose-700">Emergency info</span>}
            <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-1 text-xs font-semibold uppercase tracking-[0.16em] text-slate-600">
              {hours ? 'Open-now check' : 'Call for hours'}
            </span>
          </div>

          <p class="mt-6 text-sm font-semibold uppercase tracking-[0.16em] text-slate-500">Veterinarian in {locationLine}</p>
          <h1 class="mt-3 max-w-4xl text-4xl font-black leading-tight tracking-tight text-slate-950 md:text-6xl">
            {profileData.name}
          </h1>
          <p class="mt-5 max-w-4xl text-lg leading-8 text-slate-700">
            {factualSummary}
          </p>

          <div class="mt-7 flex flex-wrap items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 p-3">
            <div class="min-w-[13rem] flex-1 rounded-xl bg-white px-4 py-3">
              <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-500">Phone</p>
              <p class="mt-1 whitespace-nowrap text-base font-black tracking-tight text-slate-950">{profileData.phone_number || 'Not listed'}</p>
            </div>
            <div class="min-w-[10rem] flex-1 rounded-xl bg-white px-4 py-3">
              <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-500">Rating</p>
              <p class="mt-1 text-base font-black tracking-tight text-slate-950">
                {metrics.rating != null ? `${metrics.rating.toFixed(1)} / 5` : 'Not listed'}
              </p>
            </div>
            <div class="min-w-[12rem] flex-1 rounded-xl border border-cyan-100 bg-cyan-50 px-4 py-3">
              <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-cyan-700">VetScore</p>
              <p class="mt-1 text-base font-black tracking-tight text-slate-950">
                {vetscoreLabel}
                {localRankLabel && <span class="ml-2 text-sm font-semibold text-cyan-800">{localRankLabel}</span>}
              </p>
            </div>
            <div
              class="js-open-now open-now-card min-w-[12rem] flex-1 rounded-xl bg-white px-4 py-3"
              data-hours={serializedHours}
              data-emergency-24={profileData.emergency_24_hour ? 'true' : 'false'}
              data-compact="true"
            >
              <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-slate-500">Open now</p>
              <p class="mt-1 text-base font-black tracking-tight text-slate-950" data-open-status>{hours ? 'Checking...' : 'Call for hours'}</p>
              <p class="mt-1 text-xs font-semibold text-slate-500" data-open-detail>{hours ? 'Using your time' : 'Hours not listed'}</p>
            </div>
          </div>

          <div class="mt-7 flex flex-wrap gap-3">
            {telHref && <a href={telHref} class="rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800">Call</a>}
            {website && <a href={website} target="_blank" rel="noopener noreferrer" class="rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:border-slate-400">Website</a>}
            {profileData.address && <a href={mapLink(profileData.address)} target="_blank" rel="noopener noreferrer" class="rounded-full border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-900 transition hover:border-slate-400">Directions</a>}
            <a href={careNowHref} class="rounded-full border border-emerald-200 bg-emerald-50 px-5 py-3 text-sm font-semibold text-emerald-800 transition hover:bg-emerald-100">Find care now</a>
            {isClaimedProfile ? (
              <span class="rounded-full border border-emerald-200 bg-emerald-50 px-5 py-3 text-sm font-semibold text-emerald-800">Claimed listing</span>
            ) : (
              <a href={claimHref} class="rounded-full border border-cyan-200 bg-cyan-50 px-5 py-3 text-sm font-semibold text-cyan-800 transition hover:bg-cyan-100">Claim listing</a>
            )}
          </div>
        </div>

        <aside class="border-t border-slate-200 bg-slate-50 p-6 md:p-8 lg:border-l lg:border-t-0">
          <ProfileImage picture={profileData.picture} name={profileData.name} rating={profileData.rating} claimed={profileData.claimed || profileData.is_verified} class="h-72 w-full" />
          <div class="mt-5 space-y-3">
            <div class="rounded-2xl border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Address</p>
              <p class="mt-2 text-sm leading-6 text-slate-800">{profileData.address ? stripCountry(profileData.address) : 'Address not listed'}</p>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-4">
              <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Website</p>
              <p class="mt-2 break-all text-sm font-semibold text-slate-800">{website ? websiteLabel(website) : 'Website not listed'}</p>
            </div>
            {profileData.email_address && (
              <div class="rounded-2xl border border-slate-200 bg-white p-4">
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Email</p>
                <p class="mt-2 break-all text-sm font-semibold text-slate-800">{profileData.email_address}</p>
              </div>
            )}
          </div>
        </aside>
      </div>
    </section>

    <section class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,1fr)_380px]">
      <div class="space-y-6">
        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card md:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">What stands out</p>
          <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950">Useful differences nearby</h2>
          <p class="mt-3 max-w-3xl text-base leading-7 text-slate-600">
            A few details that may help you decide whether this clinic is worth calling first.
          </p>

          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {distinctiveFacts.length > 0 ? distinctiveFacts.map((fact) => (
              <article class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                <h3 class="text-lg font-bold text-slate-950">{fact.label}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-600">{fact.detail}</p>
              </article>
            )) : (
              <article class="rounded-2xl border border-slate-200 bg-slate-50 p-5 md:col-span-2">
                <h3 class="text-lg font-bold text-slate-950">Straightforward contact record</h3>
                <p class="mt-2 text-sm leading-6 text-slate-600">No unusual service or access detail stands out yet, so start with the phone, website, address, and hours.</p>
              </article>
            )}
          </div>
        </section>

        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card md:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Care focus</p>
          <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950">Animals, services, and access</h2>
          <div class="mt-6 grid gap-5 lg:grid-cols-2">
            <div>
              <h3 class="text-lg font-bold text-slate-950">Animals treated</h3>
              <div class="mt-3 flex flex-wrap gap-2">
                {animals.length > 0 ? animals.map((animal) => (
                  <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-medium text-slate-700">{formatAnimal(animal)}</span>
                )) : <span class="text-sm text-slate-500">Call to confirm which pets they treat.</span>}
              </div>
            </div>
            <div>
              <h3 class="text-lg font-bold text-slate-950">Services and specialties</h3>
              <div class="mt-3 flex flex-wrap gap-2">
                {services.length > 0 ? services.map((service) => (
                  <span class="rounded-full border border-slate-200 bg-slate-50 px-3 py-2 text-sm font-medium text-slate-700">{service}</span>
                )) : <span class="text-sm text-slate-500">Call to confirm services and specialties.</span>}
              </div>
            </div>
          </div>

          <div class="mt-7">
            <h3 class="text-lg font-bold text-slate-950">Access details</h3>
            <div class="mt-3 flex flex-wrap gap-2">
              {capabilityChips.length > 0 ? capabilityChips.map((chip) => (
                <span class="rounded-full border border-cyan-200 bg-cyan-50 px-3 py-2 text-sm font-medium text-cyan-800">{chip}</span>
              )) : <span class="text-sm text-slate-500">Call to confirm booking options, walk-ins, and accessibility.</span>}
            </div>
          </div>
        </section>

        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card md:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Hours and booking</p>
          <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950">Hours to check before visiting</h2>
          <p class="mt-3 text-base leading-7 text-slate-600">{hoursSummary.summary}</p>
          {hours ? (
            <div class="mt-5">
              <HoursTable
                data={hours}
                emergency24Hour={Boolean(profileData.emergency_24_hour)}
                emergencyServices={Boolean(profileData.emergency_services || profileData.emergency_24_hour)}
                telehealthAvailable={Boolean(profileData.telehealth_available)}
              />
            </div>
          ) : (
            <p class="mt-5 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 text-sm leading-6 text-slate-600">Call to confirm whether they can see your pet today.</p>
          )}
        </section>

        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card md:p-8">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Fit notes</p>
          <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950">When this clinic may be useful</h2>
          <div class="mt-6 grid gap-4 md:grid-cols-2">
            {bestFitRows.map((row) => (
              <article class="rounded-2xl border border-slate-200 bg-slate-50 p-5">
                <h3 class="text-lg font-bold text-slate-950">{row.label}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-600">{row.detail}</p>
              </article>
            ))}
          </div>
        </section>
      </div>

      <aside class="space-y-6">
        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Cost and policies</p>
          <h2 class="mt-2 text-2xl font-black tracking-tight text-slate-950">Cost details</h2>
          {hasCostPolicyDetails ? (
            <div class="mt-5 space-y-2">
              {profileData.price_range && (
                <div class="flex items-center justify-between rounded-2xl bg-slate-50 px-4 py-3 text-sm">
                  <span class="font-medium text-slate-700">Price range</span>
                  <span class="font-bold text-slate-950">{profileData.price_range}</span>
                </div>
              )}
              {profileData.accepts_pet_insurance && (
                <div class="flex items-center justify-between rounded-2xl bg-slate-50 px-4 py-3 text-sm">
                  <span class="font-medium text-slate-700">Pet insurance</span>
                  <span class="font-bold text-slate-950">Listed</span>
                </div>
              )}
              {asBool(profileData.payment_plans) && (
                <div class="flex items-center justify-between rounded-2xl bg-slate-50 px-4 py-3 text-sm">
                  <span class="font-medium text-slate-700">Payment plans</span>
                  <span class="font-bold text-slate-950">Listed</span>
                </div>
              )}
              {profileData.free_first_visit && (
                <div class="flex items-center justify-between rounded-2xl bg-slate-50 px-4 py-3 text-sm">
                  <span class="font-medium text-slate-700">Free first visit</span>
                  <span class="font-bold text-slate-950">Listed</span>
                </div>
              )}
            </div>
          ) : (
            <p class="mt-5 rounded-2xl border border-dashed border-slate-300 bg-slate-50 p-4 text-sm leading-6 text-slate-600">
              Call to confirm exam fees, insurance billing, and payment options.
            </p>
          )}
          {pricingRows.length > 0 && (
            <div class="mt-5 space-y-2">
              {pricingRows.map(([label, value]) => (
                <div class="flex items-center justify-between rounded-2xl border border-slate-200 px-4 py-3 text-sm">
                  <span class="font-medium text-slate-700">{label}</span>
                  <span class="font-bold text-slate-950">{value}</span>
                </div>
              ))}
            </div>
          )}
        </section>

        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">People and communication</p>
          <h2 class="mt-2 text-2xl font-black tracking-tight text-slate-950">Team details</h2>
          <div class="mt-5 space-y-4">
            <div>
              <p class="text-sm font-semibold text-slate-950">Languages</p>
              <p class="mt-1 text-sm leading-6 text-slate-600">{languages.length ? humanList(languages, { limit: 4 }) : 'Not listed'}</p>
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-950">Veterinarians named</p>
              <p class="mt-1 text-sm leading-6 text-slate-600">{veterinarianNames.length ? humanList(veterinarianNames, { limit: 3 }) : 'Not listed'}</p>
            </div>
            <div>
              <p class="text-sm font-semibold text-slate-950">Established</p>
              <p class="mt-1 text-sm leading-6 text-slate-600">{profileData.year_established || profileData.years_in_business || 'Not listed'}</p>
            </div>
            {profileData.parking_info && (
              <div>
                <p class="text-sm font-semibold text-slate-950">Parking</p>
                <p class="mt-1 text-sm leading-6 text-slate-600">{profileData.parking_info}</p>
              </div>
            )}
          </div>
        </section>

        <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
          <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Before calling</p>
          <h2 class="mt-2 text-2xl font-black tracking-tight text-slate-950">Details to confirm</h2>
          {dataGaps.length > 0 ? (
            <p class="mt-4 text-sm leading-7 text-slate-600">Ask about {humanList(dataGaps, { limit: 5 })} if those details matter for your visit.</p>
          ) : (
            <p class="mt-4 text-sm leading-7 text-slate-600">Core contact, location, care, and review details are available.</p>
          )}
          {timelineItems.length > 0 && (
            <div class="mt-5 grid gap-2">
              {timelineItems.map((item) => (
                <div class="flex items-center justify-between rounded-2xl bg-slate-50 px-4 py-3 text-sm">
                  <span class="font-medium text-slate-700">{item.label}</span>
                  <span class="font-bold text-slate-950">{item.value}</span>
                </div>
              ))}
            </div>
          )}
        </section>

        {nearbyCities?.length > 0 && (
          <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
            <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Browse nearby</p>
            <h2 class="mt-2 text-2xl font-black tracking-tight text-slate-950">Other city pages</h2>
            <div class="mt-5 flex flex-wrap gap-2">
              {nearbyCities.slice(0, 10).map((item) => (
                <a href={`/${country}/${region}/${item.city_slug}/`} class="rounded-full border border-slate-200 px-3 py-2 text-sm font-medium text-slate-700 transition hover:border-primary-500 hover:text-primary-700">
                  {item.city} ({item.count})
                </a>
              ))}
            </div>
          </section>
        )}

        {relatedVets.length > 0 && (
          <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-card">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">Alternatives</p>
                <h2 class="mt-2 text-2xl font-black tracking-tight text-slate-950">Backup options nearby</h2>
                <p class="mt-2 text-sm leading-6 text-slate-600">
                  {priorityAlternativeCount > 0
                    ? 'Showing clinics with 24/7 emergency, emergency support, telehealth, or online booking first.'
                    : 'Showing nearby clinics to compare if this one is not a fit.'}
                </p>
              </div>
              <a href={`/${country}/${region}/${city}/`} class="text-sm font-semibold text-primary-600 hover:text-primary-700">
                View all
              </a>
            </div>
            <div class="mt-5 grid gap-5">
              {priorityRelatedVets.slice(0, 4).map((vet) => <RelatedVet {...vet} />)}
            </div>
          </section>
        )}
      </aside>
    </section>
  </section>

</Layout>
