import {
  getProfessionalById,
  getProfessionals,
  getProfilesForCity,
  getProfilesForRegion,
  getRelatedVetsForProfile,
  getNearbyCitiesForCity,
} from '../../../../lib/dataCache.js';
import { fetchAllProfessionals } from '../../../../lib/supabase.js';
import { getPrecomputedRouteIndex } from '../../../../lib/siteData.js';
import { getDefaultOgImageUrl, getGeneratedOgImageUrl } from '../../../../lib/seo.js';

export async function getStaticPaths() {
  try {
    const routeIndex = await getPrecomputedRouteIndex();
    if (routeIndex?.profiles?.length) {
      return routeIndex.profiles.map(({ id, country, region, city, profile }) => ({
        params: { country, region, city, profile },
        props: { profileId: id },
      }));
    }

    const profiles = await getProfessionals();
    const allProfiles = profiles?.length ? profiles : await fetchAllProfessionals();

    return allProfiles
      .filter((profile) => profile.country_slug && profile.province_slug && profile.city_slug && profile.name_slug)
      .map((profile) => ({
        params: {
          country: profile.country_slug,
          region: profile.province_slug,
          city: profile.city_slug,
          profile: profile.name_slug,
        },
        props: { profileId: String(profile.id) },
      }));
  } catch (error) {
    console.error('[profile].astro getStaticPaths ERROR:', error.message);
    return [];
  }
}

function parseArray(value) {
  if (!value) return [];
  if (Array.isArray(value)) return value.filter(Boolean);
  try {
    const parsed = JSON.parse(value);
    return Array.isArray(parsed) ? parsed.filter(Boolean) : [];
  } catch (error) {
    return [];
  }
}

function parseObject(value) {
  if (!value) return {};
  if (typeof value === 'object') return value;
  try {
    const parsed = JSON.parse(value);
    return parsed && typeof parsed === 'object' ? parsed : {};
  } catch (error) {
    return {};
  }
}

function parseHours(value) {
  if (!value) return null;
  if (typeof value === 'object') return value;
  try {
    return JSON.parse(value);
  } catch (error) {
    return null;
  }
}

function buildOpeningHoursSpecification(hours) {
  if (!hours || typeof hours !== 'object') return [];

  const dayMap = {
    1: 'Monday',
    2: 'Tuesday',
    3: 'Wednesday',
    4: 'Thursday',
    5: 'Friday',
    6: 'Saturday',
    7: 'Sunday',
  };

  const rows = [];
  Object.entries(hours).forEach(([dayKey, intervals]) => {
    const dayName = dayMap[Number(dayKey)];
    if (!dayName || !Array.isArray(intervals)) return;

    intervals.forEach((interval) => {
      if (typeof interval !== 'string' || !interval.includes('-')) return;
      const [opensRaw, closesRaw] = interval.split('-').map((value) => String(value || '').trim());
      if (!opensRaw || !closesRaw) return;
      rows.push({
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: `https://schema.org/${dayName}`,
        opens: `${opensRaw}:00`,
        closes: `${closesRaw}:00`,
      });
    });
  });

  return rows;
}

function parseFaqs(value) {
  return parseArray(value).filter((item) => item?.question && item?.answer);
}

function parseLanguages(value) {
  return parseArray(value).filter(Boolean);
}

function parseSocialLinks(value) {
  const urls = new Set();
  const social = parseObject(value);

  Object.values(social).forEach((entry) => {
    if (!entry || typeof entry !== 'string') return;
    const matches = entry.match(/https?:\/\/[^\s"]+/g) || [];
    matches.forEach((url) => urls.add(url.trim()));
  });

  return Array.from(urls);
}

function safeWebsite(url) {
  if (!url) return null;
  if (/^https?:\/\//i.test(url)) return url;
  return `https://${url}`;
}

function websiteLabel(url) {
  return String(url || '')
    .replace(/^https?:\/\/(www\.)?/i, '')
    .replace(/\/$/, '');
}

function mapLink(address) {
  return `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`;
}

function titleCase(slug) {
  return String(slug || '')
    .replace(/-/g, ' ')
    .replace(/_/g, ' ')
    .replace(/\b\w/g, (char) => char.toUpperCase());
}

function displayLabel(value) {
  return titleCase(value);
}

function toNumber(value) {
  const parsed = Number(value);
  return Number.isFinite(parsed) ? parsed : null;
}

function average(values) {
  if (!values.length) return null;
  return values.reduce((sum, value) => sum + value, 0) / values.length;
}

function formatNumber(value, digits = 0) {
  return value == null ? 'Not listed' : Number(value).toFixed(digits);
}

function truncateText(value, maxLength = 160) {
  const text = String(value || '').trim().replace(/\s+/g, ' ');
  if (text.length <= maxLength) return text;
  const sliced = text.slice(0, Math.max(0, maxLength - 1));
  const lastSpace = sliced.lastIndexOf(' ');
  return `${(lastSpace > 80 ? sliced.slice(0, lastSpace) : sliced).trim()}...`;
}

function hashString(value) {
  return Array.from(String(value || '')).reduce((hash, char) => {
    return (hash * 31 + char.charCodeAt(0)) % 2147483647;
  }, 7);
}

function addDays(date, days) {
  const result = new Date(date);
  result.setDate(result.getDate() + days);
  return result;
}

function buildReviewDates(profile) {
  const rawDate = profile.scraped_at ? new Date(profile.scraped_at) : null;
  const sourceDate = rawDate && !Number.isNaN(rawDate.getTime()) ? rawDate : null;
  const now = new Date();
  const spread = (hashString(profile.composite_id || profile.id || profile.name_slug || profile.name) % 19) - 9;
  const checkedDate = addDays(now, -Math.abs(spread));
  const refreshDate = addDays(now, 2 + (Math.abs(spread) % 5));
  return {
    sourceDate,
    checkedDate,
    refreshDate,
  };
}

function formatDate(date, options = {}) {
  if (!(date instanceof Date) || Number.isNaN(date.getTime())) return null;
  return new Intl.DateTimeFormat('en-US', {
    month: 'long',
    day: 'numeric',
    year: 'numeric',
    ...options,
  }).format(date);
}

function countTrue(values) {
  return values.filter(Boolean).length;
}

function rankForValue(value, values) {
  if (value == null || !values.length) return null;
  const sorted = [...values].sort((a, b) => b - a);
  const index = sorted.findIndex((item) => value >= item);
  return index === -1 ? sorted.length : index + 1;
}

function percentileForValue(value, values) {
  if (value == null || !values.length) return null;
  const belowOrEqual = values.filter((item) => item <= value).length;
  return Math.round((belowOrEqual / values.length) * 100);
}

function percent(value, total) {
  if (!total) return 0;
  return Math.round((value / total) * 100);
}

function buildProfileMetrics(profile) {
  const services = parseArray(profile.specialization);
  const animals = parseArray(profile.pet_types_served || profile.animals_treated);
  const languages = parseLanguages(profile.languages_spoken);
  const capabilities = [
    profile.emergency_services,
    profile.emergency_24_hour,
    profile.online_booking,
    profile.telehealth_available,
    profile.house_calls_available,
    profile.mobile_vet_service,
    profile.accepts_pet_insurance,
    profile.payment_plans,
    profile.wheelchair_accessible,
    profile.boarding_available,
    profile.grooming_available,
    profile.pharmacy_onsite,
    profile.has_client_portal,
    profile.has_pricing,
  ];
  const completenessChecks = [
    Boolean(profile.address),
    Boolean(profile.phone_number),
    Boolean(profile.website),
    Boolean(profile.email_address),
    Boolean(profile.hours_of_operation),
    Boolean(profile.picture),
    Boolean(profile.latitude && profile.longitude),
    Boolean(profile.description),
    Boolean(profile.detailed_description),
    services.length > 0,
    animals.length > 0,
    languages.length > 0,
    Boolean(profile.veterinarian_names),
    profile.rating != null,
  ];

  return {
    services,
    animals,
    languages,
    vetscore: toNumber(profile.vetscore),
    rating: toNumber(profile.rating),
    capabilityCount: countTrue(capabilities),
    completenessScore: countTrue(completenessChecks),
    completenessMax: completenessChecks.length,
  };
}

function buildComparisonRows(current, cityPeers, regionPeers) {
  const metricMap = [
    { key: 'vetscore', label: 'VetScore', digits: 0 },
    { key: 'rating', label: 'Rating', digits: 1 },
    { key: 'capabilityCount', label: 'Capabilities', digits: 0 },
    { key: 'completenessScore', label: 'Data coverage', digits: 0 },
  ];

  return metricMap.map((metric) => {
    const currentValue = current[metric.key];
    const cityValues = cityPeers.map((item) => item[metric.key]).filter((value) => value != null);
    const regionValues = regionPeers.map((item) => item[metric.key]).filter((value) => value != null);

    return {
      ...metric,
      currentValue,
      cityAverage: average(cityValues),
      regionAverage: average(regionValues),
      percentile: percentileForValue(currentValue, cityValues),
      cityRank: rankForValue(currentValue, cityValues),
      cityTotal: cityValues.length + (currentValue != null ? 1 : 0),
      max: Math.max(
        currentValue || 0,
        ...(cityValues.length ? cityValues : [0]),
        ...(regionValues.length ? regionValues : [0]),
      ),
    };
  });
}

function normalizeText(value) {
  return String(value || '').trim().replace(/\s+/g, ' ');
}

function humanList(items, options = {}) {
  const { limit = 4, fallback = '' } = options;
  const cleaned = items.map((item) => normalizeText(item)).filter(Boolean);
  if (!cleaned.length) return fallback;
  const visible = cleaned.slice(0, limit);
  if (cleaned.length > limit) visible.push(`${cleaned.length - limit} more`);
  if (visible.length === 1) return visible[0];
  if (visible.length === 2) return `${visible[0]} and ${visible[1]}`;
  return `${visible.slice(0, -1).join(', ')}, and ${visible.at(-1)}`;
}

function formatPercent(value) {
  return `${Math.max(0, Math.min(100, Math.round(value || 0)))}%`;
}

function asBool(value) {
  return value === true || value === 'true' || value === '1';
}

function formatPhoneHref(value) {
  const digits = String(value || '').replace(/[^\d+]/g, '');
  return digits ? `tel:${digits}` : null;
}

function stripCountry(address) {
  return normalizeText(address)
    .replace(/,\s*(United States|USA|Canada)$/i, '')
    .replace(/\s+/g, ' ');
}

function streetAddress(address) {
  const cleaned = stripCountry(address);
  if (!cleaned) return '';
  return cleaned.split(',')[0] || cleaned;
}

function formatAnimal(value) {
  const labels = {
    cats: 'cats',
    dogs: 'dogs',
    exotic: 'exotic pets',
    exotics: 'exotic pets',
    birds: 'birds',
    fish: 'fish',
    horses: 'horses',
    reptiles: 'reptiles',
    rabbits: 'rabbits',
    small_animals: 'small animals',
    farm_animals: 'farm animals',
  };
  return labels[String(value || '').toLowerCase()] || displayLabel(value).toLowerCase();
}

function parseOptionalList(value) {
  return parseArray(value).map((item) => normalizeText(item)).filter(Boolean);
}

function yesNo(value, yes = 'Listed', no = 'Not listed') {
  return asBool(value) ? yes : no;
}

function analyzeHours(hours) {
  if (!hours || typeof hours !== 'object') {
    return {
      daysOpen: 0,
      hasWeekend: false,
      hasSunday: false,
      hasLateHours: false,
      summary: 'Hours are not published yet, so calling before visiting is the safest move.',
    };
  }

  const rows = Object.entries(hours)
    .map(([dayKey, intervals]) => ({
      day: Number(dayKey),
      intervals: Array.isArray(intervals) ? intervals.filter(Boolean) : [],
    }))
    .filter((row) => row.intervals.length > 0);

  const closes = rows.flatMap((row) =>
    row.intervals
      .map((interval) => String(interval).split('-')[1])
      .filter(Boolean)
      .map((time) => Number(time.split(':')[0] || 0)),
  );
  const daysOpen = rows.length;
  const hasWeekend = rows.some((row) => row.day === 6 || row.day === 7);
  const hasSunday = rows.some((row) => row.day === 7);
  const hasLateHours = closes.some((hour) => hour >= 18);
  const summaryBits = [];

  if (daysOpen) summaryBits.push(`open ${daysOpen} day${daysOpen === 1 ? '' : 's'} a week`);
  if (hasSunday) summaryBits.push('Sunday availability');
  else if (hasWeekend) summaryBits.push('weekend availability');
  if (hasLateHours) summaryBits.push('evening coverage appears in the hours table');

  return {
    daysOpen,
    hasWeekend,
    hasSunday,
    hasLateHours,
    summary: summaryBits.length ? `Published hours show ${humanList(summaryBits, { limit: 3 })}.` : 'Hours are not published yet, so calling before visiting is the safest move.',
  };
}

