---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { getProfessionals, getProfilesForRegion } from '../../../lib/dataCache.js';
import { fetchAllProfessionals } from '../../../lib/supabase';
import { getPrecomputedRouteIndex } from '../../../lib/siteData.js';
import { getDefaultOgImageUrl, getGeneratedOgImageUrl, pickFirstProfileImage } from '../../../lib/seo.js';

function toTitleCase(str) {
  return str
    .replace(/-/g, ' ')
    .split(' ')
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

function parsePrice(value) {
  if (!value) return null;
  const match = String(value).match(/\$(\d+)/);
  return match ? Number(match[1]) : null;
}

function average(numbers) {
  return numbers.length ? Math.round(numbers.reduce((sum, value) => sum + value, 0) / numbers.length) : null;
}

function avgRating(profiles) {
  const ratings = profiles
    .map((profile) => Number.parseFloat(profile.rating))
    .filter((value) => Number.isFinite(value));
  return ratings.length ? (ratings.reduce((sum, value) => sum + value, 0) / ratings.length).toFixed(1) : null;
}

function isTrue(value) {
  return value === true || value === 'true' || value === 1 || value === '1';
}

export async function getStaticPaths() {
  try {
    const routeIndex = await getPrecomputedRouteIndex();
    if (routeIndex?.regions?.length) {
      return routeIndex.regions.map(({ country, region }) => ({ params: { country, region } }));
    }

    const profiles = await getProfessionals();
    const allProfiles = profiles?.length ? profiles : await fetchAllProfessionals();

    return [...new Set(
      allProfiles
        .filter((profile) => profile.country_slug && profile.province_slug)
        .map((profile) => `${profile.country_slug}/${profile.province_slug}`)
    )].map((key) => {
      const [country, region] = key.split('/');
      return { params: { country, region } };
    });
  } catch (error) {
    console.error('Error in region getStaticPaths:', error);
    return [];
  }
}

const { country, region } = Astro.params;

let profiles = await getProfilesForRegion(country, region);

if (!profiles?.length) {
  try {
    const allProfiles = await getProfessionals();
    profiles = allProfiles.filter((profile) => profile.country_slug === country && profile.province_slug === region);
  } catch (error) {
    profiles = [];
  }
}

const regionName = profiles[0]?.province || toTitleCase(region);
const countryName = profiles[0]?.country || toTitleCase(country);
const totalClinics = profiles.length;

const cityStats = {};
profiles.forEach((profile) => {
  if (!profile.city || !profile.city_slug) return;
  const key = profile.city_slug;
  if (!cityStats[key]) {
    cityStats[key] = {
      name: profile.city,
      slug: profile.city_slug,
      count: 0,
      emergency: 0,
      onlineBooking: 0,
      telehealth: 0,
      pricing: 0,
      ratings: [],
    };
  }
  cityStats[key].count += 1;
  if (isTrue(profile.emergency_services) || isTrue(profile.emergency_24_hour)) cityStats[key].emergency += 1;
  if (isTrue(profile.online_booking)) cityStats[key].onlineBooking += 1;
  if (isTrue(profile.telehealth_available)) cityStats[key].telehealth += 1;
  if (isTrue(profile.has_pricing)) cityStats[key].pricing += 1;

  const rating = Number.parseFloat(profile.rating);
  if (Number.isFinite(rating) && rating > 0 && rating <= 5) cityStats[key].ratings.push(rating);
});

const topCities = Object.values(cityStats)
  .map((city) => ({
    ...city,
    avgRating: city.ratings.length ? (city.ratings.reduce((sum, value) => sum + value, 0) / city.ratings.length).toFixed(1) : null,
  }))
  .sort((a, b) => b.count - a.count);
const totalCities = topCities.length;

const withEmergency = profiles.filter((profile) => isTrue(profile.emergency_services) || isTrue(profile.emergency_24_hour)).length;
const withOnlineBooking = profiles.filter((profile) => isTrue(profile.online_booking)).length;
const withTelehealth = profiles.filter((profile) => isTrue(profile.telehealth_available)).length;
const withPricing = profiles.filter((profile) => isTrue(profile.has_pricing)).length;
const withInsurance = profiles.filter((profile) => isTrue(profile.accepts_pet_insurance)).length;
const withWheelchair = profiles.filter((profile) => isTrue(profile.wheelchair_accessible)).length;
const withClaimed = profiles.filter((profile) => isTrue(profile.claimed)).length;
const withLanguages = profiles.filter((profile) => {
  if (!profile.languages_spoken || profile.languages_spoken === '[]') return false;
  try {
    const parsed = typeof profile.languages_spoken === 'string' ? JSON.parse(profile.languages_spoken) : profile.languages_spoken;
    return Array.isArray(parsed) && parsed.some((language) => String(language).toLowerCase() !== 'english');
  } catch {
    return false;
  }
}).length;

const allLanguages = new Set();
profiles.forEach((profile) => {
  if (!profile.languages_spoken || profile.languages_spoken === '[]') return;
  try {
    const parsed = typeof profile.languages_spoken === 'string' ? JSON.parse(profile.languages_spoken) : profile.languages_spoken;
    if (Array.isArray(parsed)) {
      parsed
        .filter((language) => String(language).toLowerCase() !== 'english')
        .forEach((language) => allLanguages.add(language));
    }
  } catch {}
});

const examPrices = profiles.map((profile) => parsePrice(profile.pricing_exam)).filter(Boolean);
const vaccinePrices = profiles.map((profile) => parsePrice(profile.pricing_vaccine)).filter(Boolean);
const dentalPrices = profiles.map((profile) => parsePrice(profile.pricing_dental)).filter(Boolean);
const spayPrices = profiles.map((profile) => parsePrice(profile.pricing_spay_dog)).filter(Boolean);

const highestRatedCity = topCities
  .filter((entry) => entry.avgRating)
  .sort((a, b) => Number.parseFloat(b.avgRating) - Number.parseFloat(a.avgRating))[0] || null;
const topEmergencyCity = topCities.filter((entry) => entry.emergency > 0).sort((a, b) => b.emergency - a.emergency)[0] || null;
const topDigitalCity = topCities
  .map((entry) => ({ ...entry, digitalAccess: entry.onlineBooking + entry.telehealth }))
  .filter((entry) => entry.digitalAccess > 0)
  .sort((a, b) => b.digitalAccess - a.digitalAccess)[0] || null;
const regionAvgRating = avgRating(profiles);

const regionOverviewParts = [
  `Compare ${totalClinics.toLocaleString()} vet clinics and animal hospitals across ${totalCities.toLocaleString()} cities in ${regionName}.`,
  withEmergency > 0 ? `${withEmergency.toLocaleString()} list emergency or 24/7 care.` : '',
  withOnlineBooking > 0 ? `${withOnlineBooking.toLocaleString()} list online booking.` : '',
  withTelehealth > 0 ? `${withTelehealth.toLocaleString()} list telehealth.` : '',
  withPricing > 0 ? `${withPricing.toLocaleString()} include pricing details.` : '',
].filter(Boolean);
const regionOverview = `${regionOverviewParts.join(' ')} Use the city cards to compare local clinic counts, access signals, ratings, and pricing before choosing where to look next.`;

const generatedRegionImage = getGeneratedOgImageUrl('regions', [country, region]);
const socialImage = generatedRegionImage || pickFirstProfileImage(profiles) || getDefaultOgImageUrl();
const pageTitle = `Veterinary Services in ${regionName}, ${countryName} | ${totalClinics.toLocaleString()} Vet Clinics`;
const pageDescription = `Compare ${totalClinics.toLocaleString()} vet clinics and animal hospitals across ${totalCities} cities in ${regionName}, with hours, phone numbers, emergency care, services, and pricing details.`;
const canonicalURL = `https://vetlist.org/${country}/${region}/`;
const regionIntentKeywords = [
  `veterinary services ${regionName}`,
  `veterinary hospital ${regionName}`,
  `vet clinic ${regionName}`,
  `animal hospital ${regionName}`,
  `veterinarian ${regionName}`,
];
const openGraphConfig = {
  type: 'website',
  url: canonicalURL,
  title: pageTitle,
  description: pageDescription,
  siteName: 'VetList.org',
  locale: 'en_US',
  image: socialImage,
  imageAlt: `Veterinary services directory for ${regionName}, ${countryName}`,
};
const twitterCardConfig = {
  card: 'summary_large_image',
  title: pageTitle,
  description: pageDescription,
  image: socialImage,
  imageAlt: `Veterinary services directory for ${regionName}, ${countryName}`,
};

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: countryName, href: `/${country}/` },
  { label: regionName, href: `/${country}/${region}/` },
];
---

<Layout title={pageTitle} description={pageDescription} openGraph={openGraphConfig} twitterCard={twitterCardConfig}>
  <script type="application/ld+json" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `Veterinarians in ${regionName}`,
    description: pageDescription,
    url: canonicalURL,
    image: socialImage,
    about: regionIntentKeywords,
    mainEntity: {
      '@type': 'ItemList',
      name: `Veterinary Clinics in ${regionName}`,
      numberOfItems: totalClinics,
      itemListOrder: 'https://schema.org/ItemListOrderDescending',
      itemListElement: topCities.slice(0, 12).map((city, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        item: {
          '@type': 'WebPage',
          name: `Veterinarians in ${city.name}`,
          url: `https://vetlist.org/${country}/${region}/${city.slug}/`,
          description: `${city.count} veterinary clinics in ${city.name}, ${regionName}`,
        },
      })),
    },
    breadcrumb: {
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbItems.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.label,
        item: `https://vetlist.org${item.href}`,
      })),
    },
  })} />

  <Fragment slot="head">
    <meta property="business:contact_data:region" content={regionName} />
    <meta property="business:contact_data:country_name" content={countryName} />
  </Fragment>

  <div class="mx-auto max-w-7xl py-6 md:py-8">
    <Breadcrumbs items={breadcrumbItems} />

    <section class="mt-4 overflow-hidden rounded-[32px] border border-slate-200 bg-slate-950 text-white shadow-2xl">
      <div class="bg-[radial-gradient(circle_at_top_left,_rgba(56,189,248,0.26),_transparent_26%),radial-gradient(circle_at_bottom_right,_rgba(251,191,36,0.16),_transparent_24%)] px-5 py-6 md:px-8 md:py-8">
        <div class="flex flex-col gap-6 xl:flex-row xl:items-stretch xl:justify-between">
          <div class="max-w-4xl">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-200">Region directory</p>
            <h1 class="mt-3 text-4xl font-black tracking-tight text-white md:text-5xl">Veterinary services in {regionName}</h1>
            <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-200">
              Compare vet clinics across {totalCities.toLocaleString()} cities in {regionName}, with hours, phone numbers, emergency care, services, and clinic profiles.
            </p>
            <div class="mt-5 flex flex-wrap gap-2">
              <span class="rounded-full border border-white/10 bg-white/10 px-4 py-2 text-sm text-slate-100">{totalClinics.toLocaleString()} clinics</span>
              <span class="rounded-full border border-white/10 bg-white/10 px-4 py-2 text-sm text-slate-100">{totalCities.toLocaleString()} cities</span>
              {withEmergency > 0 && <span class="rounded-full border border-red-400/20 bg-red-400/10 px-4 py-2 text-sm text-red-100">{withEmergency.toLocaleString()} emergency listings</span>}
              {withOnlineBooking > 0 && <span class="rounded-full border border-cyan-300/20 bg-cyan-300/10 px-4 py-2 text-sm text-cyan-100">{withOnlineBooking.toLocaleString()} with online booking</span>}
            </div>
          </div>

          <div class="grid grid-cols-2 gap-3 xl:w-[320px] xl:h-full xl:min-h-[260px] xl:grid-rows-2">
            <div class="flex h-full flex-col rounded-3xl border border-white/10 bg-white/5 p-4 backdrop-blur">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">Emergency</p>
              <p class="mt-auto text-5xl font-black leading-[0.9] text-red-300 drop-shadow-[0_10px_28px_rgba(252,165,165,0.24)] sm:text-6xl">{withEmergency.toLocaleString()}</p>
              <p class="mt-2 text-sm text-slate-300">clinics list urgent care</p>
            </div>
            <div class="flex h-full flex-col rounded-3xl border border-white/10 bg-white/5 p-4 backdrop-blur">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">Cities</p>
              <p class="mt-auto text-5xl font-black leading-[0.9] text-emerald-300 drop-shadow-[0_10px_28px_rgba(110,231,183,0.23)] sm:text-6xl">{totalCities.toLocaleString()}</p>
              <p class="mt-2 text-sm text-slate-300">city pages covered</p>
            </div>
            <div class="flex h-full flex-col rounded-3xl border border-white/10 bg-white/5 p-4 backdrop-blur">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">Book online</p>
              <p class="mt-auto text-5xl font-black leading-[0.9] text-cyan-300 drop-shadow-[0_10px_28px_rgba(103,232,249,0.25)] sm:text-6xl">{withOnlineBooking.toLocaleString()}</p>
              <p class="mt-2 text-sm text-slate-300">clinics list booking</p>
            </div>
            <div class="flex h-full flex-col rounded-3xl border border-white/10 bg-white/5 p-4 backdrop-blur">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">Avg rating</p>
              <p class="mt-auto text-5xl font-black leading-[0.9] text-amber-300 drop-shadow-[0_10px_28px_rgba(252,211,77,0.24)] sm:text-6xl">{regionAvgRating || 'NA'}</p>
              <p class="mt-2 text-sm text-slate-300">public rating</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-8 grid gap-4 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Region snapshot</p>
        <div class="mt-4 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          <div><p class="text-sm text-slate-500">Emergency</p><p class="mt-1 text-3xl font-black text-slate-950">{withEmergency.toLocaleString()}</p><p class="text-sm text-slate-600">clinics listing urgent access</p></div>
          <div><p class="text-sm text-slate-500">Online booking</p><p class="mt-1 text-3xl font-black text-slate-950">{withOnlineBooking.toLocaleString()}</p><p class="text-sm text-slate-600">with self-serve booking</p></div>
          <div><p class="text-sm text-slate-500">Telehealth</p><p class="mt-1 text-3xl font-black text-slate-950">{withTelehealth.toLocaleString()}</p><p class="text-sm text-slate-600">with remote care listed</p></div>
          <div><p class="text-sm text-slate-500">Transparent pricing</p><p class="mt-1 text-3xl font-black text-slate-950">{withPricing.toLocaleString()}</p><p class="text-sm text-slate-600">with pricing listed</p></div>
          <div><p class="text-sm text-slate-500">Insurance</p><p class="mt-1 text-3xl font-black text-slate-950">{withInsurance.toLocaleString()}</p><p class="text-sm text-slate-600">clinics accepting pet insurance</p></div>
          <div><p class="text-sm text-slate-500">Claimed</p><p class="mt-1 text-3xl font-black text-slate-950">{withClaimed}</p><p class="text-sm text-slate-600">clinic-managed profiles</p></div>
        </div>
      </div>

      <div class="rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">What stands out</p>
        <div class="mt-4 space-y-4 text-sm text-slate-600">
          {highestRatedCity && <p><span class="font-semibold text-slate-950">{highestRatedCity.name}</span> has the strongest average rating at {highestRatedCity.avgRating}/5.</p>}
          {topEmergencyCity && <p><span class="font-semibold text-slate-950">{topEmergencyCity.name}</span> has the most clinics listing emergency or 24/7 care, with {topEmergencyCity.emergency} options.</p>}
          {topDigitalCity && <p><span class="font-semibold text-slate-950">{topDigitalCity.name}</span> has {topDigitalCity.digitalAccess} clinics listing online booking or telehealth.</p>}
          <p>{withLanguages} clinics list non-English language support across {allLanguages.size} languages.</p>
          {examPrices.length > 0 && <p>Published exam pricing averages <span class="font-semibold text-slate-950">${average(examPrices)}</span> across clinics with pricing listed.</p>}
          {withWheelchair > 0 && <p>{withWheelchair} clinics list wheelchair-accessible facilities.</p>}
        </div>
      </div>
    </section>

    {(examPrices.length || vaccinePrices.length || dentalPrices.length || spayPrices.length || allLanguages.size > 0) && (
      <section class="mt-8 grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Pricing context</p>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {examPrices.length > 0 && <div class="rounded-2xl bg-slate-50 p-4"><div class="text-sm text-slate-500">Exam</div><div class="mt-1 text-2xl font-black text-slate-950">${average(examPrices)}</div></div>}
            {vaccinePrices.length > 0 && <div class="rounded-2xl bg-slate-50 p-4"><div class="text-sm text-slate-500">Vaccine</div><div class="mt-1 text-2xl font-black text-slate-950">${average(vaccinePrices)}</div></div>}
            {dentalPrices.length > 0 && <div class="rounded-2xl bg-slate-50 p-4"><div class="text-sm text-slate-500">Dental</div><div class="mt-1 text-2xl font-black text-slate-950">${average(dentalPrices)}</div></div>}
            {spayPrices.length > 0 && <div class="rounded-2xl bg-slate-50 p-4"><div class="text-sm text-slate-500">Spay</div><div class="mt-1 text-2xl font-black text-slate-950">${average(spayPrices)}</div></div>}
          </div>
        </div>

        <div class="rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Published languages</p>
          <div class="mt-4 flex flex-wrap gap-3">
            {withWheelchair > 0 && <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-700">{withWheelchair} wheelchair accessible</span>}
            {withLanguages > 0 && <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-700">{withLanguages} multilingual profiles</span>}
            {[...allLanguages].slice(0, 12).map((language) => (
              <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-700">{language}</span>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="mt-8">
      <div class="mb-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Browse cities</p>
        <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950">Cities in {regionName}</h2>
      </div>
      <div id="cities-grid" class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {topCities.map((city) => {
          return (
            <a
              href={`/${country}/${region}/${city.slug}/`}
              class="city-card group rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)] transition-all duration-200 hover:-translate-y-0.5 hover:border-cyan-300/70 hover:shadow-[0_24px_60px_rgba(15,23,42,0.12)]"
              data-city-name={city.name.toLowerCase()}
            >
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">City</p>
                  <h3 class="mt-2 text-2xl font-black tracking-tight text-slate-950 transition group-hover:text-cyan-700">{city.name}</h3>
                </div>
                <span class="rounded-full bg-slate-950 px-3 py-1 text-sm font-semibold text-white">{city.count}</span>
              </div>
              <div class="mt-4 flex flex-wrap gap-2 text-sm text-slate-600">
                {city.emergency > 0 && <span class="rounded-full bg-red-50 px-3 py-1 text-red-700">{city.emergency} emergency</span>}
                {city.onlineBooking > 0 && <span class="rounded-full bg-cyan-50 px-3 py-1 text-cyan-700">{city.onlineBooking} book online</span>}
                {city.telehealth > 0 && <span class="rounded-full bg-purple-50 px-3 py-1 text-purple-700">{city.telehealth} telehealth</span>}
                {city.avgRating && <span class="rounded-full bg-amber-50 px-3 py-1 text-amber-800">{city.avgRating} / 5 avg</span>}
              </div>
              <div class="mt-5 flex items-center justify-between text-sm text-slate-600">
                <span>Open city page</span>
                <span class="font-semibold text-cyan-700 transition group-hover:translate-x-1">View</span>
              </div>
            </a>
          );
        })}
      </div>
    </section>

    <section class="mt-8 grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">About this region</p>
        <div class="mt-4 space-y-3 text-sm leading-7 text-slate-600">
          <p>{regionOverview}</p>
          <p>
            In {regionName}, <span class="font-semibold text-slate-950">{withEmergency.toLocaleString()}</span> clinics list emergency care,
            <span class="font-semibold text-slate-950"> {withOnlineBooking.toLocaleString()}</span> list online booking,
            <span class="font-semibold text-slate-950"> {withTelehealth.toLocaleString()}</span> list telehealth, and
            <span class="font-semibold text-slate-950"> {withPricing.toLocaleString()}</span> include pricing details.
          </p>
        </div>
      </div>

      <div class="rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Useful starting points</p>
        <div class="mt-4 flex flex-wrap gap-3">
          {topEmergencyCity && <a href={`/${country}/${region}/${topEmergencyCity.slug}/`} class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100">Emergency: {topEmergencyCity.name}</a>}
          {topDigitalCity && <a href={`/${country}/${region}/${topDigitalCity.slug}/`} class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100">Booking or telehealth: {topDigitalCity.name}</a>}
          {highestRatedCity && <a href={`/${country}/${region}/${highestRatedCity.slug}/`} class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100">Highest rating: {highestRatedCity.name}</a>}
          <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-700">{totalClinics.toLocaleString()} clinic profiles</span>
        </div>
      </div>
    </section>
  </div>
</Layout>
