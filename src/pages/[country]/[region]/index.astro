---
import Layout from '../../../layouts/Layout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { getProfessionals, getProfilesForRegion } from '../../../lib/dataCache.js';
// Keep the direct import as fallback
import { fetchAllProfessionals } from '../../../lib/supabase';

// Convert slug to title case
function toTitleCase(str) {
  return str
    .replace(/-/g, ' ')
    .split(' ')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

export async function getStaticPaths() {
  try {
    // Try to get from cache first
    const profiles = await getProfessionals();
    console.log(`[region].astro getStaticPaths: Received ${profiles?.length || 0} profiles from cache.`);
    
    // If cache failed or is empty, fall back to direct fetch
    const allProfiles = profiles?.length ? profiles : await fetchAllProfessionals();
    
    // Filter out profiles with missing or empty slugs
    const validProfiles = allProfiles.filter(profile => 
      profile.country_slug && 
      profile.province_slug && 
      profile.country_slug.trim() !== '' && 
      profile.province_slug.trim() !== ''
    );
    
    console.log(`[region].astro getStaticPaths: ${validProfiles.length} valid profiles after filtering`);
    
    const regions = new Map();
    validProfiles.forEach(profile => {
      const country = profile.country_slug;
      const region = profile.province_slug;
      const key = `${country}/${region}`;
      if (!regions.has(key)) {
        regions.set(key, { country, region });
      }
    });
    
    const paths = Array.from(regions.values()).map(({ country, region }) => ({
      params: { country, region }
    }));
    
    console.log(`[region].astro getStaticPaths: Generated ${paths.length} region paths`);
    return paths;
  } catch (error) {
    console.error("[region].astro getStaticPaths ERROR:", error.message);
    return [];
  }
}

const { region, country } = Astro.params;

// Attempt to use the cached data first
let profiles: any[] = [];

// Get profiles for this region from cache
profiles = await getProfilesForRegion(country, region);

// If no profiles found in cache, fetch all profiles and filter
if (!profiles || profiles.length === 0) {
  console.log(`[region].astro: No profiles found in cache for ${country}/${region}, trying direct fetch...`);
  try {
    const allProfiles = await getProfessionals();
    profiles = allProfiles.filter(p => 
      p.country_slug === country && 
      p.province_slug === region
    );
  } catch (e) {
    console.error(`[region].astro: Error fetching profiles from cache:`, e.message);
    
    // Try direct fetch as last resort
    try {
      const allProfiles = await fetchAllProfessionals();
      profiles = allProfiles.filter(p => 
        p.country_slug === country && 
        p.province_slug === region
      );
    } catch (directFetchError) {
      console.error(`[region].astro: Direct fetch also failed:`, directFetchError.message);
      profiles = [];
    }
  }
}

console.log(`[region].astro: Fetched ${profiles.length} profiles for ${country}/${region}`);

// Aggregate cities with counts and sort by popularity
const cityCounts = new Map();
profiles.forEach(profile => {
  const cityKey = profile.city_slug;
  cityCounts.set(cityKey, (cityCounts.get(cityKey) || 0) + 1);
});

const cities = [...new Set(profiles.map(profile => profile.city_slug))]
  .map(citySlug => {
    const cityData = profiles.find(profile => profile.city_slug === citySlug);
    return {
      name: cityData.city,
      slug: `/${country}/${region}/${citySlug}`,
      count: cityCounts.get(citySlug) || 0
    };
  })
  .sort((a, b) => b.count - a.count); // Sort by count, most to least

const regionName = toTitleCase(region);

// Aggregate statistics
const totalVets = profiles.length;
const uniqueCities = cities.length;
const specializations = profiles.flatMap(profile => profile.specialization || []).reduce((acc, spec) => {
  acc[spec] = (acc[spec] || 0) + 1;
  return acc;
}, {});
const topSpecializations = Object.entries(specializations)
  .sort(([, a], [, b]) => (b as number) - (a as number))
  .slice(0, 2)
  .map(([spec]) => toTitleCase(spec.replace(/-/g, ' ')));

// Additional insights
const hasMobileServices = profiles.some(profile => profile.specialization?.includes('mobile-vet-services'));
const insight1 = hasMobileServices ? 'the rise of mobile vet services' : 'a focus on traditional clinic care';
const hasSeniorCare = profiles.some(profile => profile.specialization?.includes('senior-pet-care'));
const insight2 = hasSeniorCare ? 'specialized senior pet care' : 'general pet wellness';

// Select a sample of cities for readability (first 6 most popular)
const sampleCities = cities.slice(0, 6).map(city => city.name).join(', ');

const path = Astro.url.pathname;
---

<Layout title={`${regionName} Veterinarians`}>
  <Breadcrumbs path={path} />
  
  <!-- Hero Section with Disappearing Logic -->
  <section class="relative overflow-hidden bg-gradient-to-br from-primary-700 via-primary-800 to-primary-900 pt-4 pb-4 md:pt-6 md:pb-6 mb-2" style="margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); width: 100vw;">
    <!-- Subtle background elements -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 -right-40 w-80 h-80 bg-blue-500/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl"></div>
    </div>

    <div class="container mx-auto px-4 md:px-8 lg:px-12 max-w-6xl relative">
      <!-- Header Container with Dynamic Height -->
      <div
        id="hero-header-container"
        class="text-center transition-all duration-500 ease-out overflow-hidden"
        style="margin-bottom: 0.5rem;"
      >
        <!-- Main Header -->
        <div id="hero-header" class="transition-all duration-500 ease-out">
          <h1 class="text-lg md:text-xl xl:text-2xl font-medium text-white/85 mb-1.5 leading-tight tracking-wide">
            {regionName} Veterinarians
          </h1>
          <p class="text-sm xl:text-base text-primary-100/70 leading-relaxed max-w-5xl mx-auto font-light">
            Discover top veterinary clinics across {regionName} in cities like {sampleCities}! 
            Explore a network of {totalVets} veterinarians serving {uniqueCities} cities, specializing in 
            services like {topSpecializations.join(', ')}. Learn about {regionName} vet trends, including 
            {insight1} and {insight2}.
          </p>
        </div>

        <!-- Ultra-minimal Header State - Behind Content -->
        <div
          id="hero-header-mini"
          class="transition-all duration-500 ease-out opacity-0 scale-90 pointer-events-none fixed inset-x-0 z-40"
          style="top: -10px;"
        >
          <div class="container mx-auto px-4 md:px-8 lg:px-12 max-w-6xl">
            <button
              id="header-expand-btn"
              class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-white/10 backdrop-blur-md rounded-full border border-white/20 text-white/70 hover:text-white/90 hover:bg-white/20 transition-all text-xs font-light shadow-lg"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1"
                stroke="currentColor"
                class="w-3 h-3"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
              </svg>
              <span>{regionName} Veterinarians</span>
            </button>
          </div>
        </div>
      </div>


    </div>
  </section>

    <div id="cities-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {cities.length > 0 ? (
        cities.map(city => (
          <a 
            href={city.slug}
            class="city-card flex items-center gap-3 p-4 bg-white rounded-xl shadow-card hover:shadow-lg transition group"
            data-city-name={city.name.toLowerCase()}
            data-clinic-count={city.count}
          > 
            <div class="text-primary-500 bg-primary-50 p-2 rounded-full group-hover:bg-primary-100">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
            </div>
            <div class="flex-1">
              <span class="text-gray-700 group-hover:text-primary-700 transition font-medium">
                {toTitleCase(city.name)}
              </span>
              <span class="ml-2 text-sm text-gray-500">
                {city.count} {city.count === 1 ? 'Clinic' : 'Clinics'}
              </span>
            </div>
          </a>
        ))
      ) : (
        <p class="text-gray-600 col-span-full text-center py-8">No cities found in {regionName} for this range.</p>
      )}
    </div>
</Layout>



<script>
  // Hero header collapse/expand functionality
  document.addEventListener("DOMContentLoaded", function () {
    const heroHeaderContainer = document.getElementById("hero-header-container");
    const heroHeader = document.getElementById("hero-header");
    const heroHeaderMini = document.getElementById("hero-header-mini");
    const expandBtn = document.getElementById("header-expand-btn");

    let isCollapsed = false;
    let autoCollapseTimeout: any;
    let userHasExpanded = false;

    // Auto-collapse after 3 seconds (only if user hasn't manually expanded)
    function startAutoCollapse() {
      autoCollapseTimeout = setTimeout(function () {
        if (!isCollapsed && !userHasExpanded) {
          collapseHeader();
        }
      }, 3000);
    }

    // Cancel auto-collapse
    function cancelAutoCollapse() {
      if (autoCollapseTimeout) {
        clearTimeout(autoCollapseTimeout);
      }
    }

    // Collapse header
    function collapseHeader() {
      if (isCollapsed || !heroHeader || !heroHeaderMini || !heroHeaderContainer)
        return;

      isCollapsed = true;

      // Get current height and set it explicitly for smooth transition
      const currentHeight = heroHeaderContainer.offsetHeight;
      heroHeaderContainer.style.height = currentHeight + "px";

      // Animate out main header
      heroHeader.style.opacity = "0";
      heroHeader.style.transform = "translateY(-10px) scale(0.98)";
      heroHeader.style.pointerEvents = "none";

      // Animate in mini header and collapse container height
      setTimeout(function () {
        if (heroHeaderMini && heroHeaderContainer) {
          // Position mini header between the collapsed header space and the search bar
          const heroSection = heroHeaderContainer.closest("section");
          if (heroSection) {
            const rect = heroSection.getBoundingClientRect();
            heroHeaderMini.style.top = rect.top + window.scrollY + 10 + "px";
          }

          heroHeaderMini.style.opacity = "1";
          heroHeaderMini.style.transform = "scale(1)";
          heroHeaderMini.style.pointerEvents = "auto";

          // Collapse to mini header height and move content up more
          heroHeaderContainer.style.height = "0px";
          heroHeaderContainer.style.marginBottom = "0rem";
        }
      }, 250);
    }

    // Expand header
    function expandHeader() {
      if (!isCollapsed || !heroHeader || !heroHeaderMini || !heroHeaderContainer)
        return;

      isCollapsed = false;
      userHasExpanded = true; // Mark that user has manually expanded

      // Animate out mini header
      heroHeaderMini.style.opacity = "0";
      heroHeaderMini.style.transform = "scale(0.9)";
      heroHeaderMini.style.pointerEvents = "none";

      // Restore container height and margin
      heroHeaderContainer.style.height = "auto";
      heroHeaderContainer.style.marginBottom = "0.5rem";

      // Animate in main header
      setTimeout(function () {
        if (heroHeader) {
          heroHeader.style.opacity = "1";
          heroHeader.style.transform = "translateY(0) scale(1)";
          heroHeader.style.pointerEvents = "auto";
        }
      }, 250);

      // Don't restart auto-collapse timer since user manually expanded
    }

    // Event listeners
    if (expandBtn) {
      expandBtn.addEventListener("click", expandHeader);
    }

    // Cancel auto-collapse on user interaction with header container
    if (heroHeaderContainer) {
      heroHeaderContainer.addEventListener("mouseenter", cancelAutoCollapse);
      heroHeaderContainer.addEventListener("mouseleave", function () {
        // Only restart timer if user hasn't manually expanded
        if (!userHasExpanded) {
          autoCollapseTimeout = setTimeout(function () {
            if (!isCollapsed) {
              collapseHeader();
            }
          }, 2000);
        }
      });
    }

    // Reposition mini header on scroll when collapsed
    function repositionMiniHeader() {
      if (isCollapsed && heroHeaderMini && heroHeaderContainer) {
        const heroSection = heroHeaderContainer.closest("section");
        if (heroSection) {
          const rect = heroSection.getBoundingClientRect();
          
          // Hide the mini header if the hero section is completely scrolled past
          if (rect.bottom < 0) {
            heroHeaderMini.style.opacity = "0";
            heroHeaderMini.style.pointerEvents = "none";
          } else {
            heroHeaderMini.style.opacity = "1";
            heroHeaderMini.style.pointerEvents = "auto";
            heroHeaderMini.style.top =
              Math.max(10, rect.top + window.scrollY + 10) + "px";
          }
        }
      }
    }

    window.addEventListener("scroll", repositionMiniHeader);
    window.addEventListener("resize", repositionMiniHeader);

    // Start auto-collapse timer
    startAutoCollapse();
  });


</script>