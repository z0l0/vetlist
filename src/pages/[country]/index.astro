---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getProfessionals, getProfilesForCountry } from '../../lib/dataCache.js';
import { fetchAllProfessionals } from '../../lib/supabase';
import { getPrecomputedRouteIndex } from '../../lib/siteData.js';
import { getDefaultOgImageUrl, getGeneratedOgImageUrl, pickFirstProfileImage } from '../../lib/seo.js';

function toTitleCase(str) {
  return str.replace(/-/g, ' ').split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
}

function isTrue(value) {
  return value === true || value === 'true' || value === 1 || value === '1';
}

export async function getStaticPaths() {
  try {
    const routeIndex = await getPrecomputedRouteIndex();
    if (routeIndex?.countries?.length) {
      return routeIndex.countries.map(({ country }) => ({ params: { country } }));
    }

    const profiles = await getProfessionals();
    const allProfiles = profiles?.length ? profiles : await fetchAllProfessionals();
    const validProfiles = allProfiles.filter(profile => profile.country_slug && profile.country_slug.trim() !== '');
    const countries = new Set(validProfiles.map(profile => profile.country_slug));
    return Array.from(countries).map(country => ({ params: { country } }));
  } catch (error) {
    console.error("[country].astro getStaticPaths ERROR:", error.message);
    return [];
  }
}

const { country } = Astro.params;
let profiles = await getProfilesForCountry(country);

if (!profiles || profiles.length === 0) {
  try {
    const allProfiles = await getProfessionals();
    profiles = allProfiles.filter(p => p.country_slug === country);
  } catch (e) {
    try {
      const allProfiles = await fetchAllProfessionals();
      profiles = allProfiles.filter(p => p.country_slug === country);
    } catch (directFetchError) {
      profiles = [];
    }
  }
}

const countryName = profiles[0]?.country || toTitleCase(country);
const countryEmoji = country === 'united-states' ? '🇺🇸' : country === 'canada' ? '🇨🇦' : '🌍';

// Generate regions with counts
const regionCounts = {};
profiles.forEach(p => {
  if (p.province_slug && p.province) {
    if (!regionCounts[p.province_slug]) {
      regionCounts[p.province_slug] = { name: p.province, slug: p.province_slug, count: 0 };
    }
    regionCounts[p.province_slug].count++;
  }
});

const regions = Object.values(regionCounts).sort((a, b) => b.count - a.count);
const totalVets = profiles.length;
const uniqueCities = new Set(profiles.filter(p => p.city).map(p => p.city)).size;

// Calculate insights
const withEmergency = profiles.filter(p => isTrue(p.emergency_services) || isTrue(p.emergency_24_hour)).length;
const withOnlineBooking = profiles.filter(p => isTrue(p.online_booking)).length;
const withTelehealth = profiles.filter(p => isTrue(p.telehealth_available)).length;
const withPricing = profiles.filter(p => isTrue(p.has_pricing)).length;

// Ratings
const ratingsData = profiles.filter(p => p.rating && !isNaN(parseFloat(p.rating)));
const avgRating = ratingsData.length > 0 ? (ratingsData.reduce((sum, p) => sum + parseFloat(p.rating), 0) / ratingsData.length).toFixed(1) : null;

// Pricing analysis
const pricesExam = profiles.filter(p => p.pricing_exam).map(p => {
  const match = p.pricing_exam.match(/\$(\d+)/);
  return match ? parseInt(match[1]) : null;
}).filter(Boolean);
const pricesVaccine = profiles.filter(p => p.pricing_vaccine).map(p => {
  const match = p.pricing_vaccine.match(/\$(\d+)/);
  return match ? parseInt(match[1]) : null;
}).filter(Boolean);
const pricesDental = profiles.filter(p => p.pricing_dental).map(p => {
  const match = p.pricing_dental.match(/\$(\d+)/);
  return match ? parseInt(match[1]) : null;
}).filter(Boolean);
const pricesSpay = profiles.filter(p => p.pricing_spay_dog).map(p => {
  const match = p.pricing_spay_dog.match(/\$(\d+)/);
  return match ? parseInt(match[1]) : null;
}).filter(Boolean);

const avgExamPrice = pricesExam.length > 0 ? Math.round(pricesExam.reduce((a, b) => a + b, 0) / pricesExam.length) : null;
const avgVaccinePrice = pricesVaccine.length > 0 ? Math.round(pricesVaccine.reduce((a, b) => a + b, 0) / pricesVaccine.length) : null;
const avgDentalPrice = pricesDental.length > 0 ? Math.round(pricesDental.reduce((a, b) => a + b, 0) / pricesDental.length) : null;
const avgSpayPrice = pricesSpay.length > 0 ? Math.round(pricesSpay.reduce((a, b) => a + b, 0) / pricesSpay.length) : null;

// Languages
const allLanguages = new Set();
profiles.forEach(p => {
  if (p.languages_spoken && p.languages_spoken !== '[]') {
    try {
      const langs = typeof p.languages_spoken === 'string' ? JSON.parse(p.languages_spoken) : p.languages_spoken;
      if (Array.isArray(langs)) {
        langs.filter(l => l.toLowerCase() !== 'english').forEach(l => allLanguages.add(l));
      }
    } catch {}
  }
});
const withLanguages = profiles.filter(p => {
  if (!p.languages_spoken || p.languages_spoken === '[]') return false;
  try {
    const langs = typeof p.languages_spoken === 'string' ? JSON.parse(p.languages_spoken) : p.languages_spoken;
    return Array.isArray(langs) && langs.some(l => l.toLowerCase() !== 'english');
  } catch { return false; }
}).length;

// Year established
const currentYear = new Date().getFullYear();
const newestClinics = profiles.filter(p => p.year_established && parseInt(p.year_established) >= currentYear - 3).length;

// Top regions by different metrics
const regionStats = regions.map(r => {
  const regionProfiles = profiles.filter(p => p.province_slug === r.slug);
  const rated = regionProfiles.filter(p => p.rating && !isNaN(parseFloat(p.rating)));
  const emergency = regionProfiles.filter(p => isTrue(p.emergency_services) || isTrue(p.emergency_24_hour)).length;
  const online = regionProfiles.filter(p => isTrue(p.online_booking)).length;
  const telehealth = regionProfiles.filter(p => isTrue(p.telehealth_available)).length;
  return {
    ...r,
    emergency,
    online,
    telehealth,
    digitalAccess: online + telehealth,
    avgRating: rated.length > 0 ? (rated.reduce((s, p) => s + parseFloat(p.rating), 0) / rated.length).toFixed(1) : null,
  };
});

const mostClinics = regionStats[0];
const bestEmergency = [...regionStats].filter(r => r.emergency > 0).sort((a, b) => b.emergency - a.emergency)[0] || null;
const mostDigital = [...regionStats].filter(r => r.digitalAccess > 0).sort((a, b) => b.digitalAccess - a.digitalAccess)[0] || null;
const highestRated = [...regionStats].filter(r => r.avgRating).sort((a, b) => parseFloat(b.avgRating) - parseFloat(a.avgRating))[0];

const regionType = country === 'united-states' ? 'states' : 'provinces';
const regionTypeSingular = country === 'united-states' ? 'state' : 'province';
const countryOverviewParts = [
  `Compare ${totalVets.toLocaleString()} vet clinics and animal hospitals across ${regions.length.toLocaleString()} ${regionType} in ${countryName}.`,
  `${uniqueCities.toLocaleString()} cities are covered.`,
  withEmergency > 0 ? `${withEmergency.toLocaleString()} clinics list emergency or 24/7 care.` : '',
  withOnlineBooking > 0 ? `${withOnlineBooking.toLocaleString()} list online booking.` : '',
  withTelehealth > 0 ? `${withTelehealth.toLocaleString()} list telehealth.` : '',
  withPricing > 0 ? `${withPricing.toLocaleString()} include pricing details.` : '',
].filter(Boolean);
const countryOverview = `${countryOverviewParts.join(' ')} Use the ${regionTypeSingular} cards to compare clinic counts, access options, ratings, and pricing before choosing where to look next.`;
const generatedCountryImage = getGeneratedOgImageUrl('countries', [country]);
const socialImage = generatedCountryImage || pickFirstProfileImage(profiles) || getDefaultOgImageUrl();

const metaDescription = `Compare ${totalVets.toLocaleString()} vet clinics and animal hospitals across ${regions.length} ${regionType} in ${countryName}, with hours, phone numbers, emergency care, services, and clinic profiles.`;

// SEO-optimized title
const pageTitle = `Veterinary Services in ${countryName} | ${totalVets.toLocaleString()} Vet Clinics & Animal Hospitals`;

// Canonical URL
const canonicalURL = `https://vetlist.org/${country}/`;

// OpenGraph config
const openGraphConfig = {
  type: 'website',
  url: canonicalURL,
  title: pageTitle,
  description: metaDescription,
  siteName: 'VetList.org',
  locale: 'en_US',
  image: socialImage,
  imageAlt: `Veterinary services directory for ${countryName}`,
};

// Twitter Card config
const twitterCardConfig = {
  card: 'summary_large_image',
  title: pageTitle,
  description: metaDescription,
  image: socialImage,
  imageAlt: `Veterinary services directory for ${countryName}`,
};

const countryIntentKeywords = [
  `veterinary services ${countryName}`,
  `veterinary hospital ${countryName}`,
  `vet clinic ${countryName}`,
  `animal hospital ${countryName}`,
  `veterinarian ${countryName}`,
];

const breadcrumbItems = [
  { label: 'Home', href: '/' },
  { label: countryName, href: `/${country}/` },
];
---

<Layout title={pageTitle} description={metaDescription} openGraph={openGraphConfig} twitterCard={twitterCardConfig}>
  <!-- Schema.org structured data with breadcrumbs -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `${countryName} Veterinarians`,
    "description": metaDescription,
    "url": canonicalURL,
    "about": countryIntentKeywords,
    "image": socialImage,
    "mainEntity": {
      "@type": "ItemList",
      "name": `Veterinary Clinics in ${countryName}`,
      "numberOfItems": totalVets,
      "itemListOrder": "https://schema.org/ItemListOrderDescending",
      "itemListElement": regions.slice(0, 10).map((region, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "item": {
          "@type": "WebPage",
          "name": `${region.name} Veterinarians`,
          "url": `https://vetlist.org/${country}/${region.slug}/`,
          "description": `${region.count} veterinary clinics in ${region.name}, ${countryName}`
        }
      }))
    },
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://vetlist.org/" },
        { "@type": "ListItem", "position": 2, "name": countryName, "item": canonicalURL }
      ]
    }
  })} />

  <Fragment slot="head">
    <meta property="business:contact_data:country_name" content={countryName} />
  </Fragment>

  <div class="mx-auto max-w-7xl py-6 md:py-8">
    <Breadcrumbs items={breadcrumbItems} />

    <section class="mt-4 overflow-hidden rounded-[32px] border border-slate-200 bg-slate-950 text-white shadow-2xl">
      <div class="bg-[radial-gradient(circle_at_top_left,_rgba(56,189,248,0.26),_transparent_26%),radial-gradient(circle_at_bottom_right,_rgba(251,191,36,0.16),_transparent_24%)] px-5 py-6 md:px-8 md:py-8">
        <div class="flex flex-col gap-6 xl:flex-row xl:items-stretch xl:justify-between">
          <div class="max-w-4xl">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-200">Country directory</p>
            <h1 class="mt-3 text-4xl font-black tracking-tight text-white md:text-5xl">{countryEmoji} Veterinary services in {countryName}</h1>
            <p class="mt-4 max-w-3xl text-lg leading-8 text-slate-200">
              Compare vet clinics across {regions.length.toLocaleString()} {regionType} in {countryName}, with hours, phone numbers, emergency care, services, and clinic profiles.
            </p>
            <div class="mt-5 flex flex-wrap gap-2">
              <span class="rounded-full border border-white/10 bg-white/10 px-4 py-2 text-sm text-slate-100">{totalVets.toLocaleString()} clinics</span>
              <span class="rounded-full border border-white/10 bg-white/10 px-4 py-2 text-sm text-slate-100">{uniqueCities.toLocaleString()} cities covered</span>
              {withEmergency > 0 && <span class="rounded-full border border-red-400/20 bg-red-400/10 px-4 py-2 text-sm text-red-100">{withEmergency.toLocaleString()} emergency listings</span>}
              {withOnlineBooking > 0 && <span class="rounded-full border border-cyan-300/20 bg-cyan-300/10 px-4 py-2 text-sm text-cyan-100">{withOnlineBooking.toLocaleString()} with online booking</span>}
            </div>
          </div>

          <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 xl:h-full xl:min-h-[260px] xl:w-[420px] xl:grid-rows-2">
            <div class="flex h-full min-h-[150px] flex-col rounded-3xl border border-white/10 bg-white/5 p-5 backdrop-blur">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">Emergency</p>
              <p class="mt-auto whitespace-nowrap text-[2.875rem] font-black leading-none tabular-nums text-red-300 drop-shadow-[0_10px_28px_rgba(252,165,165,0.24)]">{withEmergency.toLocaleString()}</p>
              <p class="mt-2 text-sm text-slate-300">urgent care listed</p>
            </div>
            <div class="flex h-full min-h-[150px] flex-col rounded-3xl border border-white/10 bg-white/5 p-5 backdrop-blur">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">{country === 'united-states' ? 'States' : 'Provinces'}</p>
              <p class="mt-auto whitespace-nowrap text-[2.875rem] font-black leading-none tabular-nums text-emerald-300 drop-shadow-[0_10px_28px_rgba(110,231,183,0.23)]">{regions.length.toLocaleString()}</p>
              <p class="mt-2 text-sm text-slate-300">regions covered</p>
            </div>
            <div class="flex h-full min-h-[150px] flex-col rounded-3xl border border-white/10 bg-white/5 p-5 backdrop-blur">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">Book online</p>
              <p class="mt-auto whitespace-nowrap text-[2.875rem] font-black leading-none tabular-nums text-cyan-300 drop-shadow-[0_10px_28px_rgba(103,232,249,0.25)]">{withOnlineBooking.toLocaleString()}</p>
              <p class="mt-2 text-sm text-slate-300">booking listed</p>
            </div>
            <div class="flex h-full min-h-[150px] flex-col rounded-3xl border border-white/10 bg-white/5 p-5 backdrop-blur">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-300">Avg rating</p>
              <p class="mt-auto whitespace-nowrap text-[2.875rem] font-black leading-none tabular-nums text-amber-300 drop-shadow-[0_10px_28px_rgba(252,211,77,0.24)]">{avgRating || 'NA'}</p>
              <p class="mt-2 text-sm text-slate-300">public rating</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-8 grid gap-4 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Market snapshot</p>
        <div class="mt-4 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
          <div>
            <p class="text-sm text-slate-500">Emergency coverage</p>
            <p class="mt-1 text-3xl font-black text-slate-950">{withEmergency.toLocaleString()}</p>
            <p class="text-sm text-slate-600">clinics listing urgent access</p>
          </div>
          <div>
            <p class="text-sm text-slate-500">Transparent pricing</p>
            <p class="mt-1 text-3xl font-black text-slate-950">{withPricing.toLocaleString()}</p>
            <p class="text-sm text-slate-600">with pricing listed</p>
          </div>
          <div>
            <p class="text-sm text-slate-500">Multilingual care</p>
            <p class="mt-1 text-3xl font-black text-slate-950">{withLanguages.toLocaleString()}</p>
            <p class="text-sm text-slate-600">clinics listing additional languages</p>
          </div>
          <div>
            <p class="text-sm text-slate-500">Average rating</p>
            <p class="mt-1 text-3xl font-black text-slate-950">{avgRating || 'Not listed'}</p>
            <p class="text-sm text-slate-600">{ratingsData.length.toLocaleString()} clinics with rating data</p>
          </div>
          <div>
            <p class="text-sm text-slate-500">Average exam</p>
            <p class="mt-1 text-3xl font-black text-slate-950">{avgExamPrice ? `$${avgExamPrice}` : 'Not listed'}</p>
            <p class="text-sm text-slate-600">published exam pricing</p>
          </div>
          <div>
            <p class="text-sm text-slate-500">Newest clinics</p>
            <p class="mt-1 text-3xl font-black text-slate-950">{newestClinics.toLocaleString()}</p>
            <p class="text-sm text-slate-600">opened in the last three years</p>
          </div>
        </div>
      </div>

      <div class="rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Signals that matter</p>
        <div class="mt-4 space-y-4 text-sm text-slate-600">
          {mostClinics && <p><span class="font-semibold text-slate-950">{mostClinics.name}</span> has the most clinics, with {mostClinics.count.toLocaleString()} listings.</p>}
          {bestEmergency && bestEmergency.emergency > 0 && <p><span class="font-semibold text-slate-950">{bestEmergency.name}</span> has the most clinics listing emergency or 24/7 care, with {bestEmergency.emergency} options.</p>}
          {mostDigital && mostDigital.digitalAccess > 0 && <p><span class="font-semibold text-slate-950">{mostDigital.name}</span> has {mostDigital.digitalAccess} clinics listing online booking or telehealth.</p>}
          {highestRated && highestRated.avgRating && <p><span class="font-semibold text-slate-950">{highestRated.name}</span> has the strongest average rating at {highestRated.avgRating}/5.</p>}
          {allLanguages.size > 0 && <p>{allLanguages.size} non-English languages appear across clinic profiles in {countryName}.</p>}
        </div>
      </div>
    </section>

    {(avgExamPrice || avgVaccinePrice || avgDentalPrice || avgSpayPrice || allLanguages.size > 0) && (
      <section class="mt-8 grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
        <div class="rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Pricing context</p>
          <div class="mt-4 grid gap-3 sm:grid-cols-2">
            {avgExamPrice && <div class="rounded-2xl bg-slate-50 p-4"><div class="text-sm text-slate-500">Exam</div><div class="mt-1 text-2xl font-black text-slate-950">${avgExamPrice}</div></div>}
            {avgVaccinePrice && <div class="rounded-2xl bg-slate-50 p-4"><div class="text-sm text-slate-500">Vaccine</div><div class="mt-1 text-2xl font-black text-slate-950">${avgVaccinePrice}</div></div>}
            {avgDentalPrice && <div class="rounded-2xl bg-slate-50 p-4"><div class="text-sm text-slate-500">Dental</div><div class="mt-1 text-2xl font-black text-slate-950">${avgDentalPrice}</div></div>}
            {avgSpayPrice && <div class="rounded-2xl bg-slate-50 p-4"><div class="text-sm text-slate-500">Spay</div><div class="mt-1 text-2xl font-black text-slate-950">${avgSpayPrice}</div></div>}
          </div>
        </div>

        <div class="rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Published languages</p>
          <div class="mt-4 flex flex-wrap gap-3">
            {withLanguages > 0 && <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-700">{withLanguages.toLocaleString()} multilingual profiles</span>}
            {[...allLanguages].slice(0, 14).map((language) => (
              <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-700">{language}</span>
            ))}
          </div>
        </div>
      </section>
    )}

    <section class="mt-8">
      <div class="mb-4 flex items-end justify-between gap-4">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Browse locations</p>
          <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950">Browse {regionType} in {countryName}</h2>
        </div>
      </div>
      <div id="regions-grid" class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {regionStats.map((entry) => (
          <a
            href={`/${country}/${entry.slug}/`}
            class="region-card group rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)] transition-all duration-200 hover:-translate-y-0.5 hover:border-cyan-300/70 hover:shadow-[0_24px_60px_rgba(15,23,42,0.12)]"
            data-region-name={entry.name.toLowerCase()}
          >
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">{country === 'united-states' ? 'State' : 'Province'}</p>
                <h3 class="mt-2 text-2xl font-black tracking-tight text-slate-950 transition group-hover:text-cyan-700">{entry.name}</h3>
              </div>
              <span class="rounded-full bg-slate-950 px-3 py-1 text-sm font-semibold text-white">{entry.count.toLocaleString()}</span>
            </div>
            <div class="mt-4 flex flex-wrap gap-2 text-sm text-slate-600">
              {entry.emergency > 0 && <span class="rounded-full bg-red-50 px-3 py-1 text-red-700">{entry.emergency} emergency</span>}
              {entry.online > 0 && <span class="rounded-full bg-cyan-50 px-3 py-1 text-cyan-700">{entry.online} book online</span>}
              {entry.telehealth > 0 && <span class="rounded-full bg-purple-50 px-3 py-1 text-purple-700">{entry.telehealth} telehealth</span>}
              {entry.avgRating && <span class="rounded-full bg-amber-50 px-3 py-1 text-amber-800">{entry.avgRating} / 5 avg</span>}
            </div>
            <div class="mt-5 flex items-center justify-between text-sm text-slate-600">
              <span>Open region directory</span>
              <span class="font-semibold text-cyan-700 transition group-hover:translate-x-1">View</span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <section class="mt-8 grid gap-4 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">About this directory</p>
        <div class="mt-4 space-y-3 text-sm leading-7 text-slate-600">
          <p>{countryOverview}</p>
          <p>
            In {countryName}, <span class="font-semibold text-slate-950">{withEmergency.toLocaleString()}</span> clinics list emergency care,
            <span class="font-semibold text-slate-950"> {withOnlineBooking.toLocaleString()}</span> list online booking,
            <span class="font-semibold text-slate-950"> {withTelehealth.toLocaleString()}</span> list telehealth, and
            <span class="font-semibold text-slate-950"> {withPricing.toLocaleString()}</span> include pricing details.
          </p>
        </div>
      </div>

      <div class="rounded-[28px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Useful starting points</p>
        <div class="mt-4 flex flex-wrap gap-3">
          {bestEmergency && <a href={`/${country}/${bestEmergency.slug}/`} class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100">Emergency: {bestEmergency.name}</a>}
          {mostDigital && <a href={`/${country}/${mostDigital.slug}/`} class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100">Booking or telehealth: {mostDigital.name}</a>}
          {highestRated && <a href={`/${country}/${highestRated.slug}/`} class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:bg-slate-100">Highest rating: {highestRated.name}</a>}
          <span class="rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm text-slate-700">{totalVets.toLocaleString()} clinic profiles</span>
        </div>
      </div>
    </section>
</Layout>
