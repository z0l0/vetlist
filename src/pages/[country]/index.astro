---
import Layout from '../../layouts/Layout-optimized.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getProfessionals, getProfilesForCountry } from '../../lib/dataCache.js';
import { fetchAllProfessionals } from '../../lib/supabase';

// Convert slug to title case
function toTitleCase(str) {
  return str
    .replace(/-/g, ' ')
    .split(' ')
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

export async function getStaticPaths() {
  try {
    // Try to get from cache first
    const profiles = await getProfessionals();
    console.log(`[country].astro getStaticPaths: Received ${profiles?.length || 0} profiles from cache.`);
    
    // If cache failed or is empty, fall back to direct fetch
    const allProfiles = profiles?.length ? profiles : await fetchAllProfessionals();
    
    // Filter out profiles with missing or empty country_slug
    const validProfiles = allProfiles.filter(profile => 
      profile.country_slug && 
      profile.country_slug.trim() !== ''
    );
    
    console.log(`[country].astro getStaticPaths: ${validProfiles.length} valid profiles after filtering`);
    
    const countries = new Set(validProfiles.map(profile => profile.country_slug));
    
    const paths = Array.from(countries).map(country => ({
      params: { country }
    }));
    
    console.log(`[country].astro getStaticPaths: Generated ${paths.length} country paths`);
    return paths;
  } catch (error) {
    console.error("[country].astro getStaticPaths ERROR:", error.message);
    return [];
  }
}

const { country } = Astro.params;

// Attempt to use the cached data first
let profiles: any[] = [];

// Get profiles for this country from cache
profiles = await getProfilesForCountry(country);

// If no profiles found in cache, fetch all profiles and filter
if (!profiles || profiles.length === 0) {
  console.log(`[country].astro: No profiles found in cache for ${country}, trying direct fetch...`);
  try {
    const allProfiles = await getProfessionals();
    profiles = allProfiles.filter(p => p.country_slug === country);
  } catch (e) {
    console.error(`[country].astro: Error fetching profiles from cache:`, e.message);
    
    // Try direct fetch as last resort
    try {
      const allProfiles = await fetchAllProfessionals();
      profiles = allProfiles.filter(p => p.country_slug === country);
    } catch (directFetchError) {
      console.error(`[country].astro: Direct fetch also failed:`, directFetchError.message);
      profiles = [];
    }
  }
}

console.log(`[country].astro: Fetched ${profiles.length} profiles for ${country}`);

const countryName = profiles[0]?.country || toTitleCase(country);

// Generate regions dynamically for the current country
const regions = Array.from(new Set(profiles.map(profile => profile.province_slug)))
  .map(regionSlug => {
    const profile = profiles.find(p => p.province_slug === regionSlug);
    return {
      name: profile.province,
      slug: `/${country}/${regionSlug}/`
    };
  })
  .sort((a, b) => a.name.localeCompare(b.name));

// Get total number of vets
const totalVets = profiles.length;

// Get unique cities
const uniqueCities = new Set(profiles.filter(profile => profile.city).map(profile => profile.city)).size;

// Get sample cities (up to 3)
const cities = [...new Set(profiles.filter(profile => profile.city).map(profile => profile.city))];
const sampleCities = cities.length > 0 
  ? cities.slice(0, Math.min(3, cities.length)).join(', ')
  : 'various locations';

// Get top specializations
const specializationCounts = profiles.reduce((acc, profile) => {
  if (profile.specialization && Array.isArray(profile.specialization)) {
    profile.specialization.forEach(spec => {
      if (spec) {
        acc[spec] = (acc[spec] || 0) + 1;
      }
    });
  }
  return acc;
}, {});

// Default specializations in case none are found
const defaultSpecializations = ['Pet Care', 'Animal Health', 'Veterinary Medicine'];

const topSpecializations = Object.keys(specializationCounts).length > 0 
  ? Object.entries(specializationCounts)
      .sort((a, b) => (b[1] as number) - (a[1] as number))
      .slice(0, 3)
      .map(([spec]) => spec)
  : defaultSpecializations;

// Generate some insights
let insight1 = 'a wide network of veterinary professionals';
if (uniqueCities > 0 && regions.length > 0) {
  const coverage = Math.round((regions.length / uniqueCities) * 100);
  if (coverage > 0 && coverage < 100) {
    insight1 = `veterinary services available in ${coverage}% of regions`;
  } else {
    insight1 = 'extensive veterinary coverage across regions';
  }
}

const insight2 = topSpecializations.length > 0 
  ? `veterinarians specializing in ${topSpecializations[0]}`
  : 'veterinarians with diverse specializations';

const path = Astro.url.pathname;

// Meta description
const metaDescription = `Find trusted ${countryName} veterinarians, animal hospitals, and vet clinics across ${regions.length} regions. Browse our directory of ${totalVets}+ veterinary professionals specializing in ${topSpecializations.join(', ')} and more.`;

// Meta keywords - simplified for better SEO focus
const metaKeywords = `${countryName} veterinarians, vet clinics in ${countryName}, animal hospitals in ${countryName}, pet care, veterinary services, find vets in ${countryName}`;

// Open Graph data
const ogTitle = `${countryName} Veterinarians - Vetlist.org`;
const ogDescription = metaDescription;
const ogUrl = Astro.url.href;
// No custom OG image - social platforms will generate preview from page content

// Create structured Open Graph data
const openGraphData = {
  title: ogTitle,
  description: ogDescription,
  type: "website",
  url: ogUrl,
  siteName: "Vetlist.org"
};

// Create Twitter Card data
const twitterCardData = {
  card: "summary",
  title: ogTitle,
  description: ogDescription
};
---

<Layout title={`${countryName} Veterinarians`} description={metaDescription} openGraph={openGraphData} twitterCard={twitterCardData}>
  <meta name="keywords" content={metaKeywords} slot="head" />

  <!-- Schema.org markup for Google -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `${countryName} Veterinarians - Vetlist.org`,
    "description": metaDescription,
    "url": ogUrl,
    "mainEntity": {
      "@type": "ItemList",
      "itemListElement": regions.map((region, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "item": {
          "@type": "WebPage",
          "name": `${region.name} Veterinarians`,
          "url": new URL(`${country}/${region.name.toLowerCase().replace(/\s+/g, '-')}`, 'https://vetlist.org/').href
        }
      }))
    },
    "specialty": topSpecializations,
    "provider": {
      "@type": "Organization",
      "name": "Vetlist.org",
      "url": "https://vetlist.org"
    }
  })} />

  <Breadcrumbs path={path} />
  
  <!-- Hero Section with Disappearing Logic -->
  <section class="relative overflow-hidden bg-gradient-to-br from-primary-700 via-primary-800 to-primary-900 pt-4 pb-4 md:pt-6 md:pb-6 mb-2" style="margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); width: 100vw;">
    <!-- Subtle background elements -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute -top-40 -right-40 w-80 h-80 bg-blue-500/10 rounded-full blur-3xl"></div>
      <div class="absolute -bottom-40 -left-40 w-80 h-80 bg-cyan-500/10 rounded-full blur-3xl"></div>
    </div>

    <div class="container mx-auto px-4 md:px-8 lg:px-12 max-w-6xl relative">
      <!-- Header Container with Dynamic Height -->
      <div
        id="hero-header-container"
        class="text-center transition-all duration-500 ease-out overflow-hidden"
        style="margin-bottom: 0.5rem;"
      >
        <!-- Main Header -->
        <div id="hero-header" class="transition-all duration-500 ease-out">
          <h1 class="text-lg md:text-xl xl:text-2xl font-medium text-white/85 mb-1.5 leading-tight tracking-wide">
            {countryName} Veterinarians
          </h1>
          <p class="text-sm xl:text-base text-primary-100/70 leading-relaxed max-w-5xl mx-auto font-light">
            Discover top veterinary clinics across {countryName} in {regions.length} regions including cities like {sampleCities}! 
            Explore a network of {totalVets} veterinarians serving {uniqueCities} cities, specializing in 
            {topSpecializations.length > 0 ? ` ${topSpecializations.join(', ')}` : ' various veterinary services'}. 
            {countryName} offers exceptional pet care with {insight1} and {insight2}.
          </p>
        </div>

        <!-- Ultra-minimal Header State - Behind Content -->
        <div
          id="hero-header-mini"
          class="transition-all duration-500 ease-out opacity-0 scale-90 pointer-events-none fixed inset-x-0 z-40"
          style="top: -10px;"
        >
          <div class="container mx-auto px-4 md:px-8 lg:px-12 max-w-6xl">
            <button
              id="header-expand-btn"
              class="inline-flex items-center gap-1.5 px-2.5 py-1 bg-white/10 backdrop-blur-md rounded-full border border-white/20 text-white/70 hover:text-white/90 hover:bg-white/20 transition-all text-xs font-light shadow-lg"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1"
                stroke="currentColor"
                class="w-3 h-3"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M19.5 8.25l-7.5 7.5-7.5-7.5"></path>
              </svg>
              <span>{countryName} Veterinarians</span>
            </button>
          </div>
        </div>
      </div>


    </div>
  </section>
    
  <!-- Optimized Regions Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" role="list" aria-label={`Veterinary regions in ${countryName}`}>
    {regions.map(region => (
      <a 
        href={region.slug}
        class="flex items-center gap-3 p-4 bg-white rounded-xl shadow-card hover:shadow-lg transition-shadow group"
        data-region-name={region.name.toLowerCase()}
        role="listitem" 
        aria-label={`${region.name} veterinarians`}
      > 
        <div class="text-primary-500 bg-primary-50 p-2 rounded-full group-hover:bg-primary-100 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </div>
        <span class="text-gray-700 group-hover:text-primary-700 transition-colors font-medium">
          {toTitleCase(region.name)}
        </span>
      </a>
    ))}
  </div>
</Layout>

<script>
  // Hero header collapse/expand functionality
  document.addEventListener("DOMContentLoaded", function () {
    const heroHeaderContainer = document.getElementById("hero-header-container");
    const heroHeader = document.getElementById("hero-header");
    const heroHeaderMini = document.getElementById("hero-header-mini");
    const expandBtn = document.getElementById("header-expand-btn");

    let isCollapsed = false;
    let autoCollapseTimeout: any;
    let userHasExpanded = false;

    // Auto-collapse after 3 seconds (only if user hasn't manually expanded)
    function startAutoCollapse() {
      autoCollapseTimeout = setTimeout(function () {
        if (!isCollapsed && !userHasExpanded) {
          collapseHeader();
        }
      }, 3000);
    }

    // Cancel auto-collapse
    function cancelAutoCollapse() {
      if (autoCollapseTimeout) {
        clearTimeout(autoCollapseTimeout);
      }
    }

    // Collapse header
    function collapseHeader() {
      if (isCollapsed || !heroHeader || !heroHeaderMini || !heroHeaderContainer)
        return;

      isCollapsed = true;

      // Get current height and set it explicitly for smooth transition
      const currentHeight = heroHeaderContainer.offsetHeight;
      heroHeaderContainer.style.height = currentHeight + "px";

      // Animate out main header
      heroHeader.style.opacity = "0";
      heroHeader.style.transform = "translateY(-10px) scale(0.98)";
      heroHeader.style.pointerEvents = "none";

      // Animate in mini header and collapse container height
      setTimeout(function () {
        if (heroHeaderMini && heroHeaderContainer) {
          // Position mini header between the collapsed header space and the search bar
          const heroSection = heroHeaderContainer.closest("section");
          if (heroSection) {
            const rect = heroSection.getBoundingClientRect();
            heroHeaderMini.style.top = rect.top + window.scrollY + 10 + "px";
          }

          heroHeaderMini.style.opacity = "1";
          heroHeaderMini.style.transform = "scale(1)";
          heroHeaderMini.style.pointerEvents = "auto";

          // Collapse to mini header height and move content up more
          heroHeaderContainer.style.height = "0px";
          heroHeaderContainer.style.marginBottom = "0rem";
        }
      }, 250);
    }

    // Expand header
    function expandHeader() {
      if (!isCollapsed || !heroHeader || !heroHeaderMini || !heroHeaderContainer)
        return;

      isCollapsed = false;
      userHasExpanded = true; // Mark that user has manually expanded

      // Animate out mini header
      heroHeaderMini.style.opacity = "0";
      heroHeaderMini.style.transform = "scale(0.9)";
      heroHeaderMini.style.pointerEvents = "none";

      // Restore container height and margin
      heroHeaderContainer.style.height = "auto";
      heroHeaderContainer.style.marginBottom = "0.5rem";

      // Animate in main header
      setTimeout(function () {
        if (heroHeader) {
          heroHeader.style.opacity = "1";
          heroHeader.style.transform = "translateY(0) scale(1)";
          heroHeader.style.pointerEvents = "auto";
        }
      }, 250);

      // Don't restart auto-collapse timer since user manually expanded
    }

    // Event listeners
    if (expandBtn) {
      expandBtn.addEventListener("click", expandHeader);
    }

    // Cancel auto-collapse on user interaction with header container
    if (heroHeaderContainer) {
      heroHeaderContainer.addEventListener("mouseenter", cancelAutoCollapse);
      heroHeaderContainer.addEventListener("mouseleave", function () {
        // Only restart timer if user hasn't manually expanded
        if (!userHasExpanded) {
          autoCollapseTimeout = setTimeout(function () {
            if (!isCollapsed) {
              collapseHeader();
            }
          }, 2000);
        }
      });
    }

    // Reposition mini header on scroll when collapsed
    function repositionMiniHeader() {
      if (isCollapsed && heroHeaderMini && heroHeaderContainer) {
        const heroSection = heroHeaderContainer.closest("section");
        if (heroSection) {
          const rect = heroSection.getBoundingClientRect();
          
          // Hide the mini header if the hero section is completely scrolled past
          if (rect.bottom < 0) {
            heroHeaderMini.style.opacity = "0";
            heroHeaderMini.style.pointerEvents = "none";
          } else {
            heroHeaderMini.style.opacity = "1";
            heroHeaderMini.style.pointerEvents = "auto";
            heroHeaderMini.style.top =
              Math.max(10, rect.top + window.scrollY + 10) + "px";
          }
        }
      }
    }

    window.addEventListener("scroll", repositionMiniHeader);
    window.addEventListener("resize", repositionMiniHeader);

    // Start auto-collapse timer
    startAutoCollapse();
  });


</script>



