---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getProfessionals, getProfilesForCountry } from '../../lib/dataCache.js';
import { fetchAllProfessionals } from '../../lib/supabase';

function toTitleCase(str) {
  return str.replace(/-/g, ' ').split(' ').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');
}

export async function getStaticPaths() {
  try {
    const profiles = await getProfessionals();
    const allProfiles = profiles?.length ? profiles : await fetchAllProfessionals();
    const validProfiles = allProfiles.filter(profile => profile.country_slug?.trim());
    const countries = new Set(validProfiles.map(profile => profile.country_slug));
    return Array.from(countries).map(country => ({ params: { country } }));
  } catch (error) {
    console.error("[country].astro getStaticPaths ERROR:", error.message);
    return [];
  }
}

const { country } = Astro.params;
let profiles = await getProfilesForCountry(country);

if (!profiles?.length) {
  try {
    const allProfiles = await getProfessionals();
    profiles = allProfiles.filter(p => p.country_slug === country);
  } catch (e) {
    try {
      const allProfiles = await fetchAllProfessionals();
      profiles = allProfiles.filter(p => p.country_slug === country);
    } catch (directFetchError) {
      profiles = [];
    }
  }
}

const countryName = profiles[0]?.country || toTitleCase(country);
const regions = Array.from(new Set(profiles.map(profile => profile.province_slug)))
  .map(regionSlug => {
    const profile = profiles.find(p => p.province_slug === regionSlug);
    return { name: profile.province, slug: `/${country}/${regionSlug}` };
  })
  .sort((a, b) => a.name.localeCompare(b.name));

const totalVets = profiles.length;
const uniqueCities = new Set(profiles.filter(p => p.city).map(p => p.city)).size;
const sampleCities = [...new Set(profiles.filter(p => p.city).map(p => p.city))].slice(0, 3).join(', ') || 'various locations';

const specializationCounts = profiles.reduce((acc, profile) => {
  if (profile.specialization && Array.isArray(profile.specialization)) {
    profile.specialization.forEach(spec => {
      if (spec) acc[spec] = (acc[spec] || 0) + 1;
    });
  }
  return acc;
}, {});

const topSpecializations = Object.keys(specializationCounts).length > 0 
  ? Object.entries(specializationCounts).sort((a, b) => b[1] - a[1]).slice(0, 3).map(([spec]) => spec)
  : ['Pet Care', 'Animal Health', 'Veterinary Medicine'];

const metaDescription = `Find trusted ${countryName} veterinarians, animal hospitals, and vet clinics across ${regions.length} regions. Browse our directory of ${totalVets}+ veterinary professionals specializing in ${topSpecializations.join(', ')} and more.`;
const metaKeywords = `${countryName} veterinarians, vet clinics in ${countryName}, animal hospitals in ${countryName}, pet care, veterinary services, find vets in ${countryName}`;

const openGraphData = {
  title: `${countryName} Veterinarians - Vetlist.org`,
  description: metaDescription,
  type: "website",
  url: Astro.url.href,
  siteName: "Vetlist.org"
};

const twitterCardData = {
  card: "summary",
  title: `${countryName} Veterinarians - Vetlist.org`,
  description: metaDescription
};
---

<Layout title={`${countryName} Veterinarians`} description={metaDescription} openGraph={openGraphData} twitterCard={twitterCardData}>
  <meta name="keywords" content={metaKeywords} slot="head" />
  
  <!-- Optimized Schema.org markup -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "CollectionPage",
    "name": `${countryName} Veterinarians - Vetlist.org`,
    "description": metaDescription,
    "url": Astro.url.href,
    "mainEntity": {
      "@type": "ItemList",
      "itemListElement": regions.slice(0, 10).map((region, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "item": {
          "@type": "WebPage",
          "name": `${region.name} Veterinarians`,
          "url": new URL(`${country}/${region.name.toLowerCase().replace(/\s+/g, '-')}`, 'https://vetlist.org/').href
        }
      }))
    }
  })} />

  <Breadcrumbs path={Astro.url.pathname} />
  
  <!-- Simplified Hero Section -->
  <section class="bg-gradient-to-br from-primary-700 to-primary-900 py-8 mb-6 -mx-4">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-2xl md:text-3xl font-semibold text-white mb-3">
        {countryName} Veterinarians
      </h1>
      <p class="text-primary-100/80 max-w-4xl mx-auto">
        Discover {totalVets} veterinarians across {regions.length} regions in {countryName}. 
        Find specialists in {topSpecializations.slice(0, 2).join(' and ')} serving {uniqueCities} cities.
      </p>
    </div>
  </section>
    
  <!-- Optimized Regions Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4" role="list" aria-label={`Veterinary regions in ${countryName}`}>
    {regions.map(region => (
      <a 
        href={region.slug}
        class="flex items-center gap-3 p-4 bg-white rounded-xl shadow-card hover:shadow-lg transition-shadow group"
        role="listitem" 
        aria-label={`${region.name} veterinarians`}
      > 
        <div class="text-primary-500 bg-primary-50 p-2 rounded-full group-hover:bg-primary-100 transition-colors">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
          </svg>
        </div>
        <span class="text-gray-700 group-hover:text-primary-700 transition-colors font-medium">
          {toTitleCase(region.name)}
        </span>
      </a>
    ))}
  </div>
</Layout>