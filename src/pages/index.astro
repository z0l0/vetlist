---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/home/Hero.astro';
import Features from '../components/home/Features.astro';
import FAQ from '../components/home/FAQ.astro';
import Testimonials from '../components/home/Testimonials.astro';
import { fetchAllProfessionals } from '../lib/supabase';

// Fetch cities with vet data from CSV
const allProfiles = await fetchAllProfessionals();

// Aggregate cities by vet count and prepare the popularCities array
const popularCities = allProfiles
  ? (() => {
      // Count vets per city (exclude invalid cities)
      const cityCounts = allProfiles.reduce((acc, item) => {
        // Skip records with invalid or placeholder city names
        if (!item.city || item.city.trim() === '' || item.city === 'N/A' || item.city === 'null') {
          return acc;
        }
        
        const key = `${item.city}|${item.city_slug}|${item.province_slug}|${item.country_slug}`;
        if (!acc[key]) {
          acc[key] = {
            name: item.city,
            slug: `/${item.country_slug}/${item.province_slug}/${item.city_slug}`,
            count: 0
          };
        }
        acc[key].count += 1;
        return acc;
      }, {});
      // Convert to array and sort by vet count (descending), then alphabetically
      return Object.values(cityCounts)
        .sort((a: any, b: any) => {
          // First sort by count (descending)
          const countDiff = b.count - a.count;
          if (countDiff !== 0) return countDiff;
          
          // Then sort alphabetically, handling null/undefined names
          const nameA = a.name || '';
          const nameB = b.name || '';
          return nameA.localeCompare(nameB);
        })
        .slice(0, 6); // Take top 6 for the hero section
    })()
  : [];

// Fallback static list if no cities are fetched
const fallbackCities = [
  { name: 'Fort Worth', slug: '/united-states/texas/fort-worth' },
  { name: 'Dallas', slug: '/united-states/texas/dallas' },
  { name: 'Houston', slug: '/united-states/texas/houston' },
  { name: 'Austin', slug: '/united-states/texas/austin' },
  { name: 'San Antonio', slug: '/united-states/texas/san-antonio' },
  { name: 'Arlington', slug: '/united-states/texas/arlington' }
];

// Use fetched cities if available, otherwise fallback
const citiesToDisplay = popularCities.length > 0 ? popularCities : fallbackCities;

// Top visited profiles based on analytics data (last 30 days)
const topVisitedProfiles = [
