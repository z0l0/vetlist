                <span class="mt-1 block text-sm text-slate-600">{city.province} · {city.count.toLocaleString()} clinics listed</span>
              </a>
            ))}
            <a href="/canada/" class="flex items-center justify-between rounded-2xl border border-white/20 bg-white/10 px-4 py-3 text-white transition hover:bg-white/15">
              <span>
                <span class="block text-xs font-extrabold uppercase tracking-[0.16em] text-red-100">Browse all</span>
                <span class="block text-base font-semibold">Canada provinces and cities</span>
              </span>
              <span class="text-lg">→</span>
            </a>
          </div>
        </div>

        <div id="popular-vets" class="rounded-[28px] border border-white/15 bg-white/10 p-4 backdrop-blur">
          <div class="flex items-center justify-between rounded-full border border-emerald-200/25 bg-emerald-300/15 px-4 py-2 text-sm font-bold text-white">
            <span>Verified Clinics</span>
            <span class="text-xs font-semibold text-emerald-100">{verifiedLane.length} picks</span>
          </div>
          <div class="mt-3 space-y-2">
            {verifiedLane.map((clinic) => (
              <a href={`/${clinic.country_slug}/${clinic.province_slug}/${clinic.city_slug}/${clinic.name_slug}/`} class="flex items-center justify-between gap-3 rounded-2xl bg-white/90 px-4 py-3 text-slate-900 transition hover:bg-white">
                <span class="min-w-0">
                  <span class="block text-xs font-extrabold uppercase tracking-[0.14em] text-emerald-700">Verified profile</span>
                  <span class="block truncate text-base font-semibold">{clinic.name}</span>
                  <span class="block truncate text-sm text-slate-600">{clinic.city}, {clinic.province}</span>
                </span>
                {clinic.badge && (
                  <span class="shrink-0 rounded-xl bg-amber-300 px-2 py-1 text-sm font-black text-slate-900" title={clinic.badge.title}>{clinic.badge.label}</span>
                )}
              </a>
            ))}
            <div class="mt-2 flex gap-2">
              <a href="/add-vet/" class="flex-1 flex items-center justify-center rounded-2xl border-2 border-emerald-300/50 bg-white/90 px-3 py-3 text-sm font-black text-slate-900 transition hover:bg-white text-center">
                + Add Listing
              </a>
              <a href="/claim-clinic/" class="flex-1 flex items-center justify-center rounded-2xl border-2 border-slate-200/50 bg-white/90 px-3 py-3 text-sm font-black text-slate-900 transition hover:bg-white text-center">
                Claim Profile
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-6 vl-ai-panel p-6">
      <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-xs font-extrabold uppercase tracking-[0.18em] text-slate-500">Directory Depth</p>
          <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950">What you can compare across clinics</h2>
        </div>
        <p class="max-w-2xl text-sm leading-7 text-slate-600 md:text-base">
          A few of the fields VetList uses to help people choose where to call first.
        </p>
      </div>

      <div class="mt-5 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
        {dataProofCards.map((card) => (
          <a href={card.href} class="rounded-[24px] border border-slate-200 bg-white/90 p-4 transition hover:border-cyan-300/40 hover:shadow-[0_14px_30px_rgba(15,23,42,0.08)]">
            <span class="block text-3xl font-black tracking-tight text-slate-950">{card.value}</span>
            <span class="mt-1 block text-sm font-bold leading-6 text-slate-900">{card.label}</span>
            <span class="mt-2 block text-xs font-extrabold uppercase tracking-[0.12em] text-slate-500">{card.detail}</span>
          </a>
        ))}
      </div>

      <div class="mt-6 grid gap-4 lg:grid-cols-2">
        <div class="rounded-[24px] border border-slate-200 bg-slate-50/90 p-5">
          <h3 class="text-2xl font-black tracking-tight text-slate-950">Browse by region</h3>
          <div class="mt-4 grid gap-2">
            {topRegions.map((region) => (
              <a href={`/${region.country}/${region.slug}/`} class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm transition hover:border-cyan-300/40">
                <span class="font-semibold text-slate-900">{region.name}</span>
                <span class="text-slate-500">{region.count.toLocaleString()} clinics</span>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-[24px] border border-slate-200 bg-slate-50/90 p-5">
          <h3 class="text-2xl font-black tracking-tight text-slate-950">Browse by city</h3>
          <div class="mt-4 grid gap-2">
            {topCities.slice(0, 10).map((city) => (
              <a href={`/${city.country}/${city.region}/${city.slug}/`} class="flex items-center justify-between rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm transition hover:border-cyan-300/40">
                <span class="font-semibold text-slate-900">{city.name}, {city.province}</span>
                <span class="text-slate-500">{city.count.toLocaleString()} clinics</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="mt-6 vl-ai-panel p-6">
      <p class="text-xs font-extrabold uppercase tracking-[0.18em] text-slate-500">FAQ</p>
      <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950">Questions people ask before choosing a vet</h2>
      <div class="mt-4 grid gap-3">
        {faqEntries.map((entry) => (
          <details class="rounded-[22px] border border-slate-200 bg-slate-50/90 px-4 py-4">
            <summary class="cursor-pointer text-sm font-bold text-slate-900 md:text-base">{entry.question}</summary>
            <p class="mt-2 text-sm leading-7 text-slate-600 md:text-base">{entry.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </div>

  <script is:inline>
    (() => {
      const dataElement = document.getElementById('vetlist-home-ai-data');
      const input = document.getElementById('vl-ai-input');
      const submitButton = document.getElementById('vl-ai-submit');
      const typing = document.getElementById('vl-ai-typing');
      const response = document.getElementById('vl-ai-response');
      const responseEyebrow = document.getElementById('vl-ai-response-eyebrow');
      const responseTitle = document.getElementById('vl-ai-response-title');
      const responseBody = document.getElementById('vl-ai-response-body');
      const primaryLink = document.getElementById('vl-ai-primary-link');
      const resetButton = document.getElementById('vl-ai-reset');
      const suggestions = document.getElementById('vl-ai-suggestions');
      const placeholder = document.getElementById('vl-ai-placeholder');
      const placeholderText = document.getElementById('vl-ai-placeholder-text');

      if (!dataElement || !input || !submitButton || !typing || !response || !responseEyebrow || !responseTitle || !responseBody || !primaryLink || !resetButton || !suggestions || !placeholder || !placeholderText) {
        return;
      }

      const data = JSON.parse(dataElement.textContent || '{}');
      const hiddenClass = 'vl-ai-hidden';
      const placeholderPhrases = Array.isArray(data.placeholders) ? data.placeholders : [];

      function normalize(value) {
        return String(value || '').toLowerCase().replace(/[^a-z0-9\s]/g, ' ').replace(/\s+/g, ' ').trim();
      }

      function containsAny(query, terms) {
        return terms.some((term) => query.includes(term));
      }

      function autoResize() {
        input.style.height = 'auto';
        input.style.height = Math.min(input.scrollHeight, 224) + 'px';
      }

      function syncPlaceholder() {
        placeholder.classList.toggle('is-hidden', input.value.trim().length > 0);
      }

      let phraseIndex = 0;
      let charIndex = 0;
      let deleting = false;
      let typeTimer = null;
      let firstPhraseShown = false;

      function stopTypewriter() {
        if (typeTimer) {
          window.clearTimeout(typeTimer);
          typeTimer = null;
        }
      }

      function runTypewriter() {
        if (!placeholderPhrases.length || input.value.trim().length > 0) return;

        // Preload the first phrase instantly — no typing animation
        if (!firstPhraseShown) {
          firstPhraseShown = true;
          placeholderText.textContent = placeholderPhrases[0];
          charIndex = placeholderPhrases[0].length;
          deleting = true;
          typeTimer = window.setTimeout(runTypewriter, 2800);
          return;
        }

        const current = placeholderPhrases[phraseIndex];

        if (!deleting) {
          charIndex += 1;
          placeholderText.textContent = current.slice(0, charIndex);

          if (charIndex >= current.length) {
            deleting = true;
            typeTimer = window.setTimeout(runTypewriter, 2200);
            return;
          }

          typeTimer = window.setTimeout(runTypewriter, 38);
          return;
        }

        charIndex -= 1;
        placeholderText.textContent = current.slice(0, Math.max(charIndex, 0));

        if (charIndex <= 0) {
          deleting = false;
          phraseIndex = (phraseIndex + 1) % placeholderPhrases.length;
          typeTimer = window.setTimeout(runTypewriter, 320);
          return;
        }

        typeTimer = window.setTimeout(runTypewriter, 18);
      }

      function startTypewriter() {
        stopTypewriter();
        if (input.value.trim().length > 0) return;
        runTypewriter();
      }

      function renderSuggestions(items) {
        suggestions.innerHTML = (items || [])
          .map((item) => (
            '<a class="vl-ai-suggestion ' + (item.className || '') + '" href="' + item.href + '">' +
              '<span>' +
                '<span class="vl-ai-suggestion-label">' + item.label + '</span>' +
                '<span class="vl-ai-suggestion-detail">' + item.detail + '</span>' +
              '</span>' +
              '<span aria-hidden="true">→</span>' +
            '</a>'
          ))
          .join('');
      }

      function showTyping() {
        typing.classList.add('is-active');
        response.classList.add(hiddenClass);
      }

      function showResponse(result) {
        typing.classList.remove('is-active');
        responseEyebrow.textContent = result.eyebrow;
        responseTitle.textContent = result.title;
        responseBody.textContent = result.body;
        
        if (result.linkLabel) {
          primaryLink.textContent = result.linkLabel;
          primaryLink.setAttribute('href', result.href);
          primaryLink.style.display = '';
        } else {
          primaryLink.style.display = 'none';
        }
        
        renderSuggestions(result.suggestions);
        response.classList.remove(hiddenClass);
      }

      function findCityMatch(query) {
        return (data.cityRoutes || []).find((route) => (route.tokens || []).some((token) => query.includes(token)));
      }

      function findRegionMatch(query) {
        return (data.regionRoutes || []).find((route) => (route.tokens || []).some((token) => query.includes(token)));
      }

      function buildDefaultSuggestions() {
        return (data.onboardingActions || []).slice(0, 4);
      }

      function routeQuery(rawQuery) {
        const query = normalize(rawQuery);
        const cityMatch = findCityMatch(query);
        const regionMatch = findRegionMatch(query);
        const defaults = data.defaults || {};
        const suggestions = buildDefaultSuggestions();

        if (cityMatch) {
          return {
            eyebrow: 'Location Match Found',
            title: 'Starting search in ' + cityMatch.label + '...',
            body: 'We found clinics matching your criteria in ' + cityMatch.label + '. Compiling clinic profiles, hours, contact details, and service offerings for this area.',
            href: cityMatch.url,
            linkLabel: 'View Results for ' + cityMatch.label,
            suggestions,
          };
        }

        // Generic fallback that looks cool but doesn't do much
        return {
          eyebrow: 'AI Search Initiated',
          title: 'Searching across North America...',
          body: 'We are analyzing thousands of clinic profiles. To narrow down the best results for your specific request, please select whether you are looking for a vet in the United States or Canada.',
          href: '',
          linkLabel: '', // This triggers the dynamic hide
          suggestions: [
            {
              label: '🇺🇸 Search United States',
              detail: 'Find clinics across all 50 states',
              href: '/united-states/',
              className: 'is-blue',
            },
            {
              label: '🇨🇦 Search Canada',
              detail: 'Find clinics across Canadian provinces',
              href: '/canada/',
              className: 'is-red',
            }
          ],
        };
      }

      function handleSubmit() {
        const query = input.value.trim();
        showTyping();

        window.setTimeout(() => {
          showResponse(routeQuery(query));
        }, 520 + Math.floor(Math.random() * 260));
      }

      document.querySelectorAll('[data-ai-query]').forEach((button) => {
        button.addEventListener('click', () => {
          input.value = button.getAttribute('data-ai-query') || '';
          autoResize();
          syncPlaceholder();
          handleSubmit();
        });
      });

      input.addEventListener('input', () => {
        autoResize();
        syncPlaceholder();
      });

      input.addEventListener('focus', () => {
        stopTypewriter();
        placeholderText.textContent = '';
      });

      input.addEventListener('blur', () => {
        if (!input.value.trim()) {
          startTypewriter();
        }
      });

      input.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' && !event.shiftKey) {
          event.preventDefault();
          handleSubmit();
        }
      });

      submitButton.addEventListener('click', handleSubmit);
      resetButton.addEventListener('click', () => {
        input.value = '';
        autoResize();
        syncPlaceholder();
        response.classList.add(hiddenClass);
        input.focus();
        startTypewriter();
      });

      autoResize();
      syncPlaceholder();
      startTypewriter();
    })();
  </script>
</Layout>
