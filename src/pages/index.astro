    slug: "canada/alberta/calgary/springbank-pet-hospital",
    city: "Calgary",
    province: "Alberta", 
    country: "Canada",
    rating: 4.9,
    picture: null
  },
  {
    name: "North Kipling Veterinary Hospital",
    slug: "canada/ontario/toronto/north-kipling-veterinary-hospital",
    city: "Toronto",
    province: "Ontario",
    country: "Canada", 
    rating: 4.7,
    picture: null
  },
  {
    name: "Richardson Ranch",
    slug: "canada/british-columbia/tlell/richardson-ranch",
    city: "Tlell",
    province: "British Columbia",
    country: "Canada",
    rating: 4.6,
    picture: null
  },
  {
    name: "Dr. Roberto J. Rojas, DVM",
    slug: "united-states/arizona/nogales/rojas-roberto-j-dvm", 
    city: "Nogales",
    state: "Arizona",
    country: "United States",
    rating: 4.8,
    picture: null
  },
  {
    name: "North Island Veterinary Hospital",
    slug: "canada/british-columbia/port-hardy/north-island-veterinary-hospital",
    city: "Port Hardy",
    province: "British Columbia", 
    country: "Canada",
    rating: 4.7,
    picture: null
  },
  {
    name: "Junction West Animal Hospital",
    slug: "canada/ontario/toronto/junction-west-animal-hospital",
    city: "Toronto",
    province: "Ontario",
    country: "Canada",
    rating: 4.8,
    picture: null
  },
  {
    name: "Aloha Veterinary Care",
    slug: "united-states/hawaii/kihei/aloha-veterinary-care",
    city: "Kihei", 
    state: "Hawaii",
    country: "United States",
    rating: 4.9,
    picture: null
  },
  {
    name: "Greenfield Animal Hospital",
    slug: "united-states/florida/miami/greenfield-animal-hospital",
    city: "Miami",
