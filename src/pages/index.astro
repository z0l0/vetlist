    slug: "canada/alberta/edmonton/vet-er",
    city: "Edmonton",
    province: "Alberta",
    country: "Canada", 
    rating: 4.5,
    picture: null
  }
];

// Get popular vets - prioritize top visited profiles, then fill with data from CSV
const popularVets = topVisitedProfiles.map(vet => ({
  name: vet.name,
  slug: vet.slug,
  picture: vet.picture,
  rating: vet.rating,
  city: vet.city,
  state: vet.state || vet.province,
  province: vet.province,
  country: vet.country
}));

// Get statistics for hero section
const totalVets = allProfiles ? allProfiles.length : 0;
const uniqueCities = allProfiles ? new Set(allProfiles.map(p => p.city)).size : 0;
const allSpecializations = new Set();
if (allProfiles) {
  allProfiles.forEach(p => {
    if (Array.isArray(p.specialization)) {
      p.specialization.forEach(spec => allSpecializations.add(spec));
    } else if (p.specialization) {
      allSpecializations.add(p.specialization);
    }
  });
}
const topSpecializations = Array.from(allSpecializations).slice(0, 8) as string[];
---

<Layout title="Find Top Rated Veterinarians Near You | VetList.org">
  <!-- Organization schema for brand rich snippets -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "VetList.org",
    "url": "https://vetlist.org",
    "logo": "https://vetlist.org/favicon.svg",
    "description": "Find the best veterinarians and animal hospitals near you. Browse our comprehensive directory of veterinary professionals across North America.",
    "foundingDate": "2024",
    "contactPoint": {
      "@type": "ContactPoint",
      "contactType": "customer service",
      "availableLanguage": ["English"]
    },
    "potentialAction": {
      "@type": "SearchAction",
      "target": {
        "@type": "EntryPoint",
        "urlTemplate": "https://vetlist.org/search?q={search_term_string}"
      },
      "query-input": "required name=search_term_string"
    },
    "mainEntity": {
      "@type": "WebSite",
      "name": "VetList.org",
      "url": "https://vetlist.org",
      "potentialAction": {
        "@type": "SearchAction",
        "target": "https://vetlist.org/search?q={search_term_string}",
        "query-input": "required name=search_term_string"
      }
    }
  })} />
  
  <Hero 
    cities={citiesToDisplay} 
    popularVets={popularVets}
    totalVets={totalVets}
    totalCities={uniqueCities}
  />
  <Features />
  <Testimonials />
  <FAQ />
</Layout>