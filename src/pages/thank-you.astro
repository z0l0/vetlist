---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const title = 'Thank You';
const path = Astro.url.pathname.replace(/\/$/, '');
---

<Layout title={title}>
  <Breadcrumbs path={path} />

  <div class="max-w-6xl mx-auto px-4 py-8">
    <div class="bg-white p-12 md:p-8 rounded-xl shadow-lg text-center max-w-2xl mx-auto my-12">
      <div class="w-20 h-20 mb-8 bg-blue-100 rounded-xl p-5 mx-auto flex items-center justify-center">
        <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
        </svg>
      </div>
      <h1 class="text-4xl md:text-3xl mb-4 text-blue-600 font-bold">Thank You!</h1>
      <p class="text-xl md:text-lg mb-8 text-gray-600">Your message has been sent successfully. We'll get back to you as soon as possible.</p>
      <a href="/" class="inline-block bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-700 hover:to-indigo-700 text-white font-semibold px-8 py-3 rounded-full transition-all duration-300 shadow-lg hover:shadow-xl transform hover:scale-105">Return to Home</a>
    </div>
  </div>
</Layout> 