---
import Layout from '../layouts/Layout.astro';

const title = "Add Your Veterinary Practice | VetList.org";
const description = "Join VetList.org's comprehensive veterinary directory with over 10,000+ monthly visitors. Increase your practice visibility and attract more pet owners.";
---

<Layout title={title} description={description}>
  <div class="max-w-4xl mx-auto px-4 py-8">
    <!-- Header with compelling copy -->
    <div class="text-center mb-12">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-6">
        Add Your Veterinary Practice
      </h1>
      <div class="max-w-3xl mx-auto">
        <p class="text-xl text-gray-600 mb-6">
          Join VetList.org, North America's fastest-growing veterinary directory with over <strong>10,000+ monthly visitors</strong> actively searching for veterinary care.
        </p>
        <div class="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-xl p-6 mb-8">
          <div class="grid md:grid-cols-3 gap-6 text-center">
            <div>
              <div class="text-3xl font-bold text-blue-600 mb-2">10,000+</div>
              <div class="text-sm text-gray-600">Monthly Visitors</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-indigo-600 mb-2">30,000+</div>
              <div class="text-sm text-gray-600">Listed Practices</div>
            </div>
            <div>
              <div class="text-3xl font-bold text-purple-600 mb-2">24-48hrs</div>
              <div class="text-sm text-gray-600">Listing Time</div>
            </div>
          </div>
        </div>
        <p class="text-lg text-gray-600">
          Get found by pet owners in your area and grow your practice with our comprehensive directory listing. It's completely free to get started!
        </p>
      </div>
    </div>

    <!-- Add Practice Form -->
    <div class="bg-white rounded-xl shadow-lg p-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">
        Practice Information
      </h2>
      
      <form id="add-practice-form" action="https://formsubmit.co/directorytraffic@gmail.com" method="POST" class="space-y-6">
        <!-- FormSubmit configuration -->
        <input type="hidden" name="_subject" value="New Veterinary Practice Submission - VetList">
        <input type="hidden" name="_captcha" value="false">
        <input type="hidden" name="_template" value="table">
        <input type="hidden" name="_next" value="/thank-you">
        <input type="hidden" name="_honeypot" value="">
        <input type="hidden" name="form_type" value="add_practice">

        <!-- Basic Information -->
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Practice Name *
            </label>
            <input
              type="text"
              name="practice_name"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
              placeholder="Your Veterinary Clinic Name"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Phone Number *
            </label>
            <input
              type="tel"
              name="phone"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
              placeholder="(555) 123-4567"
            />
          </div>
        </div>

        <!-- Address -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2">
            Full Address *
          </label>
          <input
            type="text"
            name="address"
            required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
            placeholder="123 Main Street"
          />
        </div>

        <div class="grid md:grid-cols-3 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              City *
            </label>
            <input
              type="text"
              name="city"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
              placeholder="Toronto"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Province/State *
            </label>
            <input
              type="text"
              name="province"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
              placeholder="Ontario"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Country *
            </label>
            <select
              name="country"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
            >
              <option value="">Select Country</option>
              <option value="Canada">Canada</option>
              <option value="United States">United States</option>
            </select>
          </div>
        </div>

        <!-- Contact Information -->
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Email Address *
            </label>
            <input
              type="email"
              name="email"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
              placeholder="contact@yourvet.com"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">
              Website
            </label>
            <input
              type="url"
              name="website"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-colors"
              placeholder="https://yourvet.com"
            />
          </div>
        </div>

        <!-- Services & Specializations -->
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-4">
            Services & Specializations Offered
          </label>
          <div class="grid md:grid-cols-3 gap-3 mb-4" id="services-grid">
            <!-- Most Common Veterinary Services -->
            <label class="flex items-center p-2 rounded hover:bg-gray-50 transition-colors">
              <input
                type="checkbox"
                name="services[]"
                value="General Veterinary Care"
                class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
              />
              <span class="ml-2 text-sm text-gray-700">General Veterinary Care</span>
            </label>
            <label class="flex items-center p-2 rounded hover:bg-gray-50 transition-colors">
              <input
                type="checkbox"
                name="services[]"
                value="Emergency Care"
                class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
              />
              <span class="ml-2 text-sm text-gray-700">Emergency Care</span>
            </label>
            <label class="flex items-center p-2 rounded hover:bg-gray-50 transition-colors">
              <input
                type="checkbox"
                name="services[]"
                value="Surgery"
                class="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
              />
              <span class="ml-2 text-sm text-gray-700">Surgery</span>
            </label>
            <label class="flex items-center p-2 rounded hover:bg-gray-50 transition-colors">
              <input
                type="checkbox"
                name="services[]"
