            Add My Practice to VetList
          </button>
          <p class="text-sm text-gray-500 mt-4">
            We'll review your submission and add your practice to our directory within 24-48 hours.
          </p>
        </div>
      </form>
    </div>

    <!-- Benefits Section -->
    <div class="mt-12 grid md:grid-cols-3 gap-8">
      <div class="text-center p-6 bg-white rounded-xl shadow-md">
        <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Increased Visibility</h3>
        <p class="text-gray-600">Get found by pet owners actively searching for veterinary care in your area.</p>
      </div>
      
      <div class="text-center p-6 bg-white rounded-xl shadow-md">
        <div class="w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">More Clients</h3>
        <p class="text-gray-600">Connect with thousands of pet owners looking for trusted veterinary services.</p>
      </div>
      
      <div class="text-center p-6 bg-white rounded-xl shadow-md">
        <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <h3 class="text-xl font-semibold text-gray-900 mb-2">Quick Setup</h3>
        <p class="text-gray-600">Simple form submission and we'll have your practice listed within 24-48 hours.</p>
      </div>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Handle day checkbox changes to enable/disable time inputs
      const dayCheckboxes = document.querySelectorAll('.day-checkbox');
      
      dayCheckboxes.forEach(checkbox => {
        checkbox.addEventListener('change', function() {
          const row = this.closest('.flex');
          const timeInputs = row.querySelectorAll('.day-time');
          
          timeInputs.forEach(input => {
            input.disabled = !this.checked;
            if (!this.checked) {
              input.value = '';
            }
          });
        });
      });

      // Form submission handling
      const form = document.getElementById('add-practice-form');
      const submitButton = form.querySelector('button[type="submit"]');
      
      form.addEventListener('submit', function() {
        submitButton.textContent = 'Submitting...';
        submitButton.disabled = true;
      });
    });
  </script>

  <style>
    /* Custom styles for better visual appeal */
    .shadow-card {
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }
    
    input:disabled, select:disabled {
      background-color: #f9fafb;
      cursor: not-allowed;
    }
    
    .day-time:disabled {
      opacity: 0.5;
    }
    
    /* Hover effects for checkboxes */
    label:has(input[type="checkbox"]):hover {
      background-color: #f8fafc;
    }
    
    /* Focus styles */
    input:focus, select:focus, textarea:focus {
      outline: none;
      box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
    }
  </style>
</Layout>
