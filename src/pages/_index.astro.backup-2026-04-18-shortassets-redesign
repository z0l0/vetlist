---
import Layout from '../layouts/Layout.astro';
import { fetchAllProfessionals } from '../lib/supabase';
import { getDefaultOgImageUrl } from '../lib/seo.js';

function isTrue(value) {
  return value === true || value === 'true' || value === 1 || value === '1';
}

function parseArray(value) {
  if (!value) return [];
  if (Array.isArray(value)) return value.filter(Boolean);
  try {
    const parsed = JSON.parse(value);
    return Array.isArray(parsed) ? parsed.filter(Boolean) : [];
  } catch {
    return [];
  }
}

function normalizeToken(value) {
  return String(value || '').trim().toLowerCase().replace(/\s+/g, ' ');
}

function profileLanguages(profile) {
  return parseArray(profile.languages_spoken)
    .map(normalizeToken)
    .filter((lang) => lang && lang !== 'english' && lang !== 'en');
}

const exoticKeywords = ['exotic', 'avian', 'bird', 'reptile', 'amphib', 'rabbit', 'ferret', 'small mammal', 'pocket', 'guinea pig'];

function profilePetTypes(profile) {
  return parseArray(profile.pet_types_served || profile.animals_treated)
    .map(normalizeToken)
    .filter(Boolean);
}

function profileHasExoticCare(profile) {
  const petTypes = profilePetTypes(profile);
  return petTypes.some((item) => exoticKeywords.some((keyword) => item.includes(keyword)));
}

function buildHomepageInsights(profiles) {
  let emergency = 0;
  let emergency24 = 0;
  let onlineBooking = 0;
  let telehealth = 0;
  let digitalAccess = 0;
  let pricing = 0;
  let multilingual = 0;
  let exotic = 0;

  for (const profile of profiles) {
    if (isTrue(profile.emergency_services) || isTrue(profile.emergency_24_hour)) emergency += 1;
    if (isTrue(profile.emergency_24_hour)) emergency24 += 1;
    if (isTrue(profile.online_booking)) onlineBooking += 1;
    if (isTrue(profile.telehealth_available)) telehealth += 1;
    if (isTrue(profile.online_booking) || isTrue(profile.telehealth_available)) digitalAccess += 1;
    if (isTrue(profile.has_pricing)) pricing += 1;

    const languages = profileLanguages(profile);
    if (languages.length) multilingual += 1;
    if (profileHasExoticCare(profile)) exotic += 1;
  }

  return {
    total: profiles.length,
    emergency,
    emergency24,
    onlineBooking,
    telehealth,
    digitalAccess,
    pricing,
    multilingual,
    exotic,
  };
}

const allProfiles = await fetchAllProfessionals();
const totalVets = allProfiles.length;
const uniqueCities = new Set(
  allProfiles
    .filter((profile) => profile.city && profile.province && profile.country)
    .map((profile) => `${profile.city}|${profile.province}|${profile.country}`),
).size;

const usProfiles = allProfiles.filter((profile) => profile.country_slug === 'united-states');
const caProfiles = allProfiles.filter((profile) => profile.country_slug === 'canada');

const regionStats = {};
allProfiles.forEach((profile) => {
  if (!profile.country_slug || !profile.province_slug || !profile.province) return;
  const key = `${profile.country_slug}/${profile.province_slug}`;
  if (!regionStats[key]) {
    regionStats[key] = { country: profile.country_slug, slug: profile.province_slug, name: profile.province, count: 0 };
  }
  regionStats[key].count += 1;
});
const topRegions = Object.values(regionStats).sort((a, b) => b.count - a.count).slice(0, 10);

const cityStats = {};
allProfiles.forEach((profile) => {
  if (!profile.country_slug || !profile.province_slug || !profile.city_slug || !profile.city) return;
  const key = `${profile.country_slug}/${profile.province_slug}/${profile.city_slug}`;
  if (!cityStats[key]) {
    cityStats[key] = {
      country: profile.country_slug,
      region: profile.province_slug,
      slug: profile.city_slug,
      name: profile.city,
      province: profile.province,
      count: 0,
    };
  }
  cityStats[key].count += 1;
});

const topCities = Object.values(cityStats).sort((a, b) => b.count - a.count).slice(0, 14);
const topUsCities = Object.values(cityStats)
  .filter((city) => city.country === 'united-states')
  .sort((a, b) => b.count - a.count)
  .slice(0, 8);
const topCanadaCities = Object.values(cityStats)
  .filter((city) => city.country === 'canada')
  .sort((a, b) => b.count - a.count)
  .slice(0, 8);
const usCityCount = Object.values(cityStats).filter((city) => city.country === 'united-states').length;
const canadaCityCount = Object.values(cityStats).filter((city) => city.country === 'canada').length;

const topScoredClinics = allProfiles
  .filter((profile) => Number.parseFloat(profile.vetscore) > 0 && profile.country_slug && profile.province_slug && profile.city_slug && profile.name_slug)
  .sort((a, b) => (Number.parseFloat(b.vetscore) || 0) - (Number.parseFloat(a.vetscore) || 0))
  .slice(0, 7);

const verifiedClinics = allProfiles
  .filter((profile) =>
    (profile.claimed === true || profile.claimed === 'true' || profile.is_verified === true || profile.is_verified === 'true') &&
    profile.country_slug &&
    profile.province_slug &&
    profile.city_slug &&
    profile.name_slug,
  )
  .sort((a, b) =>
    (Number.parseFloat(b.rating) || 0) - (Number.parseFloat(a.rating) || 0) ||
    (Number.parseFloat(b.vetscore) || 0) - (Number.parseFloat(a.vetscore) || 0),
  )
  .slice(0, 7);

function buildClinicBadge(profile) {
  const rating = Number.parseFloat(profile.rating);
  if (Number.isFinite(rating) && rating > 0 && rating <= 5) {
    return { label: `${rating.toFixed(1)}★`, title: 'Public rating' };
  }

  const score = Number.parseFloat(profile.vetscore);
  if (Number.isFinite(score) && score > 0) {
    return { label: `${Math.round(score)}/100`, title: 'VetScore' };
  }

  return null;
}

const verifiedLane = (verifiedClinics.length ? verifiedClinics : topScoredClinics).map((clinic) => ({
  ...clinic,
  badge: buildClinicBadge(clinic),
}));

const priorityCityPages = topCities.slice(0, 10).map((city) => ({
  cityLabel: `${city.name}, ${city.province}`,
  linkLabel: `Vet clinics in ${city.name}`,
  url: `/${city.country}/${city.region}/${city.slug}/`,
}));

const northAmericaInsights = buildHomepageInsights(allProfiles);

const cityInsightMap = {};
for (const profile of allProfiles) {
  if (!profile.country_slug || !profile.province_slug || !profile.city_slug || !profile.city) continue;
  const key = `${profile.country_slug}/${profile.province_slug}/${profile.city_slug}`;
  if (!cityInsightMap[key]) {
    cityInsightMap[key] = {
      name: profile.city,
      region: profile.province,
      regionSlug: profile.province_slug,
      country: profile.country_slug,
      slug: profile.city_slug,
      total: 0,
      multilingual: 0,
      exotic: 0,
      emergency: 0,
      emergency24: 0,
      onlineBooking: 0,
      telehealth: 0,
      pricing: 0,
    };
  }
  cityInsightMap[key].total += 1;
  if (profileLanguages(profile).length) cityInsightMap[key].multilingual += 1;
  if (profileHasExoticCare(profile)) cityInsightMap[key].exotic += 1;
  if (isTrue(profile.emergency_services) || isTrue(profile.emergency_24_hour)) cityInsightMap[key].emergency += 1;
  if (isTrue(profile.emergency_24_hour)) cityInsightMap[key].emergency24 += 1;
  if (isTrue(profile.online_booking)) cityInsightMap[key].onlineBooking += 1;
  if (isTrue(profile.telehealth_available)) cityInsightMap[key].telehealth += 1;
  if (isTrue(profile.has_pricing)) cityInsightMap[key].pricing += 1;
}

const cityInsights = Object.values(cityInsightMap);
const topExoticCities = cityInsights
  .filter((city) => city.exotic > 0)
  .sort((a, b) => b.exotic - a.exotic)
  .slice(0, 6);
const topMultilingualCities = cityInsights
  .filter((city) => city.multilingual > 0)
  .sort((a, b) => b.multilingual - a.multilingual)
  .slice(0, 6);
const topEmergencyCities = cityInsights
  .filter((city) => city.emergency > 0)
  .sort((a, b) => b.emergency - a.emergency)
  .slice(0, 6);
const topOnlineCities = cityInsights
  .filter((city) => city.onlineBooking > 0 || city.telehealth > 0)
  .map((city) => ({ ...city, digitalAccess: city.onlineBooking + city.telehealth }))
  .sort((a, b) => (b.onlineBooking + b.telehealth) - (a.onlineBooking + a.telehealth))
  .slice(0, 6);
const topPricingCities = cityInsights
  .filter((city) => city.pricing > 0)
  .sort((a, b) => b.pricing - a.pricing)
  .slice(0, 6);

function cityUrl(city) {
  return `/${city.country}/${city.regionSlug || city.region}/${city.slug}/`;
}

function cityName(city) {
  return `${city.name}, ${city.province || city.region}`;
}

function cityLinks(cities, countKey, singularLabel, pluralLabel = `${singularLabel}s`) {
  return (cities.length ? cities : topCities)
    .slice(0, 4)
    .map((city) => ({
      href: cityUrl(city),
      label: cityName(city),
      detail: city[countKey]
        ? `${city[countKey]} ${city[countKey] === 1 ? singularLabel : pluralLabel}`
        : `${city.count.toLocaleString()} clinics`,
    }));
}

const careNeedCards = [
  {
    label: 'Need care now or after hours',
    description: 'These cities have the most clinics listing emergency or 24/7 care. Always call before leaving.',
    href: topEmergencyCities[0] ? cityUrl(topEmergencyCities[0]) : priorityCityPages[0]?.url || '/canada/',
    links: cityLinks(topEmergencyCities, 'emergency', 'emergency option'),
  },
  {
    label: 'Want online booking or telehealth',
    description: 'Look for clinics that list self-serve booking or remote-care options before you pick up the phone.',
    href: topOnlineCities[0] ? cityUrl(topOnlineCities[0]) : priorityCityPages[0]?.url || '/canada/',
    links: cityLinks(topOnlineCities, 'digitalAccess', 'digital access option'),
  },
  {
    label: 'Have an exotic or less-common pet',
    description: 'Look for cities with clinics that mention birds, reptiles, rabbits, farm animals, or other specialty pet types.',
    href: topExoticCities[0] ? cityUrl(topExoticCities[0]) : priorityCityPages[0]?.url || '/canada/',
    links: cityLinks(topExoticCities, 'exotic', 'exotic-care option'),
  },
  {
    label: 'Need language support',
    description: 'Check cities with clinics that list non-English language support before you call.',
    href: topMultilingualCities[0] ? cityUrl(topMultilingualCities[0]) : priorityCityPages[0]?.url || '/canada/',
    links: cityLinks(topMultilingualCities, 'multilingual', 'multilingual option'),
  },
];

const dataProofCards = [
  {
    value: northAmericaInsights.emergency.toLocaleString(),
    label: 'clinics list emergency care',
    detail: topEmergencyCities[0] ? `Start in ${cityName(topEmergencyCities[0])}` : 'Browse emergency signals by city',
    href: topEmergencyCities[0] ? cityUrl(topEmergencyCities[0]) : priorityCityPages[0]?.url || '/canada/',
  },
  {
    value: northAmericaInsights.digitalAccess.toLocaleString(),
    label: 'clinics list online booking or telehealth',
    detail: topOnlineCities[0] ? `Compare ${cityName(topOnlineCities[0])}` : 'Browse digital access by city',
    href: topOnlineCities[0] ? cityUrl(topOnlineCities[0]) : priorityCityPages[0]?.url || '/canada/',
  },
  {
    value: uniqueCities.toLocaleString(),
    label: 'city directories across the U.S. and Canada',
    detail: 'Browse popular city pages',
    href: '#popular-cities',
  },
  {
    value: northAmericaInsights.pricing.toLocaleString(),
    label: 'clinic profiles include pricing details',
    detail: topPricingCities[0] ? `See ${cityName(topPricingCities[0])}` : 'Check pricing fields on profiles',
    href: topPricingCities[0] ? cityUrl(topPricingCities[0]) : priorityCityPages[0]?.url || '/canada/',
  },
];

const pageTitle = 'Find Veterinarians by City | Vet Clinics and Animal Hospitals in U.S. & Canada';
const pageDescription = `Compare ${totalVets.toLocaleString()} vet clinics across the U.S. and Canada, with city pages for hours, phone numbers, emergency care, services, and clinic profiles.`;
const socialImage = getDefaultOgImageUrl();
const openGraphConfig = {
  type: 'website',
  url: 'https://vetlist.org/',
  title: pageTitle,
  description: pageDescription,
  siteName: 'VetList.org',
  locale: 'en_US',
  image: socialImage,
  imageAlt: 'VetList veterinary directory overview',
};
const twitterCardConfig = {
  card: 'summary_large_image',
  title: pageTitle,
  description: pageDescription,
  image: socialImage,
  imageAlt: 'VetList veterinary directory overview',
};

const faqEntries = [
  {
    question: 'How do I find an emergency vet near me?',
    answer: 'Start with your city page and look for emergency, 24/7 emergency, open-now, and phone details. Always call before leaving, especially for urgent symptoms or after-hours care.',
  },
  {
    question: 'How do I know if a vet clinic is open right now?',
    answer: 'City and profile pages use the published hours on each profile to calculate open-now status in your browser from your device time. Hours can change, so call to confirm before visiting.',
  },
  {
    question: 'What should I check before choosing a veterinarian?',
    answer: 'Check the clinic address, phone number, hours, services, emergency availability, pet types treated, and whether online booking or telehealth is listed.',
  },
  {
    question: 'Can I find vets for exotic pets or less-common animals?',
    answer: `Yes. VetList includes ${northAmericaInsights.exotic.toLocaleString()} clinic profiles with specialty or exotic-pet signals, including clinics that mention birds, reptiles, rabbits, farm animals, or other less-common pets.`,
  },
  {
    question: 'Can I find clinics with online booking or telehealth?',
    answer: `Yes. Some profiles include online booking or telehealth fields, and the homepage highlights city pages where those options appear more often.`,
  },
  {
    question: 'What is shown on each clinic profile?',
    answer: 'Profiles focus on practical visit details: phone, website, directions, hours, open-now status, emergency signals, services, pet types, and nearby backup options.',
  },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'VetList.org',
    url: 'https://vetlist.org/',
    description: pageDescription,
    inLanguage: 'en-US',
    potentialAction: {
      '@type': 'SearchAction',
      target: 'https://vetlist.org/?q={search_term_string}',
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'VetList.org',
    url: 'https://vetlist.org/',
    logo: getDefaultOgImageUrl(),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Veterinary Services Directory',
    description: pageDescription,
    url: 'https://vetlist.org/',
    about: ['Veterinary services', 'Vet clinics', 'Animal hospitals', 'Emergency vet care'],
    mainEntity: {
      '@type': 'ItemList',
      name: 'Popular city veterinary pages',
      numberOfItems: priorityCityPages.length,
      itemListOrder: 'https://schema.org/ItemListOrderDescending',
      itemListElement: priorityCityPages.slice(0, 10).map((city, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        item: {
          '@type': 'WebPage',
          name: city.linkLabel,
          url: `https://vetlist.org${city.url}`,
        },
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqEntries.map((entry) => ({
      '@type': 'Question',
      name: entry.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: entry.answer,
      },
    })),
  },
];
---

<Layout title={pageTitle} description={pageDescription} openGraph={openGraphConfig} twitterCard={twitterCardConfig}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </Fragment>

  <div class="mx-auto max-w-7xl py-4 md:py-6">
    <section class="rounded-[24px] border border-slate-200 bg-white px-5 py-5 shadow-[0_14px_36px_rgba(15,23,42,0.08)] md:px-6">
      <h1 class="text-3xl font-black tracking-tight text-slate-950 md:text-4xl">Find a veterinarian by city</h1>
      <p class="mt-2 text-sm leading-7 text-slate-600 md:text-base">
        Compare vet clinics across the U.S. and Canada, with hours, phone numbers, emergency care, services, and full clinic profiles.
      </p>
      <div class="mt-3 flex flex-wrap gap-2 text-xs font-semibold text-slate-700">
        <span class="rounded-full bg-slate-100 px-3 py-1">{usProfiles.length.toLocaleString()} U.S. clinic profiles</span>
        <span class="rounded-full bg-slate-100 px-3 py-1">{caProfiles.length.toLocaleString()} Canadian clinic profiles</span>
        <span class="rounded-full bg-slate-100 px-3 py-1">{uniqueCities.toLocaleString()} city directories</span>
      </div>
    </section>

    <section id="popular-cities" class="mt-4 overflow-hidden rounded-[28px] border border-cyan-800/40 bg-[linear-gradient(130deg,#004b93_0%,#05589f_45%,#1f7cbc_100%)] p-4 md:p-6 shadow-[0_24px_58px_rgba(2,27,54,0.28)]">
      <div class="grid gap-4 lg:grid-cols-3">
        <div class="rounded-3xl border border-white/15 bg-white/10 p-4 backdrop-blur">
          <div class="mb-3 flex items-center justify-between rounded-full border border-cyan-200/30 bg-blue-400/25 px-4 py-2 text-sm font-semibold text-white">
            <span>🇺🇸 Popular US Cities</span>
            <span class="text-xs text-cyan-100">{usCityCount.toLocaleString()} total city pages</span>
          </div>
          <div class="space-y-2">
            {topUsCities.map((city) => (
              <a href={`/${city.country}/${city.region}/${city.slug}/`} class="block rounded-2xl bg-white/90 px-4 py-3 text-slate-900 transition hover:bg-white">
                <span class="block text-base font-semibold leading-tight">{city.name}</span>
                <span class="mt-1 block text-sm text-slate-600">{city.province} · {city.count.toLocaleString()} clinics listed</span>
              </a>
            ))}
            <a href="/united-states/" class="flex items-center justify-between rounded-2xl border border-white/30 bg-white/10 px-4 py-3 text-white transition hover:bg-white/15">
              <span>
                <span class="block text-xs font-semibold uppercase tracking-[0.12em] text-cyan-100">Browse all</span>
                <span class="block text-base font-semibold">United States regions and cities</span>
              </span>
              <span class="text-lg">→</span>
            </a>
          </div>
        </div>

        <div class="rounded-3xl border border-white/15 bg-white/10 p-4 backdrop-blur">
          <div class="mb-3 flex items-center justify-between rounded-full border border-red-200/35 bg-red-400/25 px-4 py-2 text-sm font-semibold text-white">
            <span>🇨🇦 Popular Canadian Cities</span>
            <span class="text-xs text-red-100">{canadaCityCount.toLocaleString()} total city pages</span>
          </div>
          <div class="space-y-2">
            {topCanadaCities.map((city) => (
              <a href={`/${city.country}/${city.region}/${city.slug}/`} class="block rounded-2xl bg-white/90 px-4 py-3 text-slate-900 transition hover:bg-white">
                <span class="block text-base font-semibold leading-tight">{city.name}</span>
                <span class="mt-1 block text-sm text-slate-600">{city.province} · {city.count.toLocaleString()} clinics listed</span>
              </a>
            ))}
            <a href="/canada/" class="flex items-center justify-between rounded-2xl border border-white/30 bg-white/10 px-4 py-3 text-white transition hover:bg-white/15">
              <span>
                <span class="block text-xs font-semibold uppercase tracking-[0.12em] text-cyan-100">Browse all</span>
                <span class="block text-base font-semibold">Canada provinces and cities</span>
              </span>
              <span class="text-lg">→</span>
            </a>
          </div>
        </div>

        <div id="popular-vets" class="rounded-3xl border border-white/15 bg-white/10 p-4 backdrop-blur">
          <div class="mb-3 flex items-center justify-between rounded-full border border-emerald-200/30 bg-emerald-400/25 px-4 py-2 text-sm font-semibold text-white">
            <span>⭐ Verified Clinics</span>
            <span class="text-xs text-emerald-100">{verifiedLane.length} picks</span>
          </div>
          <div class="space-y-2">
            {verifiedLane.map((clinic) => (
              <a href={`/${clinic.country_slug}/${clinic.province_slug}/${clinic.city_slug}/${clinic.name_slug}/`} class="flex items-center justify-between gap-3 rounded-2xl bg-white/90 px-4 py-3 text-slate-900 transition hover:bg-white">
                <span class="min-w-0">
                  <span class="block text-xs font-semibold uppercase tracking-[0.12em] text-emerald-700">Verified profile</span>
                  <span class="block truncate text-base font-semibold leading-tight">{clinic.name}</span>
                  <span class="block truncate text-sm text-slate-600">{clinic.city}, {clinic.province}</span>
                </span>
                {clinic.badge && (
                  <span class="shrink-0 rounded-xl bg-amber-300 px-2 py-1 text-sm font-bold text-slate-900" title={clinic.badge.title}>{clinic.badge.label}</span>
                )}
              </a>
            ))}
            <a href="/add-vet/" class="mt-2 flex items-center justify-center rounded-2xl border-2 border-emerald-300/60 bg-white/90 px-4 py-3 text-base font-semibold text-slate-800 transition hover:bg-white">
              + Add Your Clinic
            </a>
          </div>
        </div>
      </div>

    </section>

    <section class="mt-6 rounded-[24px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
      <div class="mb-4">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Start With The Need</p>
        <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950">Find a clinic by what matters for the visit</h2>
        <p class="mt-2 text-sm leading-7 text-slate-600">
          Thousands of clinics list details like emergency care, hours, online booking, telehealth, pet types, and language support. Start with what matters most for your visit.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-2">
        {careNeedCards.map((card) => (
          <article class="rounded-[24px] border border-slate-300/70 bg-white p-5 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
            <h3 class="text-xl font-black text-slate-950">{card.label}</h3>
            <p class="mt-2 text-sm leading-7 text-slate-600">{card.description}</p>
            <div class="mt-4 grid gap-2">
              {card.links.map((link) => (
                <a href={link.href} class="flex items-center justify-between gap-3 rounded-xl bg-slate-50 px-3 py-2 text-sm transition hover:bg-slate-100">
                  <span class="font-semibold text-slate-900">{link.label}</span>
                  <span class="shrink-0 text-xs font-semibold text-slate-500">{link.detail}</span>
                </a>
              ))}
            </div>
          </article>
        ))}
      </div>

      <div class="mt-5 rounded-[22px] border border-slate-200 bg-slate-50 p-4 md:p-5">
        <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Directory Depth</p>
            <h3 class="mt-1 text-2xl font-black tracking-tight text-slate-950">What you can compare across clinics</h3>
          </div>
          <p class="max-w-2xl text-sm leading-7 text-slate-600">
            A few of the fields VetList uses to help people choose where to call first.
          </p>
        </div>
        <div class="mt-4 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
          {dataProofCards.map((card) => (
            <a href={card.href} class="rounded-2xl border border-slate-200 bg-white p-4 transition hover:border-slate-300 hover:shadow-[0_12px_28px_rgba(15,23,42,0.08)]">
              <span class="block text-3xl font-black tracking-tight text-slate-950">{card.value}</span>
              <span class="mt-1 block text-sm font-bold leading-6 text-slate-900">{card.label}</span>
              <span class="mt-2 block text-xs font-semibold text-slate-500">{card.detail}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="mt-6 grid gap-4 lg:grid-cols-2">
      <div class="rounded-[24px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
        <h2 class="text-2xl font-black tracking-tight text-slate-950">Browse by region</h2>
        <div class="mt-4 grid gap-2">
          {topRegions.map((region) => (
            <a href={`/${region.country}/${region.slug}/`} class="flex items-center justify-between rounded-xl bg-slate-50 px-4 py-3 text-sm transition hover:bg-slate-100">
              <span class="font-semibold text-slate-900">{region.name}</span>
              <span class="text-slate-500">{region.count.toLocaleString()} clinics</span>
            </a>
          ))}
        </div>
      </div>

      <div class="rounded-[24px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
        <h2 class="text-2xl font-black tracking-tight text-slate-950">Browse by city</h2>
        <div class="mt-4 grid gap-2">
          {topCities.slice(0, 10).map((city) => (
            <a href={`/${city.country}/${city.region}/${city.slug}/`} class="flex items-center justify-between rounded-xl bg-slate-50 px-4 py-3 text-sm transition hover:bg-slate-100">
              <span class="font-semibold text-slate-900">{city.name}, {city.province}</span>
              <span class="text-slate-500">{city.count.toLocaleString()} clinics</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="mt-6 rounded-[24px] border border-slate-300/70 bg-white p-6 shadow-[0_20px_48px_rgba(15,23,42,0.10)]">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">FAQ</p>
      <h2 class="mt-2 text-3xl font-black tracking-tight text-slate-950">Questions people ask before choosing a vet</h2>
      <div class="mt-4 grid gap-3">
        {faqEntries.map((entry) => (
          <details class="rounded-2xl bg-slate-50 px-4 py-3">
            <summary class="cursor-pointer text-sm font-semibold text-slate-900">{entry.question}</summary>
            <p class="mt-2 text-sm leading-7 text-slate-600">{entry.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </div>
</Layout>
