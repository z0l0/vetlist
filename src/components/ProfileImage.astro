---
interface Props {
  picture?: string;
  name: string;
  rating?: number;
  claimed?: boolean;
  class?: string;
}

const { picture, name, rating, claimed = false, class: className = "w-80 h-80" } = Astro.props;
---

<div class={`relative ${className} flex-shrink-0`}>
  {claimed && (
    <div class="absolute top-4 left-4 z-20">
      <div class="flex items-center gap-2 rounded-full border border-emerald-200 bg-white/95 px-3 py-2 text-xs font-bold uppercase tracking-[0.14em] text-emerald-800 shadow-sm backdrop-blur">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.25"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
          <path d="m9 12 2 2 4-4"/>
        </svg>
        <span>Claimed</span>
      </div>
    </div>
  )}

  {rating !== null && rating !== undefined && (
    <div class="absolute right-4 top-4 z-10 rounded-full bg-white/95 px-3 py-2 text-sm font-bold text-slate-950 shadow-sm backdrop-blur">
      {rating.toFixed(1)} / 5
    </div>
  )}

  <div class="relative w-full h-full">
    <div class="w-full h-full bg-primary-100 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600">
        <path d="M12 6v4"/>
        <path d="M14 14h-4"/>
        <path d="M14 18h-4"/>
        <path d="M14 8h-4"/>
        <path d="M18 12h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-9a2 2 0 0 1 2-2h2"/>
        <path d="M18 22V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v18"/>
      </svg>
    </div>
    {picture && (
      <img 
        src={picture} 
        alt={`${name} veterinary clinic`}
        class="absolute inset-0 w-full h-full object-cover"
        width="640"
        height="420"
        decoding="async"
        fetchpriority="high"
      />
    )}
  </div>
</div>
