---
interface Props {
  picture?: string;
  name: string;
  rating?: number;
  class?: string;
}

const { picture, name, rating, class: className = "w-80 h-80" } = Astro.props;
---

<div class={`relative ${className} flex-shrink-0`}>
  {rating !== null && rating !== undefined && (
    <div class="absolute top-4 right-4 bg-white py-1 px-3 rounded-full shadow-sm z-10 flex items-center">
      <span class="font-semibold mr-1">{rating.toFixed(1)}</span>
      <div class="flex">
        {Array.from({ length: 5 }, (_, i) => (
          <svg class={`w-4 h-4 ${i < Math.floor(rating) ? 'text-yellow-400' : 'text-gray-300'}`} fill="currentColor" viewBox="0 0 24 24">
            <path fill-rule="evenodd" d="M10.788 3.21c.448-1.077 1.976-1.077 2.424 0l2.082 5.007 5.404.433c1.164.093 1.636 1.545.749 2.305l-4.117 3.527 1.257 5.273c.271 1.136-.964 2.033-1.96 1.425L12 18.354 7.373 21.18c-.996.608-2.231-.29-1.96-1.425l1.257-5.273-4.117-3.527c-.887-.76-.415-2.212.749-2.305l5.404-.433 2.082-5.006z" clip-rule="evenodd" />
          </svg>
        ))}
      </div>
    </div>
  )}
  
  <div class="relative w-full h-full">
    <div class="w-full h-full bg-primary-100 flex items-center justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600">
        <path d="M12 6v4"/>
        <path d="M14 14h-4"/>
        <path d="M14 18h-4"/>
        <path d="M14 8h-4"/>
        <path d="M18 12h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-9a2 2 0 0 1 2-2h2"/>
        <path d="M18 22V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v18"/>
      </svg>
    </div>
    {picture && (
      <img 
        src={picture} 
        alt={`${name} veterinary clinic`}
        class="absolute inset-0 w-full h-full object-cover"
        onerror="this.style.display='none'"
      />
    )}
  </div>
</div>