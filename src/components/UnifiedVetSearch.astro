---
// Unified Vet Search Component with Geo Search
---

<div class="relative">
  <!-- Search Input -->
  <div class="relative">
    <input 
      type="text" 
      id="unified-vet-search"
      placeholder="Search vets, specialties, or locations (e.g., 'Emergency vet Miami')"
      class="w-full px-4 py-3 pr-12 border border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-gray-800 placeholder-gray-500"
      autocomplete="off"
    />
    

    
    <!-- Search Icon -->
    <div class="absolute right-3 top-1/2 transform -translate-y-1/2 text-primary-600">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" />
      </svg>
    </div>
  </div>
  
  <!-- Search Type Indicator -->
  <div id="search-type-indicator" class="hidden mt-2 text-xs text-gray-600">
    <span id="search-type-text"></span>
  </div>
</div>

<script>
  // Initialize unified vet search
  async function initializeUnifiedVetSearch() {
    if (typeof window === 'undefined') return;
    
    try {
      // Import Algolia dynamically
      const { default: algoliasearch } = await import('algoliasearch/lite');
      console.log('Algolia loaded for unified search');
      
      // Initialize Algolia client and index
      const appId = 'G13RPGTX1B';
      const apiKey = '3733aa7e0b81cfc61dc8e4122fe93c6a';
      const indexName = 'vetlist_locations';
      
      const algoliaClient = algoliasearch(appId, apiKey);
      const index = algoliaClient.initIndex(indexName);
      
      // Get DOM elements
      const searchInput = document.getElementById('unified-vet-search') as HTMLInputElement;
      const searchTypeIndicator = document.getElementById('search-type-indicator');
      const searchTypeText = document.getElementById('search-type-text');
      
      if (!searchInput) return;
      

      
      // Create dropdown containers
      const dropdownContainer = document.createElement('div');
      dropdownContainer.className = 'fixed inset-0 pointer-events-none z-[9999]';
      dropdownContainer.innerHTML = `
        <!-- Search Results Dropdown -->
        <div id="unified-search-results" class="hidden absolute bg-white border border-gray-200 rounded-lg shadow-xl max-h-80 overflow-y-auto pointer-events-auto">
        </div>
        
        <!-- Loading indicator -->
        <div id="unified-loading" class="hidden absolute bg-white border border-gray-200 rounded-lg shadow-xl p-4 pointer-events-auto">
          <div class="flex items-center gap-2 text-gray-500 text-sm">
            <div class="animate-spin w-4 h-4 border-2 border-primary-500 border-t-transparent rounded-full"></div>
            <span id="loading-text">Searching...</span>
          </div>
        </div>
        
        <!-- No results message -->
        <div id="unified-no-results" class="hidden absolute bg-white border border-gray-200 rounded-lg shadow-xl p-4 pointer-events-auto">
          <div class="text-gray-500 text-sm">
            <div class="flex items-center gap-2 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75l-2.489-2.489m0 0a3.375 3.375 0 10-4.773-4.773 3.375 3.375 0 004.774 4.774zM21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              No results found
            </div>
            <p>Try a different search term or check spelling.</p>
          </div>
        </div>
      `;
      document.body.appendChild(dropdownContainer);
      
      const resultsContainer = document.getElementById('unified-search-results');
      const loadingIndicator = document.getElementById('unified-loading');
      const noResultsMessage = document.getElementById('unified-no-results');
      const loadingText = document.getElementById('loading-text');
      
      // Position dropdown relative to input
      function positionDropdown(element: HTMLElement) {
        if (!element || !searchInput) return;
        
        const inputRect = searchInput.getBoundingClientRect();
        element.style.left = inputRect.left + 'px';
        element.style.top = (inputRect.bottom + 8) + 'px';
        element.style.width = inputRect.width + 'px';
      }
      
      // Hide all dropdowns
      function hideAllDropdowns() {
        resultsContainer?.classList.add('hidden');
        loadingIndicator?.classList.add('hidden');
        noResultsMessage?.classList.add('hidden');
        searchTypeIndicator?.classList.add('hidden');
      }
      
      // Show loading with custom message
      function showLoading(message = 'Searching...') {
        hideAllDropdowns();
        if (loadingIndicator && loadingText) {
          loadingText.textContent = message;
          positionDropdown(loadingIndicator);
          loadingIndicator.classList.remove('hidden');
        }
      }
      
      // Show search type indicator
      function showSearchType(type: string) {
        if (searchTypeIndicator && searchTypeText) {
          searchTypeText.textContent = type;
          searchTypeIndicator.classList.remove('hidden');
        }
      }
      

      
      // Show search results
      function showResults(hits: any[]) {
        hideAllDropdowns();
        
        if (hits.length === 0) {
          if (noResultsMessage) {
            positionDropdown(noResultsMessage);
            noResultsMessage.classList.remove('hidden');
          }
          return;
        }
        
        if (resultsContainer) {
          resultsContainer.innerHTML = hits.map((hit: any) => {
            // Format specializations
            const specializations = hit.specializations || [];
            const displaySpecializations = specializations.slice(0, 3).join(', ');
            const moreCount = specializations.length > 3 ? ` +${specializations.length - 3} more` : '';
            

            
            // Rating display
            const rating = hit.rating ? `${hit.rating}⭐` : '';
            
            // Use the URL from Algolia index (which now has the correct format)
            const vetUrl = hit.url || '#';
            
            return `
              <a href="${vetUrl}/" class="block px-4 py-3 hover:bg-gray-50 border-b border-gray-100 last:border-b-0 transition-colors">
                <div class="flex items-start gap-3">
                  <div class="flex-shrink-0 w-10 h-10 relative">
                    <div class="w-full h-full rounded-lg bg-primary-100 flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600">
                        <path d="M12 6v4"/>
                        <path d="M14 14h-4"/>
                        <path d="M14 18h-4"/>
                        <path d="M14 8h-4"/>
                        <path d="M18 12h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-9a2 2 0 0 1 2-2h2"/>
                        <path d="M18 22V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v18"/>
                      </svg>
                    </div>
                    ${hit.picture ? 
                      `<img src="${hit.picture}" alt="${hit.name}" class="absolute inset-0 w-full h-full rounded-lg object-cover" onerror="this.style.display='none'" />` :
                      ''
                    }
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <h3 class="font-medium text-sm text-gray-900 truncate">${hit._highlightResult?.name?.value || hit.name}</h3>
                      ${rating ? `<span class="text-xs text-yellow-600">${rating}</span>` : ''}
                    </div>
                    <p class="text-xs text-gray-600 mb-1">${hit._highlightResult?.location?.value || hit.location}</p>
                    ${displaySpecializations ? 
                      `<p class="text-xs text-gray-500 truncate">${displaySpecializations}${moreCount}</p>` : ''
                    }
                  </div>
                </div>
              </a>
            `;
          }).join('');
          
          positionDropdown(resultsContainer);
          resultsContainer.classList.remove('hidden');
        }
      }
      

      
      // Perform search
      async function performSearch(query: string) {
        if (query.length < 2) {
          hideAllDropdowns();
          return;
        }
        
        try {
          const searchOptions: any = {
            hitsPerPage: 15,
            attributesToRetrieve: [
              'name', 'location', 'specializations', 'rating', 
              'picture', 'city', 'province', 'country', 'url'
            ],
            attributesToHighlight: ['name', 'location', 'specializations'],
            typoTolerance: true,
            minWordSizefor1Typo: 4,
            minWordSizefor2Typos: 8,
          };
          
          showLoading('Searching vets...');
          showSearchType(`🔍 Text search: "${query}"`);
          
          console.log('Search query:', query, 'Options:', searchOptions);
          
          const searchResult = await index.search(query, searchOptions);
          const hits = searchResult.hits || [];
          
          console.log('Search results:', hits.length, 'hits');
          showResults(hits);
          
        } catch (error) {
          console.error('Search error:', error);
          hideAllDropdowns();
        }
      }
      

      
      // Handle input events
      let searchTimeout: NodeJS.Timeout;
      searchInput.addEventListener('input', function() {
        const query = this.value.trim();
        
        clearTimeout(searchTimeout);
        
        searchTimeout = setTimeout(() => {
          performSearch(query);
        }, 300);
      });
      
      // Handle keyboard events
      searchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          hideAllDropdowns();
          this.blur();
        }
      });
      
      // Handle focus
      searchInput.addEventListener('focus', function() {
        const query = this.value.trim();
        if (query.length >= 2) {
          performSearch(query);
        }
      });
      
      // Hide results when clicking outside
      document.addEventListener('click', function(e) {
        if (!searchInput.contains(e.target as Node) && 
            !resultsContainer?.contains(e.target as Node) &&
            !loadingIndicator?.contains(e.target as Node) &&
            !noResultsMessage?.contains(e.target as Node)) {
          hideAllDropdowns();
        }
      });
      
      // Reposition on scroll/resize
      function repositionVisibleDropdown() {
        if (!resultsContainer?.classList.contains('hidden')) {
          positionDropdown(resultsContainer);
        }
        if (!loadingIndicator?.classList.contains('hidden')) {
          positionDropdown(loadingIndicator);
        }
        if (!noResultsMessage?.classList.contains('hidden')) {
          positionDropdown(noResultsMessage);
        }
      }
      
      window.addEventListener('scroll', repositionVisibleDropdown);
      window.addEventListener('resize', repositionVisibleDropdown);
      
    } catch (error) {
      console.error('Failed to initialize unified search:', error);
    }
  }
  
  // Initialize when DOM is ready
  document.addEventListener('DOMContentLoaded', function() {
    setTimeout(() => {
      initializeUnifiedVetSearch();
    }, 100);
  });
</script>