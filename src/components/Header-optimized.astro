---
const pathname = Astro.url.pathname;
const pathSegments = pathname.split("/").filter(Boolean);

let pageType = "homepage";
let searchPlaceholder = "Search vets, specialties, locations...";

if (pathSegments.length === 1) {
  pageType = "country";
  searchPlaceholder = "Search regions...";
} else if (pathSegments.length === 2) {
  pageType = "region";
  const regionName = pathSegments[1].replace(/-/g, " ").replace(/\b\w/g, l => l.toUpperCase());
  searchPlaceholder = `Search cities in ${regionName}`;
} else if (pathSegments.length === 3) {
  pageType = "city";
  const cityName = pathSegments[2].replace(/-/g, " ").replace(/\b\w/g, l => l.toUpperCase());
  searchPlaceholder = `Search veterinarians in ${cityName}`;
}
---

<header class="sticky top-0 z-50 bg-white shadow-sm">
  <div class="container mx-auto px-4 md:px-8 lg:px-12">
    <div class="flex items-center gap-4 py-3">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 flex-shrink-0">
        <div class="text-primary-600">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
            <circle cx="11" cy="4" r="2"></circle>
            <circle cx="18" cy="8" r="2"></circle>
            <circle cx="20" cy="16" r="2"></circle>
            <path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"></path>
          </svg>
        </div>
        <span class="text-xl font-bold text-primary-700 hidden sm:block">VetList</span>
        <span class="text-lg font-bold text-primary-700 sm:hidden">VL</span>
      </a>

      <!-- Simple Search -->
      <div class="flex-1 mx-4 relative">
        <input
          type="text"
          id="search"
          placeholder={searchPlaceholder}
          class="w-full px-4 py-2.5 pr-12 border-2 border-gray-200 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-gray-800 placeholder-gray-500 bg-gray-50 focus:bg-white transition-colors"
          data-page-type={pageType}
        />
        <div class="absolute right-3 top-1/2 -translate-y-1/2 text-primary-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"></path>
          </svg>
        </div>
      </div>

      <!-- Menu Button -->
      <button id="menu-btn" class="p-2 rounded-md hover:bg-gray-100 transition-colors" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Simple Menu -->
  <div id="menu" class="hidden absolute top-full left-0 right-0 bg-white border-t shadow-lg z-40">
    <nav class="container mx-auto px-4 py-4 space-y-2">
      <a href="/add-vet" class="block px-4 py-2 text-orange-600 font-medium hover:bg-orange-50 rounded">Add Your Clinic</a>
      <a href="/claim-clinic" class="block px-4 py-2 text-blue-600 font-medium hover:bg-blue-50 rounded">Claim Your Clinic</a>
      <a href="/canada" class="block px-4 py-2 hover:bg-gray-50 rounded">🇨🇦 Browse Canadian Vets</a>
      <a href="/united-states" class="block px-4 py-2 hover:bg-gray-50 rounded">🇺🇸 Browse American Vets</a>
      <a href="/contact" class="block px-4 py-2 hover:bg-gray-50 rounded">Contact Us</a>
    </nav>
  </div>
</header>

<script>
  // Simple menu toggle
  const menuBtn = document.getElementById('menu-btn');
  const menu = document.getElementById('menu');
  
  menuBtn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });

  // Close menu when clicking outside
  document.addEventListener('click', (e) => {
    if (!menuBtn?.contains(e.target) && !menu?.contains(e.target)) {
      menu?.classList.add('hidden');
    }
  });

  // Simple search functionality for location pages
  const searchInput = document.getElementById('search');
  const pageType = searchInput?.dataset.pageType;
  
  if (searchInput && ['country', 'region', 'city'].includes(pageType)) {
    let searchTimeout;
    
    searchInput.addEventListener('input', function() {
      const query = this.value.toLowerCase().trim();
      
      clearTimeout(searchTimeout);
      searchTimeout = setTimeout(() => {
        const items = document.querySelectorAll('[role="listitem"], .profile-card, .searchable-item');
        
        items.forEach(item => {
          const text = item.textContent.toLowerCase();
          const searchName = item.dataset.searchName?.toLowerCase() || '';
          const regionName = item.dataset.regionName?.toLowerCase() || '';
          const cityName = item.dataset.cityName?.toLowerCase() || '';
          
          const matches = text.includes(query) || searchName.includes(query) || 
                         regionName.includes(query) || cityName.includes(query);
          
          item.style.display = matches || !query ? '' : 'none';
        });
      }, 200);
    });
  }
</script>