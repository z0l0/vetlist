---
export interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  items?: BreadcrumbItem[];
  path?: string;
  className?: string;
}

const { items, path, className = '' } = Astro.props;

const breadcrumbItems = items || (() => {
  if (!path) return [];

  const segments = path.split('/').filter(Boolean);
  let currentPath = '';

  function toTitleCase(str: string) {
    if (str === 'united-states') return 'United States';
    return str
      .replace(/-/g, ' ')
      .split(' ')
      .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
      .join(' ');
  }

  const generatedItems: BreadcrumbItem[] = [{ label: 'Home', href: '/' }];

  segments.forEach((segment) => {
    currentPath += `/${segment}`;
    generatedItems.push({
      label: toTitleCase(segment),
      href: `${currentPath}/`,
    });
  });

  return generatedItems;
})();
---

{
  breadcrumbItems.length > 0 && (
    <nav aria-label="Breadcrumb" class={`overflow-x-auto ${className}`}>
      <ol class="flex min-w-max items-center gap-2 rounded-full border border-slate-200/80 bg-white/78 px-3 py-2 text-sm text-slate-500 shadow-[0_10px_30px_rgba(15,23,42,0.08)] backdrop-blur">
        {breadcrumbItems.map((item, index) => {
          const isLast = index === breadcrumbItems.length - 1;

          return (
            <>
              <li class="flex-shrink-0">
                {isLast ? (
                  <span class="font-semibold text-slate-950">{item.label}</span>
                ) : (
                  <a href={item.href} class="transition hover:text-cyan-700">
                    {item.label}
                  </a>
                )}
              </li>

              {!isLast && (
                <li class="flex-shrink-0 text-slate-300" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
                    <path fill-rule="evenodd" d="M7.22 4.22a.75.75 0 011.06 0l5.25 5.25a.75.75 0 010 1.06l-5.25 5.25a.75.75 0 11-1.06-1.06L11.94 10 7.22 5.28a.75.75 0 010-1.06z" clip-rule="evenodd" />
                  </svg>
                </li>
              )}
            </>
          );
        })}
      </ol>
    </nav>
  )
}
