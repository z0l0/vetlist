---
export interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  items?: BreadcrumbItem[];
  path?: string;
}

const { items, path } = Astro.props;

const breadcrumbItems = items || (() => {
  if (!path) return [];
  
  const segments = path.split('/').filter(Boolean);
  let currentPath = '';
  
  function toTitleCase(str: string) {
    if (str === 'united-states') return 'United States';
    return str.replace(/-/g, ' ')
      .split(' ')
      .map(word => word.charAt(0).toUpperCase() + word.slice(1))
      .join(' ');
  }
  
  const generatedItems: BreadcrumbItem[] = [
    { label: "Home", href: "/" }
  ];
  
  segments.forEach((segment) => {
    currentPath += `/${segment}`;
    generatedItems.push({
      label: toTitleCase(segment),
      href: currentPath
    });
  });
  
  return generatedItems;
})();
---

<nav aria-label="Breadcrumb" class="py-2">
  <div class="overflow-x-auto scrollbar-hide">
    <ol class="flex items-center gap-1 text-sm whitespace-nowrap min-w-max">
      {breadcrumbItems.map((item, index) => (
        <>
          <li class="flex-shrink-0">
            <a 
              href={item.href} 
              class={`hover:text-primary-600 ${index === breadcrumbItems.length - 1 ? 'font-medium text-red-600' : 'text-gray-600'}`}
            >
              {item.label}
            </a>
          </li>
          
          {index !== breadcrumbItems.length - 1 && (
            <li class="text-gray-400 flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-3 h-3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
              </svg>
            </li>
          )}
        </>
      ))}
    </ol>
  </div>
</nav>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;  /* Internet Explorer 10+ */
    scrollbar-width: none;  /* Firefox */
  }
  .scrollbar-hide::-webkit-scrollbar { 
    display: none;  /* Safari and Chrome */
  }
</style>