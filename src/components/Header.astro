<script>
  // Header Vet Search functionality
  async function initializeHeaderVetSearch() {
    if (typeof window === "undefined") return;

    try {
      // Get DOM elements
      const searchInput = document.getElementById(
        "header-vet-search",
      ) as HTMLInputElement;

      if (!searchInput) return;

      // Get page context from data attributes
      const pageType = searchInput.dataset.pageType;
      const searchType = searchInput.dataset.searchType;
      const country = searchInput.dataset.country;
      const region = searchInput.dataset.region;
      const city = searchInput.dataset.city;

      console.log("Header search initialized for:", {
        pageType,
        searchType,
        country,
        region,
        city,
      });

      // For location pages, use local search instead of Algolia
      if (["country", "region", "city"].includes(pageType)) {
        initializeLocationSearch(searchInput, pageType, {
          country,
          region,
          city,
        });
        return;
      }

      // For homepage, use Algolia search
      const { default: algoliasearch } = await import("algoliasearch/lite");
      console.log("Algolia loaded for header search");

      // Initialize Algolia client and index
      const appId = "G13RPGTX1B";
      const apiKey = "3733aa7e0b81cfc61dc8e4122fe93c6a";
      const indexName = "vetlist_locations";

      const algoliaClient = algoliasearch(appId, apiKey);
      const index = algoliaClient.initIndex(indexName);

      // Create dropdown containers with higher z-index for header
      const dropdownContainer = document.createElement("div");
      dropdownContainer.className =
        "fixed inset-0 pointer-events-none z-[9999]";
      dropdownContainer.innerHTML = `
        <!-- Search Results Dropdown -->
        <div id="header-search-results" class="hidden absolute bg-white border border-gray-200 rounded-lg shadow-2xl max-h-80 overflow-y-auto pointer-events-auto">
        </div>
        
        <!-- Loading indicator -->
        <div id="header-loading" class="hidden absolute bg-white border border-gray-200 rounded-lg shadow-2xl p-4 pointer-events-auto">
          <div class="flex items-center gap-2 text-gray-500 text-sm">
            <div class="animate-spin w-4 h-4 border-2 border-primary-500 border-t-transparent rounded-full"></div>
            <span id="header-loading-text">Searching...</span>
          </div>
        </div>
        
        <!-- No results message -->
        <div id="header-no-results" class="hidden absolute bg-white border border-gray-200 rounded-lg shadow-2xl p-4 pointer-events-auto">
          <div class="text-gray-500 text-sm">
            <div class="flex items-center gap-2 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75l-2.489-2.489m0 0a3.375 3.375 0 10-4.773-4.773 3.375 3.375 0 004.774 4.774zM21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              No results found
            </div>
            <p>Try a different search term or check spelling.</p>
          </div>
        </div>
      `;
      document.body.appendChild(dropdownContainer);

      const resultsContainer = document.getElementById("header-search-results");
      const loadingIndicator = document.getElementById("header-loading");
      const noResultsMessage = document.getElementById("header-no-results");
      const loadingText = document.getElementById("header-loading-text");

      // Position dropdown relative to input
      function positionDropdown(element: HTMLElement) {
        if (!element || !searchInput) return;

        const inputRect = searchInput.getBoundingClientRect();
        element.style.left = inputRect.left + "px";
        element.style.top = inputRect.bottom + 8 + "px";
        element.style.width = inputRect.width + "px";
      }

      // Hide all dropdowns
      function hideAllDropdowns() {
        resultsContainer?.classList.add("hidden");
        loadingIndicator?.classList.add("hidden");
        noResultsMessage?.classList.add("hidden");
      }

      // Show loading with custom message
      function showLoading(message = "Searching...") {
        hideAllDropdowns();
        if (loadingIndicator && loadingText) {
          loadingText.textContent = message;
          positionDropdown(loadingIndicator);
          loadingIndicator.classList.remove("hidden");
        }
      }

      // Show search results
      function showResults(hits: any[]) {
        hideAllDropdowns();

        if (hits.length === 0) {
          if (noResultsMessage) {
            positionDropdown(noResultsMessage);
            noResultsMessage.classList.remove("hidden");
          }
          return;
        }

        if (resultsContainer) {
          resultsContainer.innerHTML = hits
            .map((hit: any) => {
              // Format specializations
              const specializations = hit.specializations || [];
              const displaySpecializations = specializations
                .slice(0, 2)
                .join(", ");
              const moreCount =
                specializations.length > 2
                  ? ` +${specializations.length - 2} more`
                  : "";

              // Rating display
              const rating = hit.rating ? `${hit.rating}⭐` : "";

              return `
              <a href="${hit.url ? hit.url + '/' : '#'}" class="block px-4 py-3 hover:bg-gray-50 border-b border-gray-100 last:border-b-0 transition-colors">
                <div class="flex items-start gap-3">
                  <div class="flex-shrink-0 w-10 h-10 relative">
                    <div class="w-full h-full rounded-lg bg-primary-100 flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600">
                        <path d="M12 6v4"/>
                        <path d="M14 14h-4"/>
                        <path d="M14 18h-4"/>
                        <path d="M14 8h-4"/>
                        <path d="M18 12h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-9a2 2 0 0 1 2-2h2"/>
                        <path d="M18 22V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v18"/>
                      </svg>
                    </div>
                    ${
                      hit.picture
                        ? `<img src="${hit.picture}" alt="${hit.name}" class="absolute inset-0 w-full h-full rounded-lg object-cover" onerror="this.style.display='none'" />`
                        : ""
                    }
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <h3 class="font-medium text-sm text-gray-900 truncate">${hit._highlightResult?.name?.value || hit.name}</h3>
                      ${rating ? `<span class="text-xs text-yellow-600">${rating}</span>` : ""}
                    </div>
                    <p class="text-xs text-gray-600 mb-1">${hit._highlightResult?.location?.value || hit.location}</p>
                    ${
                      displaySpecializations
                        ? `<p class="text-xs text-gray-500 truncate">${displaySpecializations}${moreCount}</p>`
                        : ""
                    }
                  </div>
                </div>
              </a>
            `;
            })
            .join("");

          positionDropdown(resultsContainer);
          resultsContainer.classList.remove("hidden");
        }
      }

      // Perform search
      async function performSearch(query: string) {
        if (query.length < 2) {
          hideAllDropdowns();
          return;
        }

        try {
          const searchOptions: any = {
            hitsPerPage: 12,
            attributesToRetrieve: [
              "name",
              "location",
              "specializations",
              "rating",
              "picture",
              "city",
              "province",
              "country",
              "url",
            ],
            attributesToHighlight: ["name", "location", "specializations"],
            typoTolerance: true,
            minWordSizefor1Typo: 4,
            minWordSizefor2Typos: 8,
          };

          showLoading("Searching vets...");

          console.log("Header search query:", query);

          const searchResult = await index.search(query, searchOptions);
          const hits = searchResult.hits || [];

          console.log("Header search results:", hits.length, "hits");
          showResults(hits);
        } catch (error) {
          console.error("Header search error:", error);
          hideAllDropdowns();
        }
      }

      // Handle input events
      let searchTimeout: NodeJS.Timeout;
      searchInput.addEventListener("input", function () {
        const query = this.value.trim();

        clearTimeout(searchTimeout);

        searchTimeout = setTimeout(() => {
          performSearch(query);
        }, 300);
      });

      // Handle keyboard events
      searchInput.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
          hideAllDropdowns();
          this.blur();
        }
        if (e.key === "Enter") {
          e.preventDefault();
          const query = this.value.trim();
          if (query) {
            // Navigate to search results page or perform action
            window.location.href = `/?search=${encodeURIComponent(query)}`;
          }
        }
      });

      // Handle focus
      searchInput.addEventListener("focus", function () {
        const query = this.value.trim();
        if (query.length >= 2) {
          performSearch(query);
        }
      });

      // Hide results when clicking outside
      document.addEventListener("click", function (e) {
        if (
          !searchInput.contains(e.target as Node) &&
          !resultsContainer?.contains(e.target as Node) &&
          !loadingIndicator?.contains(e.target as Node) &&
          !noResultsMessage?.contains(e.target as Node)
        ) {
          hideAllDropdowns();
        }
      });

      // Reposition on scroll/resize
      function repositionVisibleDropdown() {
        if (
          resultsContainer &&
          !resultsContainer.classList.contains("hidden")
        ) {
          positionDropdown(resultsContainer);
        }
        if (
          loadingIndicator &&
          !loadingIndicator.classList.contains("hidden")
        ) {
          positionDropdown(loadingIndicator);
        }
        if (
          noResultsMessage &&
          !noResultsMessage.classList.contains("hidden")
        ) {
          positionDropdown(noResultsMessage);
        }
      }

      window.addEventListener("scroll", repositionVisibleDropdown);
      window.addEventListener("resize", repositionVisibleDropdown);
    } catch (error) {
      console.error("Failed to initialize header search:", error);
    }
  }

  // Location-specific search functionality
  function initializeLocationSearch(
    searchInput: HTMLInputElement,
    pageType: string,
    context: any,
  ) {
    console.log("Initializing location search for:", pageType, context);

    // Get the appropriate search elements from the page
    let targetElements: HTMLElement[] = [];
    let searchFunction: (query: string) => void;

    if (pageType === "country") {
      // Search regions
      targetElements = Array.from(
        document.querySelectorAll(".region-card"),
      ) as HTMLElement[];
      searchFunction = (query: string) => {
        const filtered = targetElements.filter((card) => {
          const regionName = card.dataset.regionName || "";
          return regionName.includes(query.toLowerCase());
        });
        updateLocationResults(targetElements, filtered, "regions", query);
      };
    } else if (pageType === "region") {
      // Search cities
      targetElements = Array.from(
        document.querySelectorAll(".city-card"),
      ) as HTMLElement[];
      searchFunction = (query: string) => {
        const filtered = targetElements.filter((card) => {
          const cityName = card.dataset.cityName || "";
          return cityName.includes(query.toLowerCase());
        });
        updateLocationResults(targetElements, filtered, "cities", query);
      };
    } else if (pageType === "city") {
      // Search profiles
      const profileCards = Array.from(
        document.querySelectorAll(".profile-card"),
      ) as HTMLElement[];
      const searchableItems = Array.from(
        document.querySelectorAll(".searchable-item"),
      ) as HTMLElement[];
      targetElements = [...profileCards, ...searchableItems];

      searchFunction = (query: string) => {
        const filteredProfiles = profileCards.filter((card) => {
          const profileName = card.dataset.searchName || "";
          const profileDescription = card.dataset.searchDescription || "";
          return (
            profileName.includes(query.toLowerCase()) ||
            profileDescription.includes(query.toLowerCase())
          );
        });

        const filteredItems = searchableItems.filter((item) => {
          const profileName = item.dataset.searchName || "";
          const profileDescription = item.dataset.searchDescription || "";
          return (
            profileName.includes(query.toLowerCase()) ||
            profileDescription.includes(query.toLowerCase())
          );
        });

        updateProfileResults(
          profileCards,
          searchableItems,
          filteredProfiles,
          filteredItems,
          query,
        );
      };
    }

    // Handle input events
    let searchTimeout: NodeJS.Timeout;
    searchInput.addEventListener("input", function () {
      const query = this.value.trim();

      clearTimeout(searchTimeout);

      searchTimeout = setTimeout(() => {
        if (query.length === 0) {
          // Reset to show all items
          if (pageType === "city") {
            updateProfileResults(
              Array.from(
                document.querySelectorAll(".profile-card"),
              ) as HTMLElement[],
              Array.from(
                document.querySelectorAll(".searchable-item"),
              ) as HTMLElement[],
              Array.from(
                document.querySelectorAll(".profile-card"),
              ) as HTMLElement[],
              Array.from(
                document.querySelectorAll(".searchable-item"),
              ) as HTMLElement[],
              "",
            );
          } else {
            updateLocationResults(
              targetElements,
              targetElements,
              pageType === "country" ? "regions" : "cities",
              "",
            );
          }
        } else {
          searchFunction(query);
        }
      }, 300);
    });

    // Handle keyboard events
    searchInput.addEventListener("keydown", function (e) {
      if (e.key === "Escape") {
        this.blur();
        this.value = "";
        // Reset results
        if (pageType === "city") {
          updateProfileResults(
            Array.from(
              document.querySelectorAll(".profile-card"),
            ) as HTMLElement[],
            Array.from(
              document.querySelectorAll(".searchable-item"),
            ) as HTMLElement[],
            Array.from(
              document.querySelectorAll(".profile-card"),
            ) as HTMLElement[],
            Array.from(
              document.querySelectorAll(".searchable-item"),
            ) as HTMLElement[],
            "",
          );
        } else {
          updateLocationResults(
            targetElements,
            targetElements,
            pageType === "country" ? "regions" : "cities",
            "",
          );
        }
      }
    });
  }

  // Update location results (regions/cities)
  function updateLocationResults(
    allElements: HTMLElement[],
    filteredElements: HTMLElement[],
    type: string,
    query: string,
  ) {
    const grid = document.getElementById(
      type === "regions" ? "regions-grid" : "cities-grid",
    );
    if (!grid) return;

    // Hide all elements
    allElements.forEach((element) => {
      element.style.display = "none";
    });

    // Clear grid
    grid.innerHTML = "";

    if (filteredElements.length === 0 && query) {
      grid.innerHTML = `
        <div class="col-span-full text-center py-8 text-gray-500">
          <p>No ${type} found matching "${query}"</p>
        </div>
      `;
    } else {
      filteredElements.forEach((element) => {
        element.style.display = "flex";
        grid.appendChild(element);
      });
    }
  }

  // Update profile results
  function updateProfileResults(
    allProfileCards: HTMLElement[],
    allSearchableItems: HTMLElement[],
    filteredProfileCards: HTMLElement[],
    filteredSearchableItems: HTMLElement[],
    query: string,
  ) {
    const profilesGrid = document.getElementById("profiles-grid");
    if (!profilesGrid) return;

    // Hide all elements
    allProfileCards.forEach((card) => {
      card.style.display = "none";
    });
    allSearchableItems.forEach((item) => {
      item.style.display = "none";
    });

    // Clear grid
    profilesGrid.innerHTML = "";

    if (
      filteredProfileCards.length === 0 &&
      filteredSearchableItems.length === 0 &&
      query
    ) {
      profilesGrid.innerHTML = `
        <div class="col-span-full text-center py-8 text-gray-500">
          <p>No veterinarians found matching "${query}"</p>
        </div>
      `;
    } else {
      filteredProfileCards.forEach((card) => {
        card.style.display = "block";
        profilesGrid.appendChild(card);
      });

      // Show filtered additional items
      filteredSearchableItems.forEach((item) => {
        item.style.display = "flex";
      });
    }
  }

  // Menu functionality
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuPanel = document.getElementById("menu-panel");
  const menuClose = document.getElementById("menu-close");
  const hamburgerLines = document.querySelectorAll(".hamburger-line");

  // Set dynamic date for popular vets
  const popularVetsText = document.getElementById("popular-vets-text");
  if (popularVetsText) {
    const currentDate = new Date();
    const monthName = currentDate.toLocaleDateString("en-US", {
      month: "long",
    });
    const year = currentDate.getFullYear();
    popularVetsText.textContent = `Most Popular Vets in ${monthName} ${year}`;
  }

  function openMenu() {
    if (!mobileMenu || !menuPanel) return;

    mobileMenu.classList.remove("hidden");
    document.body.style.overflow = "hidden";

    // Animate hamburger to X
    if (hamburgerLines[0])
      (hamburgerLines[0] as HTMLElement).style.transform =
        "rotate(45deg) translate(6px, 6px)";
    if (hamburgerLines[1])
      (hamburgerLines[1] as HTMLElement).style.opacity = "0";
    if (hamburgerLines[2])
      (hamburgerLines[2] as HTMLElement).style.transform =
        "rotate(-45deg) translate(6px, -6px)";

    // Slide in menu
    setTimeout(() => {
      if (menuPanel)
        (menuPanel as HTMLElement).style.transform = "translateX(0)";
    }, 10);
  }

  function closeMenu() {
    if (!mobileMenu || !menuPanel) return;

    (menuPanel as HTMLElement).style.transform = "translateX(100%)";
    document.body.style.overflow = "";

    // Animate X back to hamburger
    if (hamburgerLines[0])
      (hamburgerLines[0] as HTMLElement).style.transform = "";
    if (hamburgerLines[1])
      (hamburgerLines[1] as HTMLElement).style.opacity = "";
    if (hamburgerLines[2])
      (hamburgerLines[2] as HTMLElement).style.transform = "";

    setTimeout(() => {
      if (mobileMenu) mobileMenu.classList.add("hidden");
    }, 300);
  }

  // Event listeners
  menuToggle?.addEventListener("click", openMenu);
  menuClose?.addEventListener("click", closeMenu);

  // Close menu when clicking backdrop
  mobileMenu?.addEventListener("click", (e) => {
    if (e.target === mobileMenu) {
      closeMenu();
    }
  });

  // Close menu when clicking any nav link
  const navLinks = mobileMenu?.querySelectorAll("a");
  navLinks?.forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Close menu with Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !mobileMenu?.classList.contains("hidden")) {
      closeMenu();
    }
  });

  // Handle search flash badge animation
  function initializeSearchFlashBadge() {
    const searchInput = document.getElementById("header-vet-search");
    const flashBadge = document.getElementById("search-flash-badge");

    if (searchInput && flashBadge) {
      let hasInteracted = false;

      // Flash animation sequence
      function flashBadgeAnimation() {
        if (hasInteracted || !flashBadge) return;

        // Show with flash effect
        flashBadge.style.opacity = "1";
        flashBadge.style.transform = "scale(1)";
        flashBadge.style.boxShadow = "0 0 20px rgba(59, 130, 246, 0.6)";

        // Flash sequence: 3 flashes
        const flashTimes = [800, 1600, 2400];
        flashTimes.forEach(function (time, index) {
          setTimeout(function () {
            if (hasInteracted || !flashBadge) return;
            flashBadge.style.opacity = "0.3";
            flashBadge.style.transform = "scale(0.95)";
            setTimeout(function () {
              if (hasInteracted || !flashBadge) return;
              flashBadge.style.opacity = "1";
              flashBadge.style.transform = "scale(1)";
            }, 150);
          }, time);
        });

        // Auto-hide after 4 seconds if no interaction
        setTimeout(function () {
          if (!hasInteracted) {
            hideBadge();
          }
        }, 4000);
      }

      // Function to hide badge
      function hideBadge() {
        hasInteracted = true;
        if (flashBadge) {
          flashBadge.style.opacity = "0";
          flashBadge.style.transform = "scale(0.8)";
          flashBadge.style.boxShadow = "none";
        }
      }

      // Hide badge on any interaction
      searchInput.addEventListener("focus", hideBadge);
      searchInput.addEventListener("input", hideBadge);
      searchInput.addEventListener("click", hideBadge);

      // Start flash sequence after page load
      setTimeout(flashBadgeAnimation, 1000);
    }
  }

  // Initialize header search when DOM is ready
  document.addEventListener("DOMContentLoaded", function () {
    initializeSearchFlashBadge();
    setTimeout(() => {
      initializeHeaderVetSearch();
    }, 100);
  });
</script>
