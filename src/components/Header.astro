---
// Check page type based on URL pattern
const pathname = Astro.url.pathname;
const isHomepage = pathname === "/";

// Parse URL to determine page type and context
let pageType = "homepage";
let headerPillLabel = "Browse By Location";
let headerPillBadge = "Use Menu";
let searchContext: {
  country?: string;
  region?: string;
  city?: string;
  placeholder?: string;
  searchType?: string;
} = {};

const pathSegments = pathname.split("/").filter(Boolean);
const supportedCountrySlugs = new Set(["canada", "united-states"]);
const hasSupportedCountryPrefix =
  pathSegments.length > 0 && supportedCountrySlugs.has(pathSegments[0]);
const networkPromos = [
  {
    label: "DentistList",
    description: "Find dentists by city",
    href: "https://dentistlist.org",
  },
  {
    label: "CivillyWedd",
    description: "Browse wedding vendors",
    href: "https://civillywedd.com",
  },
];

if (pathSegments.length === 1 && hasSupportedCountryPrefix) {
  // Country page: /canada
  pageType = "country";
  searchContext = {
    country: pathSegments[0],
    placeholder: "Search regions...",
    searchType: "regions",
  };
} else if (pathSegments.length === 2 && hasSupportedCountryPrefix) {
  // Region page: /canada/ontario
  pageType = "region";
  const regionName = pathSegments[1]
    .replace(/-/g, " ")
    .replace(/\b\w/g, (l) => l.toUpperCase());
  searchContext = {
    country: pathSegments[0],
    region: pathSegments[1],
    placeholder: `Search cities in ${regionName}`,
    searchType: "cities",
  };
} else if (pathSegments.length === 3 && hasSupportedCountryPrefix) {
  // City page: /canada/ontario/toronto
  pageType = "city";
  const cityName = pathSegments[2]
    .replace(/-/g, " ")
    .replace(/\b\w/g, (l) => l.toUpperCase());
  searchContext = {
    country: pathSegments[0],
    region: pathSegments[1],
    city: pathSegments[2],
    placeholder: `Search veterinarians in ${cityName}`,
    searchType: "profiles",
  };
} else if (pathSegments.length === 4 && hasSupportedCountryPrefix) {
  // Profile page: /canada/ontario/toronto/vet-name
  pageType = "profile";
  searchContext = {
    placeholder: "Search vets, specialties, locations...",
    searchType: "general",
  };
}

// Default to homepage search if not a location or profile page
if (!["country", "region", "city", "profile"].includes(pageType)) {
  pageType = "homepage";
  searchContext = {
    placeholder: "Search vets, specialties, locations...",
    searchType: "general",
  };
}

// Force Algolia search for add-vet and claim-clinic pages
if (
  pathname === "/add-vet" ||
  pathname === "/add-vet/" ||
  pathname === "/claim-clinic" ||
  pathname === "/claim-clinic/"
) {
  pageType = "owner-tools";
  headerPillLabel = pathname.startsWith("/claim-clinic")
    ? "Owner Tools"
    : "Add Listing";
  headerPillBadge = pathname.startsWith("/claim-clinic")
    ? "Claim Flow"
    : "Submission";
  searchContext = {
    placeholder: "Search vets, specialties, locations...",
    searchType: "general",
  };
}
const showHeaderNetworkPromos = true;
---

<header class="relative z-40 border-b border-slate-200/80 bg-white/78 shadow-[0_12px_40px_rgba(15,23,42,0.08)] backdrop-blur-xl">
  <div class="mx-auto w-full max-w-[1600px] px-4 md:px-6">
    <div class="flex items-center gap-3 py-3">
      <!-- Logo -->
      <a href="/" class="flex shrink-0 items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-slate-950 text-cyan-200 shadow-lg shadow-cyan-950/10">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <circle cx="11" cy="4" r="2"></circle>
            <circle cx="18" cy="8" r="2"></circle>
            <circle cx="20" cy="16" r="2"></circle>
            <path
              d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"
            ></path>
          </svg>
        </div>
        <span class="hidden text-base font-extrabold tracking-tight text-slate-950 sm:block">VetList</span>
        <span class="text-base font-extrabold tracking-tight text-slate-950 sm:hidden">VL</span>
      </a>

      <!-- Veterinary Search - Takes up most of the space -->
      <div class="relative flex-1">
        {showHeaderNetworkPromos ? (
          <div class="rounded-[26px] border border-slate-200 bg-white p-1.5 shadow-[0_8px_24px_rgba(15,23,42,0.08)]">
            <div id="mobile-header-network-promos" class="sm:hidden">
              {networkPromos.map((promo, index) => (
                <a
                  href={promo.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-mobile-header-promo
