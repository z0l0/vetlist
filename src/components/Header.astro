---
// Check page type based on URL pattern
const pathname = Astro.url.pathname;
const isHomepage = pathname === "/";

// Parse URL to determine page type and context
let pageType = "homepage";
let searchContext: {
  country?: string;
  region?: string;
  city?: string;
  placeholder?: string;
  searchType?: string;
} = {};

const pathSegments = pathname.split("/").filter(Boolean);

if (pathSegments.length === 1) {
  // Country page: /canada
  pageType = "country";
  searchContext = {
    country: pathSegments[0],
    placeholder: "Search regions...",
    searchType: "regions",
  };
} else if (pathSegments.length === 2) {
  // Region page: /canada/ontario
  pageType = "region";
  const regionName = pathSegments[1]
    .replace(/-/g, " ")
    .replace(/\b\w/g, (l) => l.toUpperCase());
  searchContext = {
    country: pathSegments[0],
    region: pathSegments[1],
    placeholder: `Search cities in ${regionName}`,
    searchType: "cities",
  };
} else if (pathSegments.length === 3) {
  // City page: /canada/ontario/toronto
  pageType = "city";
  const cityName = pathSegments[2]
    .replace(/-/g, " ")
    .replace(/\b\w/g, (l) => l.toUpperCase());
  searchContext = {
    country: pathSegments[0],
    region: pathSegments[1],
    city: pathSegments[2],
    placeholder: `Search veterinarians in ${cityName}`,
    searchType: "profiles",
  };
}

// Default to homepage search if not a location page
if (!["country", "region", "city"].includes(pageType)) {
  pageType = "homepage";
  searchContext = {
    placeholder: "Search vets, specialties, locations...",
    searchType: "general",
  };
}

// Force Algolia search for add-vet and claim-clinic pages
if (pathname === "/add-vet" || pathname === "/claim-clinic") {
  pageType = "homepage";
  searchContext = {
    placeholder: "Search vets, specialties, locations...",
    searchType: "general",
  };
}
