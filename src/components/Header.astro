                >
                  <span class="min-w-0">
                    <span class="block truncate text-sm font-bold tracking-tight text-slate-900">
                      {promo.label}
                    </span>
                    <span class="block truncate text-xs text-slate-500">
                      {promo.description}
                    </span>
                  </span>
                  <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 transition group-hover:border-cyan-300/50 group-hover:bg-cyan-50 group-hover:text-cyan-700">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="h-4 w-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5H19.5M19.5 4.5V10.5M19.5 4.5L9 15M6.75 6.75H10.5M17.25 13.5V17.25A1.5 1.5 0 0115.75 18.75H6.75A1.5 1.5 0 015.25 17.25V8.25A1.5 1.5 0 016.75 6.75H10.5" />
                    </svg>
                  </span>
                </a>
              ))}
            </div>
            <div class="hidden gap-1.5 sm:grid sm:grid-cols-2">
              {networkPromos.map((promo) => (
                <a
                  href={promo.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group flex min-w-0 items-center justify-between gap-3 rounded-[22px] border border-slate-200 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] px-4 py-3 transition hover:border-cyan-300/60 hover:bg-[linear-gradient(180deg,#f8fdff_0%,#eef9ff_100%)] hover:shadow-[0_8px_20px_rgba(15,23,42,0.07)]"
                >
                  <span class="min-w-0">
                    <span class="block truncate text-sm font-bold tracking-tight text-slate-900">
                      {promo.label}
                    </span>
                    <span class="block truncate text-xs text-slate-500">
                      {promo.description}
                    </span>
                  </span>
                  <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full border border-slate-200 bg-white text-slate-500 transition group-hover:border-cyan-300/50 group-hover:bg-cyan-50 group-hover:text-cyan-700">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="h-4 w-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5H19.5M19.5 4.5V10.5M19.5 4.5L9 15M6.75 6.75H10.5M17.25 13.5V17.25A1.5 1.5 0 0115.75 18.75H6.75A1.5 1.5 0 015.25 17.25V8.25A1.5 1.5 0 016.75 6.75H10.5" />
                    </svg>
                  </span>
                </a>
              ))}
            </div>
          </div>
        ) : (
          <div class="relative">
            <div
              id="search-flash-badge"
              class="pointer-events-none absolute -top-3 left-4 inline-flex items-center gap-2 rounded-full border border-cyan-300/30 bg-slate-950 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-cyan-200 opacity-0 shadow-lg transition-all duration-500"
              style="transform: scale(0.85);"
            >
              <span class="h-1.5 w-1.5 rounded-full bg-cyan-300"></span>
              Search
            </div>

            <input
              type="text"
              id="header-vet-search"
              placeholder={searchContext.placeholder ||
                "Search vets, specialties, locations..."}
              class="w-full rounded-full border border-slate-200 bg-white px-5 py-3 pr-12 text-sm text-slate-800 shadow-[0_8px_24px_rgba(15,23,42,0.08)] transition focus:border-cyan-400 focus:outline-none focus:ring-4 focus:ring-cyan-100 sm:text-base"
              autocomplete="off"
              data-page-type={pageType}
              data-search-type={searchContext.searchType}
              data-country={searchContext.country || ""}
              data-region={searchContext.region || ""}
              data-city={searchContext.city || ""}
            />

            <div class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-slate-400">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                fill="none"
                viewBox="0 0 24 24"
                stroke-width="1.8"
                stroke="currentColor"
                class="h-5 w-5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"
                ></path>
              </svg>
            </div>
          </div>
        )}
      </div>

      <!-- Hamburger Menu Button -->
      <button
        id="menu-toggle"
        class="flex h-11 w-11 shrink-0 flex-col items-center justify-center space-y-1.5 rounded-2xl border border-slate-200 bg-white text-slate-700 shadow-[0_8px_24px_rgba(15,23,42,0.08)] transition-all duration-300 hover:border-slate-300 hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-cyan-300 focus:ring-offset-2"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span
          class="hamburger-line h-0.5 w-5 rounded-full bg-slate-700 transition-all duration-300"
        ></span>
        <span
          class="hamburger-line h-0.5 w-5 rounded-full bg-slate-700 transition-all duration-300"
        ></span>
        <span
          class="hamburger-line h-0.5 w-5 rounded-full bg-slate-700 transition-all duration-300"
        ></span>
      </button>
    </div>

  </div>

  <!-- Slide-in Menu -->
  <div
    id="mobile-menu"
    class="fixed inset-0 z-[1001] hidden opacity-0 pointer-events-none transition-opacity duration-300"
  >
    <!-- Backdrop -->
    <div
      data-menu-backdrop
      class="absolute inset-0 bg-slate-950/75 backdrop-blur-sm transition-opacity duration-300"
    >
    </div>

    <!-- Menu Panel -->
    <div
      class="absolute right-0 top-0 h-dvh w-full max-w-none overflow-y-auto border-l border-white/10 bg-slate-950 text-white shadow-2xl transform translate-x-full transition-transform duration-300 ease-in-out will-change-transform sm:max-w-[22rem]"
      id="menu-panel"
    >
      <!-- Menu Header -->
      <div class="flex items-center justify-between border-b border-white/10 bg-slate-950 p-5">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-slate-400">Navigation</p>
          <h2 class="mt-1 text-lg font-bold text-white">Browse VetList</h2>
        </div>
        <button
          id="menu-close"
          class="rounded-full border border-white/10 p-2 transition-colors duration-200 hover:bg-white/10"
          aria-label="Close menu"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6 text-slate-300"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>

      <!-- Menu Items -->
      <nav class="space-y-3 p-4 pb-8 sm:space-y-4 sm:p-6">
        <!-- Add Your Clinic - Highlighted -->
        <a
          href="/add-vet/"
          class="flex items-center gap-4 rounded-3xl border border-white/10 bg-white/10 p-4 text-white transition-all duration-200 hover:bg-white/15"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M12 4.5v15m7.5-7.5h-15"></path>
          </svg>
          <span class="font-semibold text-lg">Add Your Clinic</span>
        </a>

        <!-- Claim Your Clinic -->
        <a href="/claim-clinic/" class="flex items-center gap-4 rounded-3xl border border-cyan-300/25 bg-cyan-300/10 p-4 text-cyan-100 transition-all duration-200 hover:bg-cyan-300/15">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            ></path>
          </svg>
          <span class="font-semibold text-lg">Claim Your Clinic</span>
        </a>

        <!-- Browse Canadian Vets -->
        <a
          href="/canada/"
          class="flex items-center gap-4 rounded-3xl border border-white/10 bg-white/5 p-4 transition-colors duration-200 hover:bg-white/10"
        >
          <span class="text-2xl">🇨🇦</span>
          <span class="font-medium text-white">Browse Canadian Vets</span>
        </a>

        <!-- Browse American Vets -->
        <a
          href="/united-states/"
          class="flex items-center gap-4 rounded-3xl border border-white/10 bg-white/5 p-4 transition-colors duration-200 hover:bg-white/10"
        >
          <span class="text-2xl">🇺🇸</span>
          <span class="font-medium text-white">Browse American Vets</span>
        </a>

        <!-- Vets in Popular Cities -->
        <a
          href="/#popular-cities"
          class="flex items-center gap-4 rounded-3xl border border-white/10 bg-white/5 p-4 transition-colors duration-200 hover:bg-white/10"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6 text-slate-300"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"></path>
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"
            ></path>
          </svg>
          <span class="font-medium text-white">Vets in Popular Cities</span>
        </a>

        <!-- Most Popular Vets -->
        <a
          href="/#popular-vets"
          class="flex items-center gap-4 rounded-3xl border border-white/10 bg-white/5 p-4 transition-colors duration-200 hover:bg-white/10"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6 text-slate-300"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z"
            ></path>
          </svg>
          <span class="font-medium text-white" id="popular-vets-text"
            >Most Popular Vets</span
          >
        </a>

        <!-- Contact Us -->
        <a
          href="/contact/"
          class="flex items-center gap-4 rounded-3xl border border-white/10 bg-white/5 p-4 transition-colors duration-200 hover:bg-white/10"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="w-6 h-6 text-slate-300"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"
            ></path>
          </svg>
          <span class="font-medium text-white">Contact Us</span>
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  // Header Vet Search functionality
  async function initializeHeaderVetSearch() {
    if (typeof window === "undefined") return;

    try {
      // Get DOM elements
      const searchInput = document.getElementById(
        "header-vet-search",
      ) as HTMLInputElement;

      if (!searchInput) return;

      // Get page context from data attributes
      const pageType = searchInput.dataset.pageType;
      const searchType = searchInput.dataset.searchType;
      const country = searchInput.dataset.country || "";
      const region = searchInput.dataset.region || "";
      const city = searchInput.dataset.city || "";

      console.log("Header search initialized for:", {
        pageType,
        searchType,
        country,
        region,
        city,
      });

      // For location pages, use local search instead of Algolia
      if (pageType && ["country", "region", "city"].includes(pageType)) {
        initializeLocationSearch(searchInput, pageType, {
          country,
          region,
          city,
        });
        return;
      }

      // For homepage, use Algolia search
      const { default: algoliasearch } = await import("algoliasearch/lite");
      console.log("Algolia loaded for header search");

      // Initialize Algolia client and index
      const appId = "G13RPGTX1B";
      const apiKey = "3733aa7e0b81cfc61dc8e4122fe93c6a";
      const indexName = "vetlist_locations";

      const algoliaClient = algoliasearch(appId, apiKey);
      const index = algoliaClient.initIndex(indexName);

      // Create dropdown containers with higher z-index for header
      const dropdownContainer = document.createElement("div");
      dropdownContainer.className =
        "fixed inset-0 pointer-events-none z-[9999]";
      dropdownContainer.innerHTML = `
        <!-- Search Results Dropdown -->
        <div id="header-search-results" class="hidden absolute bg-white border border-gray-200 rounded-lg shadow-2xl max-h-80 overflow-y-auto pointer-events-auto">
        </div>
        
        <!-- Loading indicator -->
        <div id="header-loading" class="hidden absolute bg-white border border-gray-200 rounded-lg shadow-2xl p-4 pointer-events-auto">
          <div class="flex items-center gap-2 text-gray-500 text-sm">
            <div class="animate-spin w-4 h-4 border-2 border-primary-500 border-t-transparent rounded-full"></div>
            <span id="header-loading-text">Searching...</span>
          </div>
        </div>
        
        <!-- No results message -->
        <div id="header-no-results" class="hidden absolute bg-white border border-gray-200 rounded-lg shadow-2xl p-4 pointer-events-auto">
          <div class="text-gray-500 text-sm">
            <div class="flex items-center gap-2 mb-2">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75l-2.489-2.489m0 0a3.375 3.375 0 10-4.773-4.773 3.375 3.375 0 004.774 4.774zM21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              No results found
            </div>
            <p>Try a different search term or check spelling.</p>
          </div>
        </div>
      `;
      document.body.appendChild(dropdownContainer);

      const resultsContainer = document.getElementById("header-search-results");
      const loadingIndicator = document.getElementById("header-loading");
      const noResultsMessage = document.getElementById("header-no-results");
      const loadingText = document.getElementById("header-loading-text");

      // Position dropdown relative to input
      function positionDropdown(element: HTMLElement) {
        if (!element || !searchInput) return;

        const inputRect = searchInput.getBoundingClientRect();
        element.style.left = inputRect.left + "px";
        element.style.top = inputRect.bottom + 8 + "px";
        element.style.width = inputRect.width + "px";
      }

      // Hide all dropdowns
      function hideAllDropdowns() {
        resultsContainer?.classList.add("hidden");
        loadingIndicator?.classList.add("hidden");
        noResultsMessage?.classList.add("hidden");
      }

      // Show loading with custom message
      function showLoading(message = "Searching...") {
        hideAllDropdowns();
        if (loadingIndicator && loadingText) {
          loadingText.textContent = message;
          positionDropdown(loadingIndicator);
          loadingIndicator.classList.remove("hidden");
        }
      }

      // Show search results
      function showResults(hits: any[]) {
        hideAllDropdowns();

        if (hits.length === 0) {
          if (noResultsMessage) {
            positionDropdown(noResultsMessage);
            noResultsMessage.classList.remove("hidden");
          }
          return;
        }

        if (resultsContainer) {
          resultsContainer.innerHTML = hits
            .map((hit: any) => {
              // Format specializations
              const specializations = hit.specializations || [];
              const displaySpecializations = specializations
                .slice(0, 2)
                .join(", ");
              const moreCount =
                specializations.length > 2
                  ? ` +${specializations.length - 2} more`
                  : "";

              // Rating display
              const rating = hit.rating ? `${hit.rating}⭐` : "";

              return `
              <a href="${hit.url ? hit.url + '/' : '#'}" class="block px-4 py-3 hover:bg-gray-50 border-b border-gray-100 last:border-b-0 transition-colors">
                <div class="flex items-start gap-3">
                  <div class="flex-shrink-0 w-10 h-10 relative">
                    <div class="w-full h-full rounded-lg bg-primary-100 flex items-center justify-center">
                      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary-600">
                        <path d="M12 6v4"/>
                        <path d="M14 14h-4"/>
                        <path d="M14 18h-4"/>
                        <path d="M14 8h-4"/>
                        <path d="M18 12h2a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2v-9a2 2 0 0 1 2-2h2"/>
                        <path d="M18 22V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v18"/>
                      </svg>
                    </div>
	                    ${
	                      hit.picture
	                        ? `<img src="${hit.picture}" alt="${hit.name}" class="absolute inset-0 w-full h-full rounded-lg object-cover" width="40" height="40" loading="lazy" decoding="async" />`
	                        : ""
	                    }
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center gap-2 mb-1">
                      <h3 class="font-medium text-sm text-gray-900 truncate">${hit._highlightResult?.name?.value || hit.name}</h3>
                      ${rating ? `<span class="text-xs text-yellow-600">${rating}</span>` : ""}
                    </div>
                    <p class="text-xs text-gray-600 mb-1">${hit._highlightResult?.location?.value || hit.location}</p>
                    ${
                      displaySpecializations
                        ? `<p class="text-xs text-gray-500 truncate">${displaySpecializations}${moreCount}</p>`
                        : ""
                    }
                  </div>
                </div>
              </a>
            `;
            })
            .join("");

          positionDropdown(resultsContainer);
          resultsContainer.classList.remove("hidden");
        }
      }

      // Perform search
      async function performSearch(query: string) {
        if (query.length < 2) {
          hideAllDropdowns();
          return;
        }

        try {
          const searchOptions: any = {
            hitsPerPage: 12,
            attributesToRetrieve: [
              "name",
              "location",
              "specializations",
              "rating",
              "picture",
              "city",
              "province",
              "country",
              "url",
            ],
            attributesToHighlight: ["name", "location", "specializations"],
            typoTolerance: true,
            minWordSizefor1Typo: 4,
            minWordSizefor2Typos: 8,
          };

          showLoading("Searching vets...");

          console.log("Header search query:", query);

          const searchResult = await index.search(query, searchOptions);
          const hits = searchResult.hits || [];

          console.log("Header search results:", hits.length, "hits");
          showResults(hits);
        } catch (error) {
          console.error("Header search error:", error);
          hideAllDropdowns();
        }
      }

      // Handle input events
      let searchTimeout: NodeJS.Timeout;
      searchInput.addEventListener("input", function () {
        const query = this.value.trim();

        clearTimeout(searchTimeout);

        searchTimeout = setTimeout(() => {
          performSearch(query);
        }, 300);
      });

      // Handle keyboard events
      searchInput.addEventListener("keydown", function (e) {
        if (e.key === "Escape") {
          hideAllDropdowns();
          this.blur();
        }
        if (e.key === "Enter") {
          e.preventDefault();
          const query = this.value.trim();
          if (query) {
            // Navigate to search results page or perform action
            window.location.href = `/?search=${encodeURIComponent(query)}`;
          }
        }
      });

      // Handle focus
      searchInput.addEventListener("focus", function () {
        const query = this.value.trim();
        if (query.length >= 2) {
          performSearch(query);
        }
      });

      // Hide results when clicking outside
      document.addEventListener("click", function (e) {
        if (
          !searchInput.contains(e.target as Node) &&
          !resultsContainer?.contains(e.target as Node) &&
          !loadingIndicator?.contains(e.target as Node) &&
          !noResultsMessage?.contains(e.target as Node)
        ) {
          hideAllDropdowns();
        }
      });

      // Reposition on scroll/resize
      function repositionVisibleDropdown() {
        if (
          resultsContainer &&
          !resultsContainer.classList.contains("hidden")
        ) {
          positionDropdown(resultsContainer);
        }
        if (
          loadingIndicator &&
          !loadingIndicator.classList.contains("hidden")
        ) {
          positionDropdown(loadingIndicator);
        }
        if (
          noResultsMessage &&
          !noResultsMessage.classList.contains("hidden")
        ) {
          positionDropdown(noResultsMessage);
        }
      }

      window.addEventListener("scroll", repositionVisibleDropdown);
      window.addEventListener("resize", repositionVisibleDropdown);
    } catch (error) {
      console.error("Failed to initialize header search:", error);
    }
  }

  // Location-specific search functionality
  function initializeLocationSearch(
    searchInput: HTMLInputElement,
    pageType: string,
    context: any,
  ) {
    console.log("Initializing location dropdown search for:", pageType, context);

    type LocalSearchResult = {
      label: string;
      subtitle: string;
      href: string;
    };

    const results: LocalSearchResult[] = [];

    if (pageType === "country") {
      const cards = Array.from(
        document.querySelectorAll(".region-card"),
      ) as HTMLElement[];
      cards.forEach((card) => {
        const name = (card.dataset.regionName || "").trim();
        const href =
          card.getAttribute("href") ||
          card.querySelector("a")?.getAttribute("href") ||
          "";
        if (!name || !href) return;
        results.push({
          label: name
            .split(" ")
            .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
            .join(" "),
          subtitle: "Region / Province",
          href,
        });
      });
    } else if (pageType === "region") {
      const cards = Array.from(
        document.querySelectorAll(".city-card"),
      ) as HTMLElement[];
      cards.forEach((card) => {
        const name = (card.dataset.cityName || "").trim();
        const href =
          card.getAttribute("href") ||
          card.querySelector("a")?.getAttribute("href") ||
          "";
        if (!name || !href) return;
        results.push({
          label: name
            .split(" ")
            .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
            .join(" "),
          subtitle: "City",
          href,
        });
      });
    } else if (pageType === "city") {
      const vetCards = Array.from(
        document.querySelectorAll(".vet-card"),
      ) as HTMLElement[];
      vetCards.forEach((card) => {
        const rawSearchText = (card.dataset.searchText || "").trim();
        const titleText =
          card.querySelector("h2, h3, [data-name]")?.textContent?.trim() ||
          rawSearchText.split(" in ")[0] ||
          "";
        const subtitleText =
          card.querySelector("p")?.textContent?.trim() || "Clinic";
        const href = card.querySelector("a[href]")?.getAttribute("href") || "";
        if (!titleText || !href) return;
        results.push({
          label: titleText,
          subtitle: subtitleText,
          href,
        });
      });
    }

    if (!results.length) return;

    const scrim = document.createElement("div");
    scrim.className =
      "fixed inset-0 z-[900] hidden bg-slate-950/28 backdrop-blur-[1px]";
    document.body.appendChild(scrim);

    const dropdown = document.createElement("div");
    dropdown.className =
      "fixed z-[901] hidden max-h-[60vh] overflow-y-auto rounded-2xl border border-slate-200 bg-white shadow-[0_24px_60px_rgba(15,23,42,0.2)]";
    document.body.appendChild(dropdown);

    function positionDropdown() {
      const inputRect = searchInput.getBoundingClientRect();
      dropdown.style.left = `${inputRect.left}px`;
      dropdown.style.top = `${inputRect.bottom + 10}px`;
      dropdown.style.width = `${inputRect.width}px`;
    }

    function hideDropdown() {
      dropdown.classList.add("hidden");
      scrim.classList.add("hidden");
    }

    function showDropdown() {
      positionDropdown();
      dropdown.classList.remove("hidden");
      scrim.classList.remove("hidden");
    }

    function renderFilteredResults(query: string) {
      const normalized = query.trim().toLowerCase();
      if (!normalized) {
        hideDropdown();
        return;
      }

      const filtered = results
        .filter((item) =>
          `${item.label} ${item.subtitle}`.toLowerCase().includes(normalized),
        )
        .slice(0, 12);

      if (!filtered.length) {
        dropdown.innerHTML = `
          <div class="px-4 py-4 text-sm text-slate-500">
            No matches found for "${query}".
          </div>
        `;
        showDropdown();
        return;
      }

      dropdown.innerHTML = filtered
        .map(
          (item) => `
            <a href="${item.href}" class="block border-b border-slate-100 px-4 py-3 transition-colors hover:bg-slate-50 last:border-b-0">
              <p class="text-sm font-semibold text-slate-900">${item.label}</p>
              <p class="text-xs text-slate-500">${item.subtitle}</p>
            </a>
          `,
        )
        .join("");
      showDropdown();
    }

    let searchTimeout: ReturnType<typeof setTimeout>;
    searchInput.addEventListener("input", function () {
      clearTimeout(searchTimeout);
      const query = this.value;
      searchTimeout = setTimeout(() => renderFilteredResults(query), 120);
    });

    searchInput.addEventListener("focus", function () {
      if (this.value.trim().length > 0) {
        renderFilteredResults(this.value);
      }
    });

    searchInput.addEventListener("keydown", function (e) {
      if (e.key === "Escape") {
        this.blur();
        hideDropdown();
      }
    });

    scrim.addEventListener("click", () => {
      hideDropdown();
      searchInput.blur();
    });

    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      if (!searchInput.contains(target) && !dropdown.contains(target)) {
        hideDropdown();
      }
    });

    window.addEventListener("resize", () => {
      if (!dropdown.classList.contains("hidden")) positionDropdown();
    });
    window.addEventListener("scroll", () => {
      if (!dropdown.classList.contains("hidden")) positionDropdown();
    });
  }

  // Menu functionality
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const menuPanel = document.getElementById("menu-panel");
  const menuClose = document.getElementById("menu-close");
  const hamburgerLines = document.querySelectorAll(".hamburger-line");
  let closeMenuTimeout: ReturnType<typeof setTimeout> | null = null;

  // Set dynamic date for popular vets
  const popularVetsText = document.getElementById("popular-vets-text");
  if (popularVetsText) {
    const currentDate = new Date();
    const monthName = currentDate.toLocaleDateString("en-US", {
      month: "long",
    });
    const year = currentDate.getFullYear();
    popularVetsText.textContent = `Most Popular Vets in ${monthName} ${year}`;
  }

  function hideHeaderSearchOverlays() {
    ["header-search-results", "header-loading", "header-no-results"].forEach(
      (id) => {
        document.getElementById(id)?.classList.add("hidden");
      },
    );
  }

  function openMenu() {
    if (!mobileMenu || !menuPanel) return;

    if (closeMenuTimeout) {
      clearTimeout(closeMenuTimeout);
      closeMenuTimeout = null;
    }

    hideHeaderSearchOverlays();
    (document.getElementById("header-vet-search") as HTMLInputElement | null)
      ?.blur();

    mobileMenu.classList.remove("hidden");
    mobileMenu.classList.remove("pointer-events-none", "opacity-0");
    mobileMenu.classList.add("opacity-100");
    document.body.style.overflow = "hidden";
    menuToggle?.setAttribute("aria-expanded", "true");

    // Animate hamburger to X
    if (hamburgerLines[0])
      (hamburgerLines[0] as HTMLElement).style.transform =
        "rotate(45deg) translate(6px, 6px)";
    if (hamburgerLines[1])
      (hamburgerLines[1] as HTMLElement).style.opacity = "0";
    if (hamburgerLines[2])
      (hamburgerLines[2] as HTMLElement).style.transform =
        "rotate(-45deg) translate(6px, -6px)";

    // Slide in menu
    requestAnimationFrame(() => {
      menuPanel.classList.remove("translate-x-full");
      menuPanel.classList.add("translate-x-0");
    });
  }

  function closeMenu() {
    if (!mobileMenu || !menuPanel) return;

    menuPanel.classList.remove("translate-x-0");
    menuPanel.classList.add("translate-x-full");
    mobileMenu.classList.remove("opacity-100");
    mobileMenu.classList.add("opacity-0", "pointer-events-none");
    document.body.style.overflow = "";
    menuToggle?.setAttribute("aria-expanded", "false");

    // Animate X back to hamburger
    if (hamburgerLines[0])
      (hamburgerLines[0] as HTMLElement).style.transform = "";
    if (hamburgerLines[1])
      (hamburgerLines[1] as HTMLElement).style.opacity = "";
    if (hamburgerLines[2])
      (hamburgerLines[2] as HTMLElement).style.transform = "";

    closeMenuTimeout = setTimeout(() => {
      mobileMenu.classList.add("hidden");
      closeMenuTimeout = null;
    }, 300);
  }

  function initializeHeaderNetworkPromos() {
    const promoContainer = document.getElementById("mobile-header-network-promos");
    if (!promoContainer) return;

    const promos = Array.from(
      promoContainer.querySelectorAll("[data-mobile-header-promo]"),
    ) as HTMLElement[];
    if (promos.length <= 1) return;

    let activePromoIndex = Math.floor(Math.random() * promos.length);

    function renderActivePromo() {
      promos.forEach((promo, index) => {
        promo.classList.toggle("hidden", index !== activePromoIndex);
      });
    }

    renderActivePromo();

    window.setInterval(() => {
      if (window.innerWidth >= 640) return;
      activePromoIndex = (activePromoIndex + 1) % promos.length;
      renderActivePromo();
    }, 9000);
  }

  // Event listeners
  menuToggle?.addEventListener("click", openMenu);
  menuClose?.addEventListener("click", closeMenu);

  // Close menu when clicking backdrop
  mobileMenu?.addEventListener("click", (e) => {
    const target = e.target as HTMLElement | null;
    if (target?.hasAttribute("data-menu-backdrop")) {
      closeMenu();
    }
  });

  // Close menu when clicking any nav link
  const navLinks = mobileMenu?.querySelectorAll("a");
  navLinks?.forEach((link) => {
    link.addEventListener("click", closeMenu);
  });

  // Close menu with Escape key
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !mobileMenu?.classList.contains("hidden")) {
      closeMenu();
    }
  });

  // Handle search flash badge animation
  function initializeSearchFlashBadge() {
    const searchInput = document.getElementById("header-vet-search");
    const flashBadge = document.getElementById("search-flash-badge");

    if (searchInput && flashBadge) {
      let hasInteracted = false;

      // Flash animation sequence
      function flashBadgeAnimation() {
        if (hasInteracted || !flashBadge) return;

        // Show with flash effect
        flashBadge.style.opacity = "1";
        flashBadge.style.transform = "scale(1)";
        flashBadge.style.boxShadow = "0 0 20px rgba(59, 130, 246, 0.6)";

        // Flash sequence: 3 flashes
        const flashTimes = [800, 1600, 2400];
        flashTimes.forEach(function (time, index) {
          setTimeout(function () {
            if (hasInteracted || !flashBadge) return;
            flashBadge.style.opacity = "0.3";
            flashBadge.style.transform = "scale(0.95)";
            setTimeout(function () {
              if (hasInteracted || !flashBadge) return;
              flashBadge.style.opacity = "1";
              flashBadge.style.transform = "scale(1)";
            }, 150);
          }, time);
        });

        // Auto-hide after 4 seconds if no interaction
        setTimeout(function () {
          if (!hasInteracted) {
            hideBadge();
          }
        }, 4000);
      }

      // Function to hide badge
      function hideBadge() {
        hasInteracted = true;
        if (flashBadge) {
          flashBadge.style.opacity = "0";
          flashBadge.style.transform = "scale(0.8)";
          flashBadge.style.boxShadow = "none";
        }
      }

      // Hide badge on any interaction
      searchInput.addEventListener("focus", hideBadge);
      searchInput.addEventListener("input", hideBadge);
      searchInput.addEventListener("click", hideBadge);

      // Start flash sequence after page load
      setTimeout(flashBadgeAnimation, 1000);
    }
  }

  // Initialize header search when DOM is ready
  document.addEventListener("DOMContentLoaded", function () {
    initializeHeaderNetworkPromos();
    initializeSearchFlashBadge();
    setTimeout(() => {
      initializeHeaderVetSearch();
    }, 100);
  });
</script>
