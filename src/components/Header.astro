                    "group flex min-w-0 items-center justify-between gap-3 rounded-[22px] border border-slate-200 bg-[linear-gradient(180deg,#ffffff_0%,#f8fbff_100%)] px-4 py-3 transition hover:border-cyan-300/60 hover:bg-[linear-gradient(180deg,#f8fdff_0%,#eef9ff_100%)] hover:shadow-[0_8px_20px_rgba(15,23,42,0.07)]",
                    index !== 0 && "hidden",
