---
const currentYear = new Date().getFullYear();

const popularCities = [
  { name: 'Los Angeles', state: 'CA', slug: '/united-states/california/los-angeles/' },
  { name: 'New York', state: 'NY', slug: '/united-states/new-york/new-york/' },
  { name: 'Chicago', state: 'IL', slug: '/united-states/illinois/chicago/' },
  { name: 'Houston', state: 'TX', slug: '/united-states/texas/houston/' },
  { name: 'Toronto', state: 'ON', slug: '/canada/ontario/toronto/' },
  { name: 'Vancouver', state: 'BC', slug: '/canada/british-columbia/vancouver/' },
];

const popularStates = [
  { name: 'California', slug: '/united-states/california/' },
  { name: 'Texas', slug: '/united-states/texas/' },
  { name: 'Florida', slug: '/united-states/florida/' },
  { name: 'New York', slug: '/united-states/new-york/' },
  { name: 'Ontario', slug: '/canada/ontario/' },
  { name: 'British Columbia', slug: '/canada/british-columbia/' },
];
---

<footer class="mt-20 overflow-hidden rounded-t-[32px] border-t border-slate-800 bg-slate-950 text-white">
  <div class="bg-[radial-gradient(circle_at_top_left,_rgba(34,211,238,0.2),_transparent_24%),radial-gradient(circle_at_bottom_right,_rgba(251,191,36,0.12),_transparent_22%)]">
    <div class="mx-auto max-w-7xl px-4 py-12 md:px-6">
      <div class="grid gap-8 border-b border-white/10 pb-10 lg:grid-cols-[1.4fr_1fr_1fr_1fr]">
        <div class="space-y-4">
          <a href="/" class="inline-flex items-center gap-3">
            <span class="flex h-11 w-11 items-center justify-center rounded-2xl bg-white/10 text-cyan-200">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <circle cx="11" cy="4" r="2"></circle>
                <circle cx="18" cy="8" r="2"></circle>
                <circle cx="20" cy="16" r="2"></circle>
                <path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"></path>
              </svg>
            </span>
            <span>
              <span class="block text-lg font-extrabold tracking-tight">VetList</span>
              <span class="block text-sm text-slate-400">Veterinary directory</span>
            </span>
          </a>

          <p class="max-w-md text-sm leading-7 text-slate-300">
            VetList helps pet owners move from broad city pages into richer profile pages with verified contact details, live availability signals, and cleaner market context.
          </p>

          <div class="flex flex-wrap gap-3">
            <a href="/claim-clinic/" class="rounded-full border border-cyan-300/30 bg-cyan-300/10 px-4 py-2 text-sm font-semibold text-cyan-100 transition hover:bg-cyan-300/15">
              Claim your clinic
            </a>
            <a href="/add-vet/" class="rounded-full border border-white/15 bg-white/10 px-4 py-2 text-sm font-semibold text-white transition hover:bg-white/15">
              Add a listing
            </a>
          </div>
        </div>

        <div>
          <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Popular cities</h3>
          <div class="mt-4 space-y-3">
            {popularCities.map((city) => (
              <a href={city.slug} class="block text-sm text-slate-300 transition hover:text-cyan-200">
                {city.name}, {city.state}
              </a>
            ))}
          </div>
        </div>

        <div>
          <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Browse regions</h3>
          <div class="mt-4 space-y-3">
            {popularStates.map((state) => (
              <a href={state.slug} class="block text-sm text-slate-300 transition hover:text-cyan-200">
                {state.name}
              </a>
            ))}
          </div>
        </div>

        <div>
          <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-slate-400">Company</h3>
          <div class="mt-4 space-y-3">
            <a href="/about/" class="block text-sm text-slate-300 transition hover:text-cyan-200">About</a>
            <a href="/contact/" class="block text-sm text-slate-300 transition hover:text-cyan-200">Contact</a>
            <a href="/privacy/" class="block text-sm text-slate-300 transition hover:text-cyan-200">Privacy</a>
            <a href="/terms/" class="block text-sm text-slate-300 transition hover:text-cyan-200">Terms</a>
            <a href="/llms.txt" class="block text-sm text-slate-300 transition hover:text-cyan-200">LLMs.txt</a>
          </div>
        </div>
      </div>

      <div class="flex flex-col gap-3 pt-6 text-sm text-slate-400 md:flex-row md:items-center md:justify-between">
        <p>&copy; 2023-{currentYear} VetList. All rights reserved.</p>
        <p>Structured veterinary pages designed for search, comparison, and direct clinic discovery.</p>
      </div>
    </div>
  </div>
</footer>
