---
const currentYear = new Date().getFullYear();
---

<footer class="bg-gray-900 text-white py-12 mt-16">
  <div class="container mx-auto px-4 max-w-6xl">
    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-8">
      
      <!-- VetList Section -->
      <div class="space-y-4">
        <div class="flex items-center gap-2 mb-4">
          <div class="text-primary-400">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor" class="lucide lucide-paw-print">
              <circle cx="11" cy="4" r="2"/>
              <circle cx="18" cy="8" r="2"/>
              <circle cx="20" cy="16" r="2"/>
              <path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/>
            </svg>
          </div>
          <span class="text-xl font-bold text-white">VetList</span>
        </div>
        <p class="text-gray-300 text-sm leading-relaxed">
          Find trusted veterinarians and animal hospitals near you. Compare services, read reviews, and book appointments with confidence.
        </p>
      </div>

      <!-- About Us Section -->
      <div class="space-y-4">
        <h3 class="text-lg font-semibold text-white mb-4">About Us</h3>
        <ul class="space-y-3">
          <li>
            <a href="/about" class="text-gray-300 hover:text-primary-400 transition-colors text-sm">
              About VetList
            </a>
          </li>
          <li>
            <a href="/careers" class="text-gray-300 hover:text-primary-400 transition-colors text-sm">
              Careers
            </a>
          </li>
          <li>
            <a href="/sitemap-index.xml" class="text-gray-300 hover:text-primary-400 transition-colors text-sm">
              Sitemap
            </a>
          </li>
          <li>
            <a href="/llms.txt" class="text-gray-300 hover:text-primary-400 transition-colors text-sm">
              LLMs.txt
            </a>
          </li>
        </ul>
      </div>

      <!-- For Veterinarians Section -->
      <div class="space-y-4">
        <h3 class="text-lg font-semibold text-white mb-4">For Veterinarians</h3>
        <ul class="space-y-3">
          <li>
            <a href="/add-vet" class="inline-flex items-center gap-2 bg-gradient-to-r from-orange-500 to-red-600 text-white px-3 py-2 rounded-lg hover:from-orange-600 hover:to-red-700 transition-all text-sm font-medium">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
              Add Your Clinic
            </a>
          </li>
          <li>
            <a href="/claim-clinic" class="inline-flex items-center gap-2 bg-gradient-to-r from-blue-500 to-indigo-600 text-white px-3 py-2 rounded-lg hover:from-blue-600 hover:to-indigo-700 transition-all text-sm font-medium">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Claim Your Clinic
            </a>
          </li>
        </ul>
      </div>

      <!-- Need Help Section -->
      <div class="space-y-4">
        <h3 class="text-lg font-semibold text-white mb-4">Need Help?</h3>
        <ul class="space-y-3">
          <li>
            <a href="/contact" class="text-gray-300 hover:text-primary-400 transition-colors text-sm">
              Contact Us
            </a>
          </li>
          <li>
            <a href="/privacy" class="text-gray-300 hover:text-primary-400 transition-colors text-sm">
              Privacy Policy
            </a>
          </li>
          <li>
            <a href="/terms" class="text-gray-300 hover:text-primary-400 transition-colors text-sm">
              Terms of Service
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Section -->
    <div class="border-t border-gray-700 pt-8">
      <div class="flex flex-col md:flex-row md:justify-between md:items-center gap-4">
        <div class="text-sm text-gray-400">
          &copy; 2023-{currentYear} VetList. All rights reserved.
        </div>
      </div>
    </div>
  </div>
</footer>