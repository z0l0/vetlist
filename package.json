{
  "name": "vetlist-profiles",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/precompute-site-data.js",
    "dev": "astro dev",
    "start": "astro dev",
    "prebuild": "node scripts/precompute-site-data.js",
    "build": "node --max-old-space-size=8192 node_modules/.bin/astro build",
    "build:fast": "node scripts/build-fast.js",
    "build:full": "NODE_ENV=production npm run build",
    "build:algolia": "node scripts/build-algolia-index.js",
    "build:with-search": "npm run build:algolia && npm run build",
    "test:algolia": "node scripts/test-algolia.js",
    "generate:og": "node scripts/generate-og-images.js --mode=all --limit=500",
    "clear-cache": "node scripts/clear-cache.js",
    "dedupe": "node scripts/deduplicate-professionals.js",
    "dedupe:global": "node scripts/deduplicate-professionals-global.js",
    "precompute:data": "node scripts/precompute-site-data.js",
    "merge:enriched": "node scripts/merge-enriched-csv.js",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.3.0",
    "@supabase/supabase-js": "^2.49.1",
    "algoliasearch": "^4.25.2",
    "astro": "^5.2.5",
    "bottleneck": "^2.19.5",
    "instantsearch.js": "^4.66.0",
    "papaparse": "^5.5.3"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^5.1.0",
    "@types/algoliasearch": "^4.0.0",
    "dotenv": "^16.6.1",
    "tailwindcss": "^3.4.1",
    "terser": "^5.39.0"
  }
}
